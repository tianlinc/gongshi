<body style="background-color: #f5f5f5;" 
   
  
  
  
 onkeydown="checkBK();"
 onbeforeunload=""
>
<script>
	if( !$.browser.msie ){ // For chrome, firefox onbeforeunload envent.
		window.addEventListener('unload', function(){
			$(document.body).attr("onbeforeunload").call();
		}, false);
	} else {
		window.attachEvent('onunload', function(){
			$(document.body).attr("onbeforeunload").call();
			clearFrames();
		});
	}
</script>
<div class="top-column" id="nameDiv">
		<span class="title-span"></span>
		
		<span id="operateDiv">
			<span class="dropdown-menu-trigger dropdown-menu-down-img"></span>
			<ul class="dropdown-menu-hide">
				
				<li val='&#23548;&#20986;' onclick="exportWorkLog();"></li>
			</ul>
		</span>
		
		
	</div>
	
	<div id="tabPane">
	<ul>
		<li id="reportLink" uid="reportFrame" onclick="showBaseTabLink();" url='/pages/myspace/log/workLogView.jsf?isView=&userId=&reportId='>
			&#22522;&#26412;&#20449;&#24687;
		</li>
		
		<li id="fileTab" uid="fileFrame" onclick="chooseLogFile();" url="">
			&#38468;&#20214;&nbsp;<span id="attachmentCount"></span>
		</li>
		
		
	</ul>
  	</div>
	
	
<form id="exportForm" name="exportForm" method="post" action="/pages/myspace/log/workLogTab.jsf" enctype="application/x-www-form-urlencoded">
<input type="hidden" name="exportForm" value="exportForm" />

		<input type="hidden" id="reportId" name="reportId" />
		
<script type="text/javascript" language="Javascript">function dpf(f) {var adp = f.adp;if (adp != null) {for (var i = 0;i < adp.length;i++) {f.removeChild(adp[i]);}}};function apf(f, pvp) {var adp = new Array();f.adp = adp;var ps = pvp.split(',');for (var i = 0,ii = 0;i < ps.length;i++,ii++) {var p = document.createElement("input");p.type = "hidden";p.name = ps[i];p.value = ps[i + 1];f.appendChild(p);adp[ii] = p;i += 1;}};function jsfcljs(f, pvp, t) {apf(f, pvp);var ft = f.target;if (t) {f.target = t;}f.submit();f.target = ft;dpf(f);};</script>
<a id="exportForm:workLog" href="#" onclick="if(typeof jsfcljs == 'function'){jsfcljs(document.forms['exportForm'],'exportForm:workLog,exportForm:workLog','');}return false"></a><input type="hidden" name="javax.faces.ViewState" id="javax.faces.ViewState" value="" />
</form>
	
	<script type="text/javascript" src="/scripts/plugin/bronzesoft.ui.tabs.js?V=V808R08M07SP0802"></script>
	<script type="text/javascript" src="/scripts/utils/iDropdownMenu.js?V=V808R08M07SP0802"></script>
	<script type="text/javascript">
		var startDate = "", reportId = "";
		var isView = "", userId = "";
		
		$("#tabPane").rdmtabs({height: getLeftMenuH() - 28});
		
		if (top.isAdmin) $("#operateDiv li:last").remove();
		
		$("#operateDiv").dropdownMenu();
		
		function showBaseTabLink() {
		    $("#menuDiv a").show();
			$("#remarkLink, #exportLink").css("display", (reportId == "" ? "none" : "block"));
		}
		
		function chooseWorkLog(type) {
			// get first day of this week
			var today = new Date(), day = today.getDay();
			if(day == 0)  day = 7;
			
			var dateStr = Date.addDays(getCurrentDate(), 1 - day);
			
			// previous week or next week
			if(type != 0) {
				var sDate = new Date(startDate.replace(/-/g, "/"));
				var sDateStr = formatDate(sDate.getFullYear(), sDate.getMonth() + 1, sDate.getDate());
				
				dateStr = Date.addDays(sDateStr, type > 0 ? 7 : -7);
			}
			
			top.iPath.pop();
			
			// set info
			var doc = $("#reportFrame")[0].contentWindow.document;
			
			$("#_startDate", doc).val(dateStr);
			$("#tabPane").rdmtabs("selectTabById", "reportLink");
			$("#operate\\:refreshLog", doc).click();
		}
		
		function chooseLogFile() {
			var url = "/pages/attachment/attachmentList.jsf?type=LOG&objectId=" + reportId;
			$("#menuDiv a[id!='returnLink']").hide();
			$("#fileTab").attr({"url": url, "loaded" : "N"});
		}
		
		function addRemark(editNoteId){
			var url = "/pages/myspace/log/workLogNote.jsf?reportId=" + reportId;
			
			if (editNoteId) {
				url += "&noteId=" + editNoteId;
			}
			
			buildPage("remarkFrame", url);  $("#remarkFrame").css({zIndex: 3});
		}
		
		function exportWorkLog() {
			stopClear(3);
			$("#reportFrame")[0].contentWindow.isClear = "N";
			
			$("#reportId").val(reportId);
			$("#exportForm\\:workLog").click();
		}
 		
 		function refreshLog(id, date, fileCount) {
 			reportId = id;
 			startDate = date;
 			
 			$("#attachmentCount").html("(" + fileCount + ")");
 			$("#fileTab, #remarkLink, #exportLink").css("display", (reportId == "" ? "none" : "block"));
 		}
 		
 		function refreshNote() {
 			clearPage("remarkFrame");
 			$("#reportFrame")[0].contentWindow.refreshNote();
 		}
		
		function afterSave(id, type, fromPage) {
			if (type == 'DOC'&& fromPage == 'attachment') {
		        var con = $("#tabPane").rdmtabs("getSelectedFrame")[0].contentWindow;
			    if (typeof con.afterSave == "function") con.afterSave(id, type, fromPage);
		    } else {
			    $("#reportFrame")[0].contentWindow.refreshLogList();
			}
		}
		
		function returnPage() {
			leavePage(function(){parent.clearPage('logFrame');});
		}
	</script>
<script type="text/javascript" src="/platform/scripts/custom.js?V=V808R08M07SP0802"></script>
</body>
</html>
