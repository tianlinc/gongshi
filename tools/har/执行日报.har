r\n\trowTR = obj;\r\n\trowTR.style.backgroundColor = 'yellow';\r\n}\r\n\r\nfunction exchangeOption(leftObj,rightObj){\r\n\tif(rowTR){\r\n\t\tvar selectRow = rightObj.insertRow(1);\r\n\t\tselectRow.onclick = function(){\r\n\t\t\tgetRowData(this);\r\n\t\t}\r\n\t\tselectRow.ondblclick = function(){\r\n\t\t\texchangeOption(rightObj,leftObj);\r\n\t\t}\t\t\r\n\t\tselectRow.style.backgroundColor = '#666';\r\n\t\tselectRow.style.cursor = 'pointer';\r\n\t\tif(selectRow.parentNode.rows[selectRow.rowIndex+1]){\r\n\t\t\tselectRow.parentNode.rows[selectRow.rowIndex+1].style.backgroundColor = '#FFF';\t\t\t\r\n\t\t}\t\t\r\n\t\tvar cell = null;\t\t\r\n\t\tfor(var i=0; i<rowTR.cells.length; i++){\r\n\t\t\tcell = selectRow.insertCell();\r\n\t\t\tcell.innerHTML = rowTR.cells[i].innerHTML;\r\n\t\t\tif(i==3){\r\n\t\t\t\tcell.style.display = \"none\";\r\n\t\t\t}\r\n\t\t}\t\r\n\t\tvar tempRow = rowTR.parentNode.rows[rowTR.rowIndex+1];\r\n\t\tleftObj.deleteRow(rowTR.rowIndex);\r\n\t\trowTR = tempRow;\r\n\t\tif(rowTR){\r\n\t\t\trowTR.style.backgroundColor='yellow';\t\r\n\t\t}\t\t\t\r\n\t}\t\t\r\n}\r\n\r\n/*\r\n* date1 > date2 return 1\r\n* date1 = date2  return 0\r\n* date1 < date2 return -1\r\n*/\r\nfunction compareTwoDate(date1,date2){\r\n\tif(date1==\"\" || date2==\"\"){\r\n\t\treturn -1;\r\n\t}else if(date1==date2){\r\n\t\treturn 0;\r\n\t}else{\r\n\t\tvar fromYear = date1.substr(0,4);\r\n\t\tvar toYear = date2.substr(0,4);\r\n\t\tif(eval(fromYear + \"<\" + toYear)){\r\n\t\t\treturn -1;\r\n\t\t}else if(eval(fromYear + \">\" + toYear)){\r\n\t\t\treturn 1;\r\n\t\t}else{\r\n\t\t\tvar fromMon = date1.substr(5,2);\r\n\t\t\tvar toMon = date2.substr(5,2);\r\n\t\t\tif(eval(fromMon + \"<\" + toMon)){\r\n\t\t\t\treturn -1;\r\n\t\t\t}else if(eval(fromMon + \">\" + toMon)){\r\n\t\t\t\treturn 1;\r\n\t\t\t}else{\r\n\t\t\t\tvar fromDay = date1.substr(8,2);\r\n\t\t\t\tvar toDay = date2.substr(8,2);\r\n\t\t\t\tif(eval(fromDay + \">\" + toDay)){\r\n\t\t\t\t\treturn 1;\r\n\t\t\t\t} else if(eval(fromDay + \"==\" + toDay)){\r\n\t\t\t\t\treturn 0;\r\n\t\t\t\t}else{\r\n\t\t\t\t\treturn -1;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/*\r\n* select all checkbox\r\n*/\r\nfunction selectAllCheckBoxs(itemObjName,isSelected){\t\r\n\tif(isSelected == null){\r\n\t\tisSelected = true;\r\n\t}\r\n\tvar itemObj;\r\n\titemObj = document.getElementsByName(itemObjName);\r\n\tif (itemObj!=null){\r\n\t\t\t\tif (isNaN(itemObj.length)){\r\n\t\t\t\t   \tif (!itemObj.disabled){\r\n\t\t\t\t\t\t\t\titemObj.checked=isSelected;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t}else{\r\n\t\t\t\t    for(i=0;i<itemObj.length;i++){\r\n\t\t\t\t    \t\tif (!itemObj[i].disabled){\r\n\t\t\t\t\t   \t\t\t\titemObj[i].checked=isSelected;\r\n\t\t\t\t\t  \t\t}\r\n\t\t\t\t    }\t\r\n\t\t\t\t}\r\n\t}\r\n}\r\n\r\nfunction searchMulData(idObj,nameObj,url,tempObject, rtnValResolver){\r\n\tsearchMulData2(idObj,nameObj,url,tempObject, null, rtnValResolver);\r\n}\r\n\r\nfunction searchMulData2 (idObj,nameObj,url,tempObject, h, rtnValResolver) {\r\n\t\r\n\tif(!url) return;\r\n    if(nameObj) nameObj.blur();        \r\n    \r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj ? $(idObj).val() : $(nameObj).attr(\"ids\");  \r\n    dialogArgument[1] = nameObj ? $(nameObj).val() : \"\";\r\n    if(tempObject){\r\n        dialogArgument[2] = tempObject;\r\n    }\r\n    \r\n    h = h ? h : ((url.indexOf(\"searchUser\") >= 0\r\n    \t\t|| url.indexOf(\"searchProject\") >= 0\r\n    \t\t|| url.indexOf(\"searchProduct\") >= 0\r\n    \t\t|| url.indexOf(\"searchDepart\") >= 0\r\n    \t\t|| url.indexOf(\"searchPlan\") >= 0\r\n    \t\t|| url.indexOf(\"changeVersionWin\") >= 0\r\n    \t\t|| url.indexOf(\"searchMilestone\") >= 0 \r\n    \t\t|| url.indexOf(\"searchWorkFlowTypeMul\") >= 0 \r\n    \t\t|| url.indexOf(\"searchFinanceSubjectMul\") >=0 )? 510 : 420);\r\n    \r\n    showModDialog(url, 600, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        if(msg != null) {\r\n            if(msg == ''){\r\n     