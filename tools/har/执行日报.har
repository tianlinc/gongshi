            "text": "function _download_operation_manual($obj) {\r\n\tvar id = $obj.attr(\"ids\");\r\n\tjUploadConfigBean.dyn_getDownConfig(id, \"\", {\r\n        callback: function(r) {\r\n            if (r) {\r\n            \tif (r.length == 1 && r[0] == \"N\") {\r\n                    rdmAlert($(\"#_fileNotExistMsg\").html());\r\n                } else if (r.length == 2 && r[0] == \"PDM\") {\r\n                    downloadPdmDocument(r[1]);\r\n                } else {\r\n                    $(\"#_file_dir\").val(r[2]);\r\n                    $(\"#_file_address\").val(r[3]);\r\n                    $(\"#_file_name\").val(r[4]);\r\n                    $(\"#_file_extname\").val(r[5]);\r\n                    var httpType = \"http\";\r\n                    /* remove the target.*/\r\n                    if ($.browser.safari) {\r\n                        $(\"#_file_downform\").attr(\"target\", \"\");\r\n                    }\r\n\r\n                    var servlet;\r\n                    if (!r[0]) {\r\n                        servlet = powerPath + \"download\";\r\n                    } else if ((location.href.indexOf(\"localhost\") >= 0 && \"localhost\" == r[0]) || (location.href.indexOf(\"127.0.0.1\") >= 0 && \"127.0.0.1\" == r[0])) {\r\n                        servlet = powerPath + \"download\";\r\n                        // local host.\r\n                    } else if (r[0] != \"localhost\" && r[0] != \"127.0.0.1\") {\r\n                        servlet = httpType + \"://\" + r[0] + \":\" + r[1] + \"/download\";\r\n                    } else {\r\n                        var href = location.href;\r\n                        href = href.replaceAll(\"http://\", \"\");\r\n                        var ip = href.substring(0, href.indexOf(\":\"));\r\n                        var prot = href.substring(href.indexOf(\":\") + 1, href.indexOf(\"/\"));\r\n\r\n                        servlet = httpType + \"://\" + ip + \":\" + prot + \"/download\";\r\n                    }\r\n                    $(\"#_file_downform\").attr(\"action\", servlet).submit();\r\n                }\r\n            }\r\n        }\r\n    } );\r\n}\r\n\r\nfunction _sendDownRequest(r) {\r\n\t\r\n\tstopClear(3);\r\n\t\r\n\ttry {\r\n\t\tparent.setClear();\r\n\t} catch (e) {\r\n\t}\r\n\r\n\tif (r.length == 1 && r[0] == \"N\") {\r\n\t\trdmAlert($(\"#_fileNotExistMsg\").html());\r\n\t} else if (r.length == 2 && r[0] == \"PDM\") { // old document\r\n\t    downloadPdmDocument(r[1]);\r\n\t} else {\r\n\t\t$(\"#_file_dir\").val(r[2]);\r\n\t\t$(\"#_file_address\").val(r[3]);\r\n\t\t$(\"#_file_name\").val(r[4]);\r\n\t\t$(\"#_file_extname\").val(r[5]);\r\n\t\tvar httpType = \"http\";\r\n\t\t/* remove the target.*/\r\n\t\tif ($.browser.safari) { $(\"#_file_downform\").attr(\"target\", \"\"); }\r\n\t\t\r\n\t\tvar servlet;\r\n\t\tif(!r[0]){\r\n\t\t\tservlet = powerPath + \"download\";\r\n\t\t} else if((location.href.indexOf(\"localhost\") >= 0 && \"localhost\" == r[0]) || (location.href.indexOf(\"127.0.0.1\") >= 0 && \"127.0.0.1\" == r[0]) ) {\r\n\t\t\tservlet = powerPath + \"download\";  // local host.\r\n\t\t} else {\r\n\t\t\tvar href = location.href;\r\n\t\t\thref = href.replaceAll(\"http://\",\"\"); \r\n\t\t\tvar ip = href.substring(0,href.indexOf(\":\"));\r\n\t\t\tvar prot = href.substring(href.indexOf(\":\") + 1,href.indexOf(\"/\"));\r\n\t\t\t\r\n\t\t\tservlet = httpType + \"://\" + ip + \":\" + prot + \"/download\";\r\n\t\t}\r\n\t\t$(\"#_file_downform\").attr(\"action\", servlet).submit();\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"pages/common/searchUserMul.jsf\") > -1 || custom_url.indexOf(\"/pages/common/searchUserWin.jsf\") > -1 || custom_url.indexOf(\"/pages/security/roleGroupMemberDialog.jsf\") > -1) {\r\n\t// 用户选择框改造\r\n\t// 固定所属项目  \r\n\t$('img.search-type').hide();\r\n\t\r\n\tif ($('td[m=\"Department\"]').css(\"display\") != 'none') {\r\n\t\t$('td[m=\"Department\"]').addClass('hide');\r\n\t\t$('td[m=\"Project\"]').removeClass('hide');\r\n\t} else if ($('td[m=\"Product\"]').css(\"display\") != 'none') {\r\n\t\t$('td[m=\"Product\"]').addClass('hide');\r\n\t\t$('td[m=\"Project\"]').removeClass('hide');\r\n\t}\r\n\t// 隐藏 常用联系人 显示下级\r\n\t$('#frequentContact').hide();\r\n\t$('#showAll').hide();\r\n\t\r\n\tsearchUser();\r\n\t\r\n\t// 全局缓存与分页状态管理\r\n\tvar userStore = {\r\n\t\tallUsers: [],       // 缓存全部用户数据\r\n\t  \tcurrentPage: 0,     // 当前加载到第几页\r\n\t  \tpageSize: 100,      // 每页加载数量\r\n\t  \tisLoading: false    // 防止重复触发加载\r\n\t};\r\n\t\r\n\tfunction initHideMsg() {\r\n\t\t$(\"#_body_userInfo\").empty();\r\n\t\t\r\n\t\t// 重置分页状态\r\n\t\tuserStore.currentPage = 0;\r\n\t\tuserStore.allUsers = [];\r\n\t\t  \r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.common.SearchUser\", \"getNewUser\", [$(\"#matchText\").val(), $(\"#scopeDiv\").attr(\"uid\")], function(d){\r\n\t\t\tif (d) {\r\n\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\r\n\t\t\t\tuserStore.allUsers = d; // 缓存全部数据\r\n\t\t        renderUserPage(0);     // 先渲染第一页\r\n\t\t        setupScrollListener(); // 绑定滚动监听\r\n\t\t\t}\r\n\t\t}, true);\r\n\t}\r\n\t\r\n\t// 渲染指定页的用户数据\r\n\tfunction renderUserPage(page) {\r\n\t\tif (userStore.isLoading) return;\r\n\t\tuserStore.isLoading = true;\r\n\t\t\r\n\t\tconst start = page * userStore.pageSize;\r\n\t\tconst end = start + userStore.pageSize;\r\n\t\tconst pageData = userStore.allUsers.slice(start, end);\r\n\t\t\r\n\t\tif (pageData.length === 0) {\r\n\t\t\tuserStore.isLoading = false;\r\n\t\t\treturn; // 没有更多数据了\r\n\t\t}\r\n\t\t\r\n\t\tvar html = \"<colgroup id='tc'>\";\r\n\t\t$('th', '#userInfo .head-div').each(function () {\r\n\t\t\tvar w = $(this).width() + 2;\r\n\t\t\thtml += \"<col style='width:\"+w+\"px;' />\";\r\n\t\t});\r\n\t\thtml += \"</colgroup>\";\r\n\t\tif ($(\"#tc\").length === 0) {\r\n\t\t\t$(\"#_body_userInfo\").before(html);\r\n\t\t}\r\n\t\t\r\n\t\tvar slt = $('.selected-title').length > 0;\r\n\t\tvar rows = [];\r\n\t\t\r\n\t\tfor (var i = 0; i < pageData.length; i++) {\r\n\t\t\tvar user = pageData[i];\r\n\t\t\tvar rowIndex = start + i; // 保持奇偶行样式与全量渲染一致\r\n\t\t\tif (slt) {\r\n\t\t\t\t// 多选模式\r\n\t\t\t\trows.push(\r\n\t\t\t\t\t\t'<tr class=\"body-row ', rowIndex%2===0 ? '' : 'odd','\" id=\"', user[0],\r\n\t\t\t\t\t\t\t\t'\" onclick=\"tableMain.table(&quot;selectRow&quot;, $(this));\" ondblclick=\"$(&quot;td:eq(0) img&quot;, this).click();\">',\r\n\t\t\t\t\t\t\t\t'<td style=\"text-align: center; width: 42px; border-top: 0px;\">',\r\n\t\t\t\t\t\t\t\t'<img src=\"/images/tabAdd-hightlight.gif\" onclick=\"selectUser($(this))\" style=\"margin-right: 20px;\"></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 242px; border-top: 0px;\"><div>', user[1],'</div></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 122px; border-top: 0px;\"><div>', user[2],'</div></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 2px; border-top: 0px;\"><div>', user[3],'</div></td>',\r\n\t\t\t\t\t\t\t\t'</tr>'\r\n\t\t\t\t);\r\n\t\t\t} else {\r\n\t\t\t\t// 单选模式\r\n\t\t\t\trows.push(\r\n\t\t\t\t\t\t'<tr class=\"body-row ', rowIndex%2===0 ? '' : 'odd','\" id=\"', user[0],\r\n\t\t\t\t\t\t\t\t'\" onclick=\"seleteItem($(this));\" ondblclick=\"saveUser();\">',\r\n\t\t\t\t\t\t\t\t'<td style=\"text-align: center; width: 42px; border-top: 0px;\">',\r\n\t\t\t\t\t\t\t\t'<input type=\"radio\" name=\"user\" value=\"', user[0],'\"></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 242px; border-top: 0px;\"><div class=\"auto-link\" style=\"cursor: default;\" title=\"双击选择用户，点击用户名称可查看工作负荷\"><a href=\"#\" onclick=\"return viewWork($(this).closest(&quot;tr&quot;));\">', user[1],'</a></div></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 122px; border-top: 0px;\"><div>', user[2],'</div></td>',\r\n\t\t\t\t\t\t\t\t'<td style=\"width: 2px; border-top: 0px;\"><div>', user[3],'</div></td>',\r\n\t\t\t\t\t\t\t\t'</tr>'\r\n\t\t\t\t);\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\t$(\"#_body_userInfo\").append(rows.join(''));\r\n\t\tuserStore.currentPage++;\r\n\t\tuserStore.isLoading = false;\r\n\t}\r\n\t\r\n\t// 监听滚动触底事件\r\n\tfunction setupScrollListener() {\r\n\t\tvar $scrollContainer = $('#itemPanel');\r\n\t\tif (!$scrollContainer.length) return;\r\n\t\t\r\n\t\t$scrollContainer.unbind(\"scroll\").bind(\"scroll\", function() {\r\n\t\t\tconst scrollTop = this.scrollTop; // 替代 $(this).scrollTop()（也可用，但原生更稳定）\r\n\t\t    const scrollHeight = this.scrollHeight; // 低版本jQuery中 $(this)[0].scrollHeight 等价于 this.scrollHeight\r\n\t\t    const clientHeight = this.clientHeight; // 替代 $(this).height()（避免jQuery 1.4 高度计算偏差）\r\n\t\t\t\r\n\t\t\t// 触底阈值：距离底部 15px 时触发加载\r\n\t\t\tif (scrollTop + clientHeight >= scrollHeight - 15 && !userStore.isLoading) {\r\n\t\t\t\trenderUserPage(userStore.currentPage);\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\t\r\n\t\r\n\t// 重写方法，添加规则：隐藏部门列\r\n\tfunction reselectItem() {\r\n\t\tif (selectId && selectId != \"\") {\r\n\t\t\t$(\"#\" + selectId + \" input:radio\").attr(\"checked\", true);\r\n\t\t}\r\n\t\t\r\n\t\tinitHideMsg();\r\n\t}\r\n\t\r\n\tfunction reselectItems(){\r\n\t\t$(\"#selectBody li\").each(function(){\r\n\t\t\t$(\"#\" + $(this).attr(\"uid\") + \" td:eq(0) img\").addClass(\"item-selected\");\r\n\t\t});\r\n\t\t\r\n\t\tinitHideMsg();\r\n\t}\r\n}"
          },
