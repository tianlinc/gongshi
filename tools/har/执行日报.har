            "text": "function controlKeyInput(obj,reg){\r\n  \twhile(reg.test(obj.value)){\r\n   \t\tobj.value=obj.value.replace(reg,'');\r\n  \t}\r\n}\r\n\r\nfunction Trim(ui){ \r\n\tvar notValid=/(^\\s)|(\\s$)/; \r\n\twhile(notValid.test(ui))\r\n\t{ \r\n\t\tui=ui.replace(notValid,\"\");\r\n\t} \r\n\treturn ui;\r\n} \r\n\r\nfunction getStringLength(str){\r\n\tvar defaultLength = 2;\r\n\ttry {\r\n\t\tdefaultLength = parseInt((defaultCharLength && defaultCharLength != '' && defaultCharLength > 1) ? defaultCharLength : 2);\r\n\t} catch(e) {\r\n\t\tdefaultLength = 2;\r\n\t}\r\n    var sLen =0;\r\n    if (str && str.length) {\r\n\t    for (i=0;i<str.length;i++){\r\n\t       if (str.charCodeAt(i)>255 || str.charCodeAt(i) == 183){\r\n\t\t      sLen+=defaultLength;\r\n\t\t   }else{\r\n\t\t    sLen++;\r\n\t\t   }\r\n\t    }\r\n    }\r\n\treturn sLen;\r\n}\r\n\r\nfunction hiddenMsgSpan(objSign,num){\r\n  \tif(num<0){\r\n  \t\treturn;\r\n  \t}\r\n  \tfor(var i=0;i<=num;i++){\r\n  \t\t//var obj = document.getElementById(objSign+i);\r\n  \t\t//if(obj){\r\n  \t\t//\tobj.style.display = \"none\";\r\n  \t\t//}\r\n\t  \tif($('#'+objSign+i).size() > 0){\r\n\t  \t\t$('#'+objSign+i).hide();\r\n\t  \t}\r\n  \t}\r\n}\r\n\r\nfunction isEmail(sEmail){\r\n\tvar regu =\r\n\t\t\t\"^(([0-9a-zA-Z]+)|([0-9a-zA-Z]+[_.0-9a-zA-Z-]*[0-9a-zA-Z]+))@([a-zA-Z0-9-]+[.])+([a-zA-Z]+)$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = sEmail.match(re);\r\n\tif (r==sEmail)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isNumber(numberStr){\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction toDecimal(val, digit) {\r\n\tvar t = parseFloat(val);\r\n\t\r\n\tif (isNaN(t)) return 0;\r\n\t\r\n\tdigit = digit ? digit : 1;\r\n\t\r\n\treturn Math.round(t * 10 * digit)/(10 * digit)\r\n}\r\n\r\nfunction isFloat(numberStr)\t{\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^([0-9]*)(\\\\.)?[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isAllFloat(numberStr)\t{\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^(-?[0-9]*)(\\\\.)?[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isInteger(numberStr){\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^-?\\\\d+$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction ascllToGBK(codeStr){\r\n\tif(codeStr!=null&&codeStr!=''){\r\n\t\tif(codeStr.substr(0,1)==\"#\"){\r\n\t\t\treturn String.fromCharCode(codeStr.substr(1,6));\r\n\t\t}\r\n\t\treturn codeStr;\r\n\t}\r\n\treturn \"\";\r\n}\r\n\r\nfunction printValue(val0,val1,val2){\r\n\tif(val0=='Y'){\r\n\t\tdocument.write(val1);\r\n\t\treturn;\r\n\t}\r\n\tif(val0=='N'){\r\n\t\tdocument.write(val2);\r\n\t\treturn;\r\n\t}\r\n\tdocument.write(\"\");\r\n}\r\n\r\nfunction searchData(idObj,nameObj,url,isDefault,rtnValResolver){\r\n\tif(url == null || url == \"\") return;\r\n\t\t\r\n\tif(isDefault == null || isDefault){\t\r\n\t\tif (idObj.value && idObj.value.length <= 36) {\r\n\t\t\tif(url.indexOf(\"?\")>=0){\r\n\t\t\t\turl = url + \"&objectIds=\"+idObj.value;\r\n\t\t\t}else{\r\n\t\t\t\turl = url + \"?objectIds=\"+idObj.value;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj.value;  \r\n    dialogArgument[1] = nameObj.value;\r\n    \r\n    var h = (url.indexOf(\"searchUser\") >= 0\r\n    \t\t|| url.indexOf(\"searchProject\") >= 0\r\n    \t\t|| url.indexOf(\"searchProduct\") >= 0\r\n    \t\t|| url.indexOf(\"searchDepart\") >= 0) ? 510 : 430;\r\n     \r\n    showModDialog(url, 600, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        \r\n        if(msg!=null){\r\n\t\t   if(msg==''){\r\n\t\t\t  idObj.value = '';\r\n\t\t\t  nameObj.value = '';\r\n\t\t   }else{\r\n\t\t\t  var array = msg.split(\"%&*%\");\r\n\t\t\t  idObj.value = array[0];\r\n\t\t\t  nameObj.value = escapeHTML(array[1]);\r\n\t\t   }\r\n\t\t   rtnVal='Y';\r\n\t    }\r\n\t    if(typeof rtnValResolver == 'function'){\r\n\t       rtnValResolver(rtnVal);\r\n\t    }\r\n    });\t\r\n\t\r\n\treturn;\t\t\r\n}\r\n\r\nfunction filterData(idObj,nameObj,url,w,h,isDefault,rtnValResolver) {\r\n\tif(url == null || url == \"\") return;\r\n\t\t\r\n\tif(isDefault == null || isDefault){\t\r\n\t\tif (idObj.value && idObj.value.length <= 36) {\r\n\t\t\tif(url.indexOf(\"?\")>=0){\r\n\t\t\t\turl = url + \"&objectIds=\"+idObj.value;\r\n\t\t\t}else{\r\n\t\t\t\turl = url + \"?objectIds=\"+idObj.value;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj.value;  \r\n    dialogArgument[1] = nameObj.value;\r\n     \r\n    showModDialog(url, w, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        if(msg!=null){\r\n\t\t   if(msg==''){\r\n\t\t\t  idObj.value = '';\r\n\t\t\t  nameObj.value = '';\r\n\t\t   }else{\r\n\t\t\t  var array = msg.split(\"%&*%\");\r\n\t\t\t  idObj.value = array[0];\r\n\t\t\t  nameObj.value = escapeHTML(array[1]);\r\n\t\t   }\r\n\t\t   rtnVal='Y';\r\n\t    }\r\n\t    if(typeof rtnValResolver == 'function'){\r\n\t       rtnValResolver(rtnVal);\r\n\t    }\r\n    });\t\r\n\t\r\n\treturn;\t\t\r\n}\r\n\r\nfunction searchBelong($inp, callback, param) {\r\n\tvar scope = $inp.attr(\"scope\"), mul = $inp.attr(\"mul\"), projectType = $inp.attr(\"projectType\");\r\n\t\r\n\tvar url = powerPath + \"pages/common/searchBelong\" + ((mul && mul == \"Y\") ? \"Mul\" : \"\") + \"Win.jsf?scope=\" + (scope ? scope : \"\") + (projectType ? \"&type=\" + projectType : \"\");\r\n\t\r\n\t// add project id or product id or is relate param\r\n\tif(param && param[0])  url += \"&projectId=\" + param[0];\r\n\tif(param && param[1])  url += \"&productId=\" + param[1];\r\n\tif(param && param[2])  url += \"&isRelate=\" + param[2];\r\n\t\r\n\tvar height = (scope && scope.split(\",\").length == 1) ? ((mul && mul == \"Y\") ? 475 : 460) : 500;\r\n\t\r\n\tshowModDialog(url, 600, height, [$inp, scope], function(msg) {\r\n\t\tif(typeof callback == \"function\")  callback($inp);\r\n\t});\r\n}\r\n\r\nfunction selectTaskStatus(idObj,nameObj,functionName){\r\n\t\tvar urlAddress = powerPath + \"pages/common/taskStatusSelect.jsf\";\r\n\t\tvar dialogArgument = new Array();\r\n    dialogArgument[0] = idObj.value;  \r\n    dialogArgument[1] = nameObj.value;\r\n    showModDialog(urlAddress,300,250,dialogArgument,function(msg){\r\n    if(msg!=null){\r\n\t\tif(msg==''){\r\n\t\t\tidObj.value = '';\r\n\t\t\tnameObj.value = '';\r\n\t\t}else{\r\n\t\t\tvar array = msg.split(\"%&*%\");\r\n\t\t\tidObj.value = array[0];\r\n\t\t\tnameObj.value = escapeHTML(array[1]);\r\n\t\t\tnameObj.title = escapeHTML(array[1]);\r\n\t\t}\r\n\t}\r\n\tif(functionName && dialogArgument[0] != idObj.value){\r\n\t\teval(functionName);\r\n\t}\r\n    });\r\n\treturn;\t\t\r\n}\r\n\r\nfunction escapeHTML(value){\r\n\tif(value == null){\r\n\t\treturn \"\";\r\n\t}else{\r\n\t\tvar re = /&amp;/g;\r\n\t\tvar re2 = /&gt;/g;\r\n\t\tvar re3 = /&lt;/g;\r\n\t\treturn value.replace(re,\"&\").replace(re2,\">\").replace(re3,\"<\");;\r\n\t}\r\n}\r\n\r\nfunction selectDefault(objId,value){\r\n\tif(objId==null || objId=='' || value==''){\r\n\t\treturn;\r\n\t}\r\n\tvar obj = value.split(',');\r\n\tfor(i=0;i<obj.length;i++){\r\n\t\tif(document.getElementById(objId+obj[i])){\r\n\t\t\tdocument.getElementById(objId+obj[i]).checked='true';\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/*\r\n * Using Option  to exchange value from left to right or from right to left.  \r\n */\r\n\tvar rowTR = null;\r\nfunction getRowData(obj){\r\n\tif(rowTR){\r\n\t\trowTR.style.backgroundColor = '#FFF';\r\n\t}\r\n\trowTR = obj;\r\n\trowTR.style.backgroundColor = 'yellow';\r\n}\r\n\r\nfunction exchangeOption(leftObj,rightObj){\r\n\tif(rowTR){\r\n\t\tvar selectRow = rightObj.insertRow(1);\r\n\t\tselectRow.onclick = function(){\r\n\t\t\tgetRowData(this);\r\n\t\t}\r\n\t\tselectRow.ondblclick = function(){\r\n\t\t\texchangeOption(rightObj,leftObj);\r\n\t\t}\t\t\r\n\t\tselectRow.style.backgroundColor = '#666';\r\n\t\tselectRow.style.cursor = 'pointer';\r\n\t\tif(selectRow.parentNode.rows[selectRow.rowIndex+1]){\r\n\t\t\tselectRow.parentNode.rows[selectRow.rowIndex+1].style.backgroundColor = '#FFF';\t\t\t\r\n\t\t}\t\t\r\n\t\tvar cell = null;\t\t\r\n\t\tfor(var i=0; i<rowTR.cells.length; i++){\r\n\t\t\tcell = selectRow.insertCell();\r\n\t\t\tcell.innerHTML = rowTR.cells[i].innerHTML;\r\n\t\t\tif(i==3){\r\n\t\t\t\tcell.style.display = \"none\";\r\n\t\t\t}\r\n\t\t}\t\r\n\t\tvar tempRow = rowTR.parentNode.rows[rowTR.rowIndex+1];\r\n\t\tleftObj.deleteRow(rowTR.rowIndex);\r\n\t\trowTR = tempRow;\r\n\t\tif(rowTR){\r\n\t\t\trowTR.style.backgroundColor='yellow';\t\r\n\t\t}\t\t\t\r\n\t}\t\t\r\n}\r\n\r\n/*\r\n* date1 > date2 return 1\r\n* date1 = date2  return 0\r\n* date1 < date2 return -1\r\n*/\r\nfunction compareTwoDate(date1,date2){\r\n\tif(date1==\"\" || date2==\"\"){\r\n\t\treturn -1;\r\n\t}else if(date1==date2){\r\n\t\treturn 0;\r\n\t}else{\r\n\t\tvar fromYear = date1.substr(0,4);\r\n\t\tvar toYear = date2.substr(0,4);\r\n\t\tif(eval(fromYear + \"<\" + toYear)){\r\n\t\t\treturn -1;\r\n\t\t}else if(eval(fromYear + \">\" + toYear)){\r\n\t\t\treturn 1;\r\n\t\t}else{\r\n\t\t\tvar fromMon = date1.substr(5,2);\r\n\t\t\tvar toMon = date2.substr(5,2);\r\n\t\t\tif(eval(fromMon + \"<\" + toMon)){\r\n\t\t\t\treturn -1;\r\n\t\t\t}else if(eval(fromMon + \">\" + toMon)){\r\n\t\t\t\treturn 1;\r\n\t\t\t}else{\r\n\t\t\t\tvar fromDay = date1.substr(8,2);\r\n\t\t\t\tvar toDay = date2.substr(8,2);\r\n\t\t\t\tif(eval(fromDay + \">\" + toDay)){\r\n\t\t\t\t\treturn 1;\r\n\t\t\t\t} else if(eval(fromDay + \"==\" + toDay)){\r\n\t\t\t\t\treturn 0;\r\n\t\t\t\t}else{\r\n\t\t\t\t\treturn -1;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/*\r\n* select all checkbox\r\n*/\r\nfunction selectAllCheckBoxs(itemObjName,isSelected){\t\r\n\tif(isSelected == null){\r\n\t\tisSelected = true;\r\n\t}\r\n\tvar itemObj;\r\n\titemObj = document.getElementsByName(itemObjName);\r\n\tif (itemObj!=null){\r\n\t\t\t\tif (isNaN(itemObj.length)){\r\n\t\t\t\t   \tif (!itemObj.disabled){\r\n\t\t\t\t\t\t\t\titemObj.checked=isSelected;\r\n\t\t\t\t\t\t}\r\n\t\t\t\t}else{\r\n\t\t\t\t    for(i=0;i<itemObj.length;i++){\r\n\t\t\t\t    \t\tif (!itemObj[i].disabled){\r\n\t\t\t\t\t   \t\t\t\titemObj[i].checked=isSelected;\r\n\t\t\t\t\t  \t\t}\r\n\t\t\t\t    }\t\r\n\t\t\t\t}\r\n\t}\r\n}\r\n\r\nfunction searchMulData(idObj,nameObj,url,tempObject, rtnValResolver){\r\n\tsearchMulData2(idObj,nameObj,url,tempObject, null, rtnValResolver);\r\n}\r\n\r\nfunction searchMulData2 (idObj,nameObj,url,tempObject, h, rtnValResolver) {\r\n\t\r\n\tif(!url) return;\r\n    if(nameObj) nameObj.blur();        \r\n    \r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj ? $(idObj).val() : $(nameObj).attr(\"ids\");  \r\n    dialogArgument[1] = nameObj ? $(nameObj).val() : \"\";\r\n    if(tempObject){\r\n        dialogArgument[2] = tempObject;\r\n    }\r\n    \r\n    h = h ? h : ((url.indexOf(\"searchUser\") >= 0\r\n    \t\t|| url.indexOf(\"searchProject\") >= 0\r\n    \t\t|| url.indexOf(\"searchProduct\") >= 0\r\n    \t\t|| url.indexOf(\"searchDepart\") >= 0\r\n    \t\t|| url.indexOf(\"searchPlan\") >= 0\r\n    \t\t|| url.indexOf(\"changeVersionWin\") >= 0\r\n    \t\t|| url.indexOf(\"searchMilestone\") >= 0 \r\n    \t\t|| url.indexOf(\"searchWorkFlowTypeMul\") >= 0 \r\n    \t\t|| url.indexOf(\"searchFinanceSubjectMul\") >=0 )? 510 : 420);\r\n    \r\n    showModDialog(url, 600, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        if(msg != null) {\r\n            if(msg == ''){\r\n               $(idObj).val('');\r\n               $(nameObj).val('');\r\n            }else{\r\n               var array = msg.split(\"%&*%\");\r\n               $(idObj).val(array[0]);\r\n               $(nameObj).val(escapeHTML(array[1]));\r\n            }\r\n            rtnVal = \"Y\";\r\n        }\r\n        \r\n        if(typeof rtnValResolver =='function'){\r\n           if(array){\r\n           \t    rtnValResolver(rtnVal, array[0]);\r\n           } else {\r\n           \t\trtnValResolver(rtnVal);\r\n           }\r\n        }\r\n    });\r\n}\r\n\r\n\r\n// This function is for stripping leading and trailing spaces\r\nString.prototype.trim = function () {\r\n    return this.replace(/^\\s*(\\S*(\\s+\\S+)*)\\s*$/, \"$1\");\r\n};\r\n\r\nfunction checkCh(){\r\n\tif(window.event.keyCode === 13){\r\n\t\treturn false;\r\n\t}else{\r\n\t\treturn true;\r\n\t}\r\n}\r\n\r\nfunction enCode(str){\r\n    if (!str) {\r\n    \treturn \"\";\r\n    }\r\n    return str.replace(/&/g,\"&\").replace(/</g,\"&lt;\").replace(/>/g,\"&gt;\").replace(/\\\"/g,\"&#34;\").replace(/\\'/g,\"&#39;\");\r\n}\r\n\r\n/* This function is used to set cookies */\r\nfunction setCookie(name,value,expires,path,domain,secure) {\r\n  document.cookie = name + \"=\" + escape (value) +\r\n    ((expires) ? \"; expires=\" + expires.toGMTString() : \"\") +\r\n    ((path) ? \"; path=\" + path : \"\") +\r\n    ((domain) ? \"; domain=\" + domain : \"\") + ((secure) ? \"; secure\" : \"\");\r\n}\r\n\r\n/* This function is used to get cookies */\r\nfunction getCookie(name) {\r\n    var prefix = name + \"=\" \r\n    var start = document.cookie.indexOf(prefix) \r\n\r\n    if (start==-1) {\r\n        return null;\r\n    }\r\n    \r\n    var end = document.cookie.indexOf(\";\", start+prefix.length) \r\n    if (end==-1) {\r\n        end=document.cookie.length;\r\n    }\r\n\r\n    var value=document.cookie.substring(start+prefix.length, end) \r\n    return unescape(value);\r\n}\r\n\r\n/* This function is used to delete cookies */\r\nfunction deleteCookie(name,path,domain) {\r\n  if (getCookie(name)) {\r\n    document.cookie = name + \"=\" +\r\n      ((path) ? \"; path=\" + path : \"\") +\r\n      ((domain) ? \"; domain=\" + domain : \"\") +\r\n      \"; expires=Thu, 01-Jan-70 00:00:01 GMT\";\r\n  }\r\n}\r\n\r\n/* show or hide page content, see projectAdd page. */\r\nfunction displayDIV(obj,img){\r\n\tif(obj.style.display==\"none\"){\r\n\t\tobj.style.display=\"\";\r\n\t\tobj.style.position=\"static\";\r\n        try{\r\n          \timg.src=powerPath+\"images/icon001.gif\";\r\n        }catch(e){}\r\n\t}else{\r\n\t\tobj.style.display=\"none\";\r\n\t\tobj.style.position=\"absolute\";\r\n        try{\r\n\t\t\timg.src=powerPath+\"images/icon002.gif\";\r\n        }catch(e){}\r\n\t}\r\n}\r\n\r\nfunction getSelValue(oid){ // get h:selectonemenu's label.\r\n\tvar se = document.getElementById(oid);\r\n    var sid = se.selectedIndex;\r\n    var ops = se.children;\r\n    var op = ops[sid];\r\n    \r\n    return op ? op.innerHTML : \"\";\r\n}\r\n\r\nfunction getSelValueByObj(obj){\r\n\tvar sid = obj.selectedIndex;\r\n    var ops = obj.children;\r\n    return ops[sid].innerHTML;\r\n}\r\n\r\nfunction getDays(s1, s2){\r\n\ts1 = s1.replace(/-/g, \"/\"); \r\n\ts2 = s2.replace(/-/g, \"/\"); \r\n\ts1 = new Date(s1);\r\n\ts2 = new Date(s2);\r\n\r\n\tvar days= s1.getTime() - s2.getTime(); \r\n\treturn parseInt(days / (1000 * 60 * 60 * 24));\r\n}\r\n\r\nfunction getRangePos(obj){\r\n\tif(typeof(obj.selectionStart) == \"number\"){ \r\n\t\treturn obj.selectionStart; \r\n\t}else if(document.selection){\r\n\t\tvar strat = 0;\r\n\t\tvar range = document.selection.createRange();\r\n\t\tvar range_all = document.body.createTextRange();\r\n\t\t \r\n\t\trange_all.moveToElementText(obj); \r\n \r\n\t\tfor (var start=0; range_all.compareEndPoints(\"StartToStart\", range) < 0; start++){\r\n\t\t\trange_all.moveStart('character', 1);\r\n\t\t}\r\n\t\t \r\n\t\tfor (var i = 0; i <= start; i ++){ \r\n\t\t\tif (obj.value.charAt(i) == '\\n'){start++;} \r\n\t\t}\r\n\t\treturn start; \r\n\t}\r\n}\r\n\t  \r\nfunction setRangePos(obj, pos){\r\n\ttry {\r\n\t\tobj.focus();\r\n\t\r\n\t \tif (obj.setSelectionRange){\r\n\t   \t\tobj.setSelectionRange(pos, pos);\r\n\t \t}else if (obj.createTextRange){\r\n\t   \t\tvar range = obj.createTextRange();\r\n\t    \trange.collapse(true);\r\n\t    \trange.moveStart('character', pos);\r\n\t    \trange.moveEnd('character', pos);\r\n\t    \trange.select();\r\n\t \t}\r\n\t}catch(e){}\r\n}\r\n\r\nfunction verifyNumber($o, prec, min, max){\r\n\tvar s = $o.val();\r\n\tif (s == \".\") {$o.val(\"\"); return ;}\r\n\tif (s == \"-\") {return; }\r\n\tif (s.trim() != s) {$o.val(s.trim()); s=s.trim();}\r\n\tif (!s) {$o.val(\"\"); return;}\r\n\t\r\n\tif (isAllFloat(s)) {\r\n\t\tvar dot = s.indexOf(\".\");\r\n\t\t\r\n\t\tif (dot >= 0 && prec && prec != \"\") {\r\n\t\t\tvar bit = s.substring(dot, s.length).length - 1;\r\n\t\t\t\r\n\t\t\tif (bit > parseInt(prec)) {\r\n\t\t\t\ts = s.substring(0, parseInt(dot)+parseInt(prec)+1);\r\n\t\t\t}\r\n\t\t\tif(parseInt(prec) == 0) {\r\n\t\t\t\ts = parseInt(s);\r\n\t\t\t}\r\n\t\t}\r\n\t} else {\r\n\t\ts = \"\";\r\n\t}\r\n\t\r\n\tvar regIsDotStart = /^\\./;\r\n\tif (regIsDotStart.test(s)) s = \"0\" + s;\r\n\tvar regIsDotEnd = /\\.+$/;\r\n\tif (regIsDotEnd.test(s)) s = s.replace(regIsDotEnd,'');\r\n\t\r\n\tif (min && min != \"\" && parseFloat(s) <parseFloat(min)) s = min;\r\n\tif (max && max != \"\" && parseFloat(s) > parseFloat(max)) s = max;\r\n\t\r\n\tif (s != $o.val()) {\r\n\t\tif(s != \"\") s = parseFloat(s);\r\n\t\t$o.val(s);\r\n\t} else {\r\n\t\tif(s != \"\") $o.val(parseFloat(s));\r\n\t}\r\n\t\r\n}\r\n\r\nfunction substrByte(str, len) {\r\n\tvar defaultLength = 2;\r\n\ttry {\r\n\t\tdefaultLength = parseInt((defaultCharLength && defaultCharLength != '' && defaultCharLength > 1) ? defaultCharLength : 2);\r\n\t} catch(e) {\r\n\t\tdefaultLength = 2;\r\n\t}\r\n\tif(!str || !len) { return ''; }     \r\n\tvar a = 0;     \r\n\tvar i = 0;\r\n\tvar temp = '';      \r\n\tfor (i=0;i<str.length;i++){         \r\n\t\tif (str.charCodeAt(i)>255){  \r\n\t\t\ta+=defaultLength;\r\n\t\t}else{\r\n\t\t\ta++;\r\n\t\t}  \r\n\t\tif(a > len){ \r\n\t\t\treturn temp;\r\n\t\t}         \r\n\t\ttemp += str.charAt(i);     \r\n\t}     \r\n\treturn str; \r\n} \r\n\r\nfunction initStyle(urls, callBack) {\r\n\tif(!urls || urls.length == 0) return;\r\n\t\r\n\tfor (var i = urls.length - 1; i >= 0; i--) {\r\n\t\tif(hasStyle(urls[i])) continue;\r\n\t\t\r\n\t\tsObj = document.createElement(\"link\"); sObj.setAttribute(\"rel\", \"stylesheet\");\r\n\t\tsObj.setAttribute(\"type\", \"text/css\"); sObj.setAttribute(\"href\", urls[i] + \"?@RDM_VERSION@\");\r\n\t\tdocument.getElementsByTagName(\"head\")[0].appendChild(sObj);\r\n\t}\r\n\t\r\n\tif (typeof callBack == 'function') callBack();\r\n}\r\n\r\nfunction hasStyle(url) {\r\n\tif(!url) return true;\r\n\t\r\n\tvar flag = false;\r\n\t$(\"link\").each(function(){\r\n\t\tif($(this).attr(\"href\") && $(this).attr(\"href\").indexOf(url) >= 0) {\r\n\t\t\tflag = true; return false;\r\n\t\t}\r\n\t});\r\n\treturn flag;\r\n}\r\n\r\nfunction initScript(urls, callBack) {\r\n\tif(!urls || urls.length == 0) return;\r\n\t\r\n\tfor (var i = urls.length - 1; i >= 0; i--) {\r\n\t\tif(hasScript(urls[i])) continue;\r\n\t\t\r\n\t\tsObj = document.createElement(\"script\"); sObj.setAttribute(\"type\", \"text/javascript\"); sObj.setAttribute(\"src\", urls[i] + \"?@RDM_VERSION@\");\r\n\t\tdocument.getElementsByTagName(\"head\")[0].appendChild(sObj);\r\n\t}\r\n\t\r\n\tif (typeof callBack == 'function') callBack();\r\n}\r\n\r\nfunction hasScript(url) {\r\n\tif(!url) return true;\r\n\t\r\n\tvar flag = false;\r\n\t$(\"script\").each(function(){\r\n\t\tif($(this).attr(\"src\") && $(this).attr(\"src\").indexOf(url) >= 0) {\r\n\t\t\tflag = true; return false;\r\n\t\t}\r\n\t});\r\n\treturn flag;\r\n}\r\n\r\nfunction checkFlashPlayer(){\r\n\tvar flash = false;\r\n    if(navigator.mimeTypes.length>0){\r\n        //application/x-