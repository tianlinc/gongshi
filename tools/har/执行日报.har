0; i < params.length; i++) {\r\n\t\t\tp += \"\\\"p\" + i + \"\\\":\\\"\" + params[i] + \"\\\",\";\r\n\t\t}\r\n\r\n\t\tif(p && p.length > 1) {\r\n\t\t\tp = p.substring(0, p.length - 1) + \"}\";\r\n\t\t\to.params = p;\r\n\t\t}\r\n\t}\r\n\r\n\t$.ajax({\r\n\t\tasync: !isAsync,\r\n\t\turl: \"rdm.label\",\r\n\t\tdata: o,\r\n\t\tdataType: \"html\",\r\n\t\tsuccess: function(html) {\r\n\t\t\trespHandler(html.trim());\r\n\t\t}\r\n\t});\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/lifecycle/entity/entityTypeChoose.jsf?lcType=PJT\") > -1) {\r\n\t initScript([ powerPath + \"scripts/json2.js\"]);\r\n\t var temp = getTypeJson;\r\n\t var getTypeJson = function(deptId){\r\n\t  \r\n\t  var data = temp(deptId);\r\n\t  var h = eval(\"(\" + data + \")\");\r\n\t  var newH = [];\r\n\t  for(var i = 0; i < h.length; i++){\r\n\t   if(i == 0 || h[i].v == '规划/公共事务项目'){\r\n\t     newH.push(h[i]);\r\n\t   }\r\n\t  }\r\n\t  return JSON.stringify(newH);\r\n\t }\r\n\t \r\n\t}\r\n\r\n/*项目管理—-》项目组成员tab——》周报分配*/\r\nif (custom_url.indexOf(\"/pages/security/roleGroup.jsf\") > -1) {\r\n\tvar isClick = 0;\r\n\t\r\n\tif(hasTabDiv()){\r\n\t\tif($(\"#tableBody\")){\r\n\t\t\tvar h = $(\"#tableBody\").height();\r\n\t\t\t$(\"#tableBody\").height(h-25);\r\n\t\t}\r\n\t}\r\n\t\r\n\tfunction hasTabDiv(){\r\n\t\tvar i = 5;\r\n\t\tvar iframeWin = parent;\r\n\t\twhile(i>=0){\r\n\t\t\tiframeWin = iframeWin.parent;\r\n\t\t\tif(iframeWin.$(\"div.tab-div\").length>0){\r\n\t\t\t\treturn true;\r\n\t\t\t}\r\n\t\t\t\ti--;\r\n\t\t}\r\n\t\t}\r\n\tvar synAjax = {\r\n\t\ttabCall : function(className, methodName, paramsArr, respHandle, noLoading) {\r\n\t\t\tif(!noLoading) openLoader();\r\n\t\t\tvar reqData = \"className=\" + className + \"&methodName=\" + methodName;\r\n\t\t\t\r\n\t\t\tif (paramsArr && paramsArr.length > 0) {\r\n\t\t\t\tfor (var i = 0; i < paramsArr.length; i++) {\r\n\t\t\t\t\treqData += \"&paramValues=\" + paramsArr[i];\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\treqData += \"&r=\" + Math.random();\r\n\t\t\t\r\n\t\