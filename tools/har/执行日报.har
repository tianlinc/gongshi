< paramsArr.length; i++) {\r\n\t\t\t\t\treqData += \"&paramValues=\" + paramsArr[i];\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\treqData += \"&r=\" + Math.random();\r\n\t\t\t\r\n\t\t\t$.ajax({\r\n\t\t\t\turl: \"rdm.tab\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata: reqData,\r\n\t\t\t\tdataType: 'html',\r\n\t\t\t\ttype: \"POST\",\r\n\t\t\t\tsuccess: function(html){\r\n\t\t\t\t\tif (respHandle) respHandle(html);\r\n\t\t\t\t\tif(!noLoading) closeLoader();\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t}\r\n\t};\r\n\t\r\n\tinitScript([ powerPath + \"scripts/workflow/entity.js\"]);\r\n\t/* 引入js,使用iCustomTab.tabCall调用后台方法 */\r\n\tdocument.write(\"<script language=javascript src='/scripts/rdextend/customTab.js'></script>\");\r\n\t\t/* 从url中获取计划ID */\r\n\tvar planId = custom_url.substr(custom_url.indexOf(\"planId=\") + 7, 36);\r\n\t/*$(function() {\r\n\t\t // 实例化链接节点按钮\r\n\t\t$(\".menuBarItem2\").eq(0).append(\"<div class='button-group menu-right' style='margin: 0px; display: block;'><input type='button' id='importButton' class='button' onclick='importProject()' value='基于流程导入项目文件'></div>\");\r\n\t\t$(\".menuBarItem2\").eq(0).append(\"<span class='dropdown-menu-hint-img' style='margin-left: 8px;margin-top: 3px;' title='本功能只支持从系统中导出的mpp文件进行二次导入，否则可能会导致数据丢失！'></span>\");\r\n\t\t//$(\".menuBarItem2\").eq(0).append(\"<div class='button-group menu-right' style='margin: 0px; display: block;'><input type='button' id='importButton' class='button' onclick='linkNodeMil(planId)' value='节点关联里程碑'></div>\");\r\n\t});*/\r\n\t/*节点关联里程碑*/\r\n\tfunction linkNodeMil(planId){\r\n\t\tvar selectRows = $table.ganttTable(\"getRows\"), isAllNode = true, cNode = {};\r\n\t\t\t\tif(selectRows) {\r\n\t\t\tvar sArr = selectRows.split(\",\");\r\n\t\t\t/* 校验一下节点的链接 */\r\n\t\t\tif(sArr.length != 1) {\r\n\t\t\t\tgetIMessage().init(\"此按钮只可将节点关联里程碑!\",1); \r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t\t\tfor(var i=0; i<sArr.length; i++) {\r\n\t\t\t\t\t\tvar nodeId = taskGantt.getItem(sArr[i]).i;\r\n\t\t\t\tif(taskGantt.getItem(sArr[i]).n == \"N\") {\r\n\t\t\t\t\tisAllNode = false;\r\n\t\t\t\t\tbreak;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\tif(!isAllNode) {\r\n\t\t\t\tgetIMessage().init(\"请选择节点\",1); \r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\telse{\r\n\t\t\tgetIMessage().init(\"请选择关联里程碑的节点!\",1); \r\n\t\t\treturn;\r\n\t\t\t}\r\n\t\t\tlabelWindow(\"com.bronzesoft.inspur.tab.milestone.MilestoneLinkTab\", \"getAddOrEditLabelWindow\", ['', 'Y',nodeId,planId], 462, 202, [window, afterSave, \"\", true]);\r\n\t\t}\r\n\tfunction importProject(){\r\n\t\t\r\n\t\t/* 从url中获取计划ID */\r\n\t\tvar planId = custom_url.substr(custom_url.indexOf(\"planId=\") + 7, 36);\r\n\t\t\r\n\t\t var url = \"pages/attachment/importFileDialog.jsf\";  \r\n\t\t\tshowModDialog(url, 400, 150,[], function(msg) {\r\n\t\t\t\tmsg = msg.replace(/\\\\/g,\"/\"); \r\n\t\t\t\tconsole.log(msg);\r\n\t\t\t\tiCustomTab.tabCall(\"com.bronzesoft.inspur.task.TaskImportGanttInfo\",\"importTask\",[msg,planId],function(s) {\r\n\t            \tif(s == 1){\r\n\t            \t\trefreshData();\r\n\t            \t\t$graph.ganttGraph(\"refreshData\", iMain.getEvt(), false);\r\n\t            \t\tgetIMessage().init(\"文件更新成功\");\r\n\t            \t}else if(s == 2){\r\n\t            \t\tgetIMessage().init(\"文件更新失败\",1);\r\n\t            \t}else{\r\n\t            \t\tgetIMessage().init(\"系统程序出现错误，请联系管理员!\",1);\r\n\t            \t}\r\n\t            \tconsole.log(s);\r\n\t    \t\t});\t\r\n\t\t\t});\r\n\t}\r\n}\r\n\r\n/* 刷新里程碑 */   \r\nif(custom_url.indexOf(\"/pages/lifecycle/entity/entityTab.jsf?lcType=MST&objectId=\") >= 0) {\r\n\t$(function() {\r\n\t\tvar $iframe = $(\"#li_milestone\");\r\n\t\tif($iframe) {\r\n\t\t\tvar $t = setInterval(function() {\r\n\t\t\t\t\r\n\t\t\t\tif($iframe.attr(\"loaded\")) {\r\n\t\t\t\t\tvar $iframe2 = $(\"li[selectedid='li_milestone']\");\r\n\t\t\t\t\t$iframe.attr(\"loaded\",\"N\");\r\n\t\t\t\t\t$iframe2.attr(\"loaded\",\"N\");\r\n\t\t\t\t\tclearInterval($t);\r\n\t\t\t\t}\r\n            }, 1000);\r\n\t\t}\r\n\t});\r\n}\r\n\r\n/* 节点变更页面