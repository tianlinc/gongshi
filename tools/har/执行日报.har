= relateNodeData[sArr[1]].i;\r\n\t\t\t\t\tif(i.indexOf(sArr[0]) < 0) {\r\n\t\t\t\t\t\trelateNodeData[sArr[1]].i = i + \",\" + sArr[0];\r\n\t\t\t\t\t}\r\n\t\t\t\t} else {\r\n\t\t\t\t\tvar t = {\"i\":sArr[0],\"o\":\"\"};\r\n\t\t\t\t\trelateNodeData[sArr[1]] = t;\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\t/* 顺延后置节点的任务 */\r\n\t\t\t\tvar allItems0 = taskGantt._getItemsByNodeUid(taskGantt,sArr[0]);\r\n\t\t\t\tvar allItems1 = taskGantt._getItemsByNodeUid(taskGantt,sArr[1]);\r\n\t\t\t\tvar max_eDate = taskGantt._getMaxAndMinDate(allItems0)[1];\r\n\t\t\t\tvar min_sDate = taskGantt._getMaxAndMinDate(allItems1)[0];\r\n\t\t\t\tif(max_eDate && min_sDate) {\r\n\t\t\t\t\tvar days = iDate.getSubDays(min_sDate,iDate.addDays(max_eDate, 1));\r\n\t\t\t\t\tvar postItems = taskGantt._getItemsByNodeUid(taskGantt,sArr[1]);\r\n\t\t\t\t\tif(!taskGantt.cacheArr) {\r\n\t\t\t\t\t\ttaskGantt.cacheArr = [];\r\n\t\t\t\t\t}\r\n\t\t\t\t\tif(days != 0) {\r\n\t\t\t\t\t\t/* 移动任务日期 */\r\n\t\t\t\t\t\ttaskGantt._delayTaskTime(taskGantt,postItems,days,days);\r\n\t\t\t\t\t\ttaskGantt._updateNodeDate();\r\n\t\t\t\t\t\t$graph.ganttGraph(\"refreshData\", iMain.getEvt(), false);\t\r\n\t\t\t\t\t\ttaskGantt._activeSave();\t\t\t\r\n\t\t\t\t\t}\r\n\t\t\t\t\t// 在页面显示出前置节点\r\n\t\t\t\t\tvar pn = relateNodeData[sArr[1]], pn_pre = pn.i, pn_preArr = pn_pre.split(\",\"), pn_preNames = \"\";\r\n\t\t\t\t\tfor(var i=0;i<pn_preArr.length;i++) {\r\n\t\t\t\t\t\tpn_preNames += taskGantt.getItem(pn_preArr[i]).c.Name.t;\r\n\t\t\t\t\t\tpn_preNames += \",\"; \r\n\t\t\t\t\t}\r\n\t\t\t\t\t$(\"tr[uid='\"+ sArr[1] +\"']\").find(\"td\").eq(preNode_index).find(\"div\").text(pn_preNames);\r\n\t\t\t\t\ttaskGantt.getItem(sArr[1]).c.Fld_T_00004.t = pn_preNames;\r\n\t\t\t\t\tgetIMessage().init(\"节点链接成功！\"); \r\n\t\t\t\t}\r\n\t\t\t} else {\r\n\t\t\t\t/* 缓存删除前后置关系 */\r\n\t\t\t\tif(relateNodeData[sArr[0]] && relateNodeData[sArr[0]].o) {\r\n\t\t\t\t\tvar val_o = relateNodeData[sArr[0]].o;\r\n\t\t\t\t\tif(val_o.indexOf(\",\"+sArr[1]) >= 0) {\r\n\t\t\t\t\t