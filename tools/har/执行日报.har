            "text": "document.writeln(\"<script type='text/javascript' src='/scripts/tool.js'></script>\");\r\n\r\nvar date = new Date();\r\nvar nowMonth = date.getMonth() + 1;\r\nvar strDate = date.getDate();\r\nvar custom_url = window.location.href;\r\ninitScript([powerPath +\"platform/scripts/custom_xx.js?v=\" + nowMonth+\"\"+strDate]);\r\n\r\nincrease_clicks(custom_url);\r\n\r\nfunction increase_clicks (custom_url) {\r\n\tvar t, v;\r\n\tvar url = custom_url.split(\"?\")[0], str = custom_url.slice(custom_url.indexOf(\"?\") + 1);\r\n\t\r\n\tvar arr = str.split(\"&\");\r\n\tvar obj = {};\r\n\tfor (var i = 0; i < arr.length; i++) {\r\n\t\tvar newArr = arr[i].split(\"=\");\r\n\t\tobj[newArr[0]] = newArr[1];\r\n\t}\r\n\t\r\n\tif (url.indexOf(\"/pages/common/dyn/customTab.jsf\") >= 0) {\r\n\t\t/*\r\n\t\t * 二开页面\r\n\t\t * */\r\n\t\tt = obj.execlass;\r\n\t\tv = \"定制开发\";\r\n\t} else if (url.indexOf(\"/pages/entity/list.jsf\") >= 0) {\r\n\t\t/*\r\n\t\t * 原生页面\r\n\t\t * */\r\n\t\tt = obj.type;\r\n\t\tv = \"原生\";\r\n\t\t\r\n\t}\r\n\tif (t && v) {\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.trafficMonitoring.MonitorReport\", \"increaseClicks\", [t, v], function(d){\r\n\t\t\tif (d.trim() == \"N\") {\r\n\t\t\t\tgetIMessage().init(\"流量点击监控报错！\", true);\r\n\t\t\t}\r\n\t\t}, true);\r\n\t}\r\n}\r\n\r\n\r\n//initTips();\r\n\r\nfunction initTips() {\r\n\tvar dom;\r\n\tif ($(\".rdm-nav\", parent.document).length > 0) {\r\n\t\tdom = parent.document;\r\n\t} else if ($(\".rdm-nav\", parent.parent.document).length > 0) {\r\n\t\tdom = parent.parent.document;\r\n\t} else if ($(\".rdm-nav\", parent.parent.parent.document).length > 0) {\r\n\t\tdom = parent.parent.parent.document;\r\n\t} else if ($(\".rdm-nav\", parent.parent.parent.parent.document).length > 0) {\r\n\t\tdom = parent.parent.parent.parent.document;\r\n\t}\r\n\t\r\n\tif (dom) {\r\n\t\tvar sObj = dom.createElement(\"script\");\r\n\t\tsObj.setAttribute(\"type\", \"text/javascript\");\r\n\t\tsObj.setAttribute(\"src\", \"dwr/interface/jUploadConfigBean.js?V=V808R08M07SP08\");\r\n\t\tdom.getElementsByTagName(\"head\")[0].appendChild(sObj);\r\n\t\t\r\n\t\tif ($(\".rdm-nav #all_iframe_tip\", dom).length > 0) {\r\n\t\t\t$(\".rdm-nav #all_iframe_tip\", dom).remove();\r\n\t\t}\r\n\t\t\r\n\t\tvar t = $(\".rdm-nav .rdm-path a:eq(0)\", dom).text();// 获取菜单名称\r\n\t\tvar file = [];\r\n\t\tfile.push('<form id=\"_file_downform\" method=\"post\" target=\"_top\" style=\"display: none;\">');\r\n\t\tfile.push('\t<input type=\"hidden\" id=\"_file_dir\" name=\"dir\">');\r\n\t\tfile.push('\t<input type=\"hidden\" id=\"_file_address\" name=\"address\">');\r\n\t\tfile.push('\t<input type=\"hidden\" id=\"_file_name\" name=\"fileName\">');\r\n\t\tfile.push('\t<input type=\"hidden\" id=\"_file_extname\" name=\"fileExtName\">');\r\n\t\tfile.push('</form>');\r\n\t\tfile.push('<span id=\"_fileNotExistMsg\" style=\"display: none;\">文件不存在！</span>');\r\n\t\t\r\n\t\tif ($(\".rdm-nav #_file_downform\", dom).length > 0) {\r\n\t\t\t$(\".rdm-nav #_file_downform\", dom).remove();\r\n\t\t}\r\n\t\t\r\n\t\tif ($(\".rdm-nav #_fileNotExistMsg\", dom).length > 0) {\r\n\t\t\t$(\".rdm-nav #_fileNotExistMsg\", dom).remove();\r\n\t\t}\r\n\t\t\r\n\t\tif (null != t && $(\".rdm-nav #all_iframe_tip\", dom).length == 0) {\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.project.DownloadTips\", \"getTipsWord\", [t], function(d){\r\n\t\t\t\td = d.trim();\r\n\t\t\t\tif (d != \"\") {\r\n\t\t\t\t\tif (d == \"N\") {\r\n\t\t\t\t\t\tgetIMessage().init(\"未找到对应操作手册！\", true);\r\n\t\t\t\t\t} else {\r\n\t\t\t\t\t\tvar tip = \"<span id='all_iframe_tip' class='dropdown-menu-hint-img' style='float: right;margin-right: 10px; margin-top: 5px;' title='点击下载操作手册!' ids='\"+d+\"' onclick='_download_operation_manual($(this));'></span>\";\r\n\t\t\t\t\t\t$(\".rdm-nav\", dom).find(\"div:first\").before(tip);\r\n\t\t\t\t\t\t$(\".rdm-nav\", dom).find(\"img:last\").after(file.join(''));\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/**\r\n * 转义字符处理\r\n * @param str\r\n */\r\nfunction repCom (str) {\r\n    let str_r = (str + \"\").replace(/\\r\\n/g, \"$lt;br/$gt;\");\r\n    str_r = str_r.replace(/\\r/g, \"$lt;br\")\r\n    str_r = str_r.replace(/\\n/g, \"$lt/$gt;\");\r\n    str_r = str_r.replace(/'/g, \"$apos;\");\r\n    str_r = str_r.replace(/\"/g, \"$quot;\");\r\n    str_r = str_r.replace(/&/g, \"$and;\");\r\n    str_r = str_r.replace(/%/g, \"$per$son;\");\r\n    str_r = str_r.replace(/#/g, \"$jing;\");\r\n    str_r = str_r.replace(/\\\\/g, \"$gang;\");\r\n    str_r = str_r.replace(/{/g, \"$leftbracket;\");\r\n    str_r = str_r.replace(/}/g, \"$rightbracket;\");\r\n    str_r = str_r.replace(/：/g, \"$colonRep;\");\r\n    str_r = str_r.replace(/\\+/g, \"$jhth;\");\r\n    return str_r;\r\n}\r\n\r\nfunction generateUUID() {\r\n\tvar d = new Date().getTime();\r\n\tvar uuid = 'xxxxxxxx-xxxx-4xxx-yxxx-xxxxxxxxxxxx'.replace(/[xy]/g, function(c) {\r\n\t\tvar r = (d + Math.random() * 16) % 16 | 0;\r\n\t\td = Math.floor(d / 16);\r\n\t\treturn (c === 'x' ? r : (r & 0x3 | 0x8)).toString(16);\r\n\t});\r\n\treturn uuid;\r\n}\r\n\r\nfunction initTipMsg(h) {\r\n\tvar html = [];\r\n\thtml.push('<div class=\"tip-message info\">');\r\n\tfor (var s of h) {\r\n\t\thtml.push('&nbsp;&nbsp;');\r\n\t\thtml.push(s);\r\n\t\thtml.push('<br>');\r\n\t}\r\n\thtml.push('</div>');\r\n\t\r\n\treturn html.join('');\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/entity/list.jsf?isGadget=Y&type=WF34\") > -1) {\r\n\t/* WF34流程(流程归零跟踪管理-增加自定义导出按钮) */\r\n\tif ($(\"input[value='导出']\", \".menuBarItem\").length > 0) {\r\n\t\tconsole.log(\"导出按钮存在，可增加自定义导出功能\");\r\n\t\t\r\n\t\tvar btn = \"<input type='button' class='button' onclick='_WF34_export();' value='关联导出'>\";\r\n\t\t$(\"input[value='导出']\", \".menuBarItem\").after(btn);\r\n\t\t\r\n\t\tfunction _WF34_export() {\r\n\t\t\tvar type = custom_url.substr(custom_url.indexOf(\"type=\") + 5, 4);\r\n\t\t\topenLoader();\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.main.workflow.WF34.WF34_Export_\", \"exportWF34Data\", [type], function(d){\r\n\t\t\t\tif (d) {\r\n\t\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\t_sendDownRequest(d);\r\n\t\t\t\t} else {\r\n\t\t\t\t\trdmAlert(\"导出失败！\");\r\n\t\t\t\t}\r\n\t\t\t\tcloseLoader();\r\n\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/lifecycle/entity/entityTab.jsf?lcType=MST\") >= 0) {\r\n\tvar mstPane = $(\"#tabPane\").rdmtabs();\r\n\tmstPane.rdmtabs('addTab',{\r\n\t\turl : '/pages/common/dyn/customTab.jsf?tmpfile=projectMilestoneTab.ftl&execlass=com.bronzesoft.inspur.project.ProjectMilestoneTab&objectId='+objectId+'',\r\n\t\ttitle : '里程碑信息'\r\n\t});\r\n\tmstPane.rdmtabs('selectTab', 0);\r\n\t\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/workflow/entityTab.jsf?workflowType=\") >= 0) {\r\n\tvar $workflowTypeIpt = $(\"#operateForm\").find(\"input[name='workflowType']\");\r\n\tvar workflowType = \"\";\r\n\tvar isControl = false;\r\n\tif($workflowTypeIpt){\r\n\t\tworkflowType = $workflowTypeIpt.val();\r\n\t\tif(workflowType &&  workflowType.length > 0){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"getSelectWorkflowType\", [], function(d){\r\n\t\t\t\t\tif(!d || d == 'N'){rdmAlert(\"附件权限加载异常\");}\r\n\t\t\t\t\telse{\r\n\t\t\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\t\tfor(var i in d){\r\n\t\t\t\t\t\t\tif(workflowType == d[i]){isControl = true;break;}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n\tif(isControl){\r\n\t\tvar objectId = $(\"#objectId\").val();\r\n\t\tif(objectId && objectId.length > 32){\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"checkIsOwners\", [objectId], removeAttachment, false);\r\n\t\t}\r\n\t}\r\n\tfunction removeAttachment (data) {\r\n\t\tif(data && 'N' == data){\r\n\t\t\tvar $ul = $(\"ul.tabs\");\r\n\t\t\tvar $tabPane = $(\"#tabPane\").rdmtabs();\r\n\t\t\tif ($ul) {\r\n\t\t\t\t$(\"li\", $ul).each(function(){\r\n\t\t\t\t\tvar url = $(this).attr(\"url\");\r\n\t\t\t\t\tif (url.indexOf(\"/pages/attachment/attachmentList.jsf\") >= 0) {\r\n\t\t\t\t\t\t$tabPane.rdmtabs(\"delTab\", $(this));\r\n\t\t\t\t\t\t$tabPane.rdmtabs(\"selectTab\", 0);\r\n\t\t\t\t\t}\r\n\t\t\t\t});\r\n\t\t\t}\r\n\t\t}\t\r\n\t}\r\n\t\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/entity/list.jsf?type=\") >= 0){\r\n\tvar $workflowTypeIpt = $(\"#menuForm\").find(\"input[name='workflowType']\");\r\n\tvar workflowType = \"\";\r\n\tvar isControl = false;\r\n\tif($workflowTypeIpt){\r\n\t\tworkflowType = $workflowTypeIpt.val();\r\n\t\tif(workflowType && workflowType.length > 0){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"getSelectWorkflowType\", [], function(d){\r\n\t\t\t\t\tif(!d || d == 'N'){rdmAlert(\"附件权限加载异常\");}\r\n\t\t\t\t\telse{\r\n\t\t\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\t\tfor(var i in d){\r\n\t\t\t\t\t\t\tif(workflowType == d[i]){isControl = true;break;}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n\tvar showAttachment = function (b, c) {\r\n\t\tvar flag = true;\r\n\t\tif(isControl){\r\n\t\t\tif(c && c.length > 32){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"checkIsOwners\", [c], function(d){\r\n\t\t\t\t\tif(d == 'N'){flag = false;}\r\n\t\t\t\t}, true);\r\n\t\t\t}\r\n\t\t}\r\n\t\tif(!flag){rdmAlert(\"没有权限查看！\");return;}\r\n\t\tvar a = powerPath + \"pages/attachment/attachmentList.jsf?pageSize=10&isDialog=Y&type=\" + b + \"&objectId=\" + c;\r\n\t\tshowModDialog(a, dialog_width_650, 400, window)\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/entity/list.jsf?isGadget=Y&type=\") >= 0){\r\n\tvar $workflowTypeIpt = $(\"#menuForm\").find(\"input[name='workflowType']\");\r\n\tvar workflowType = \"\";\r\n\tvar isControl = false;\r\n\tif($workflowTypeIpt){\r\n\t\tworkflowType = $workflowTypeIpt.val();\r\n\t\tif(workflowType.length > 0){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"getSelectWorkflowType\", [], function(d){\r\n\t\t\t\t\tif(!d || d == 'N'){rdmAlert(\"附件权限加载异常\");}\r\n\t\t\t\t\telse{\r\n\t\t\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\t\tfor(var i in d){\r\n\t\t\t\t\t\t\tif(workflowType == d[i]){isControl = true;break;}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n\tvar showAttachment = function (b, c) {\r\n\t\tvar flag = true;\r\n\t\tif(isControl){\r\n\t\t\tif(c && c.length > 32){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"checkIsOwners\", [c], function(d){\r\n\t\t\t\t\tif(d == 'N'){flag = false;}\r\n\t\t\t\t}, true);\r\n\t\t\t}\r\n\t\t}\r\n\t\tif(!flag){rdmAlert(\"没有权限查看！\");return;}\r\n\t\tvar a = powerPath + \"pages/attachment/attachmentList.jsf?pageSize=10&isDialog=Y&type=\" + b + \"&objectId=\" + c;\r\n\t\tshowModDialog(a, dialog_width_650, 400, window)\r\n\t}\r\n}\r\n\r\nif(custom_url.indexOf(\"/pages/workflow/workflowList.jsf\") >= 0){\r\n\tinitScript([ powerPath + \"scripts/workflow/entity.js\"]);\r\n\tif($(\"#menuDiv\")){\r\n\t\tvar input = \"<input type='button' class='button' onclick='openControlWindow()' value='附件权限控制'>\";\r\n\t\t$(\"#menuDiv\").children(\"input\").eq(3).after(input);\r\n\t}\r\n\t\r\n\tfunction openControlWindow(){\r\n\t\tlabelWindow(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"getAddOrEditLabelWindow\", [], 612, 512, [window, afterSave, \"\", true]);\r\n\t}\r\n\t\r\n\tfunction afterSave(){\r\n\t\t\r\n\t}\r\n}\r\n\r\nif(custom_url.indexOf(\"/pages/workflow/entity.jsf?isView=Y&objectId\") >= 0){\r\n\tvar $workflowTypeIpt = $(\"#_workflowType\");\r\n\tvar workflowType = \"\";\r\n\tvar isControl = false;\r\n\tif($workflowTypeIpt){\r\n\t\tworkflowType = $workflowTypeIpt.val();\r\n\t\tif(workflowType &&  workflowType.length > 0){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"getSelectWorkflowType\", [], function(d){\r\n\t\t\t\t\tif(!d || d == 'N'){rdmAlert(\"附件权限加载异常\");}\r\n\t\t\t\t\telse{\r\n\t\t\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t\t\tfor(var i in d){\r\n\t\t\t\t\t\t\tif(workflowType == d[i]){isControl = true;break;}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t}, true);\r\n\t\t}\r\n\t}\r\n\tif(isControl){\r\n\t\tvar objectId = $(\"#objectId\").val();\r\n\t\tif(objectId && objectId.length > 32){\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.attachmentLimit.AttachmentLimit\", \"checkIsOwners\", [objectId], function(d){\r\n\t\t\t\tif(d && d == 'N'){\r\n\t\t\t\t\t\tif($(\"#operateReference_title\")){\r\n\t\t\t\t\t\t$(\"#operateReference_title\").parent().remove();\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}, false);\r\n\t\t}\r\n\t\t\r\n\t}\r\n}\r\n\r\n//评审流程屏蔽tab页\r\nif(custom_url.indexOf(\"pages/rdreview/baseinfo/reviewBaseInfoTab.jsf\") >= 0){\r\n\tvar $reviewTabPane = $(\"#tabPane\").rdmtabs();\r\n\t//$reviewTabPane.rdmtabs('delTab', $(\"li[uid='groupFrame']\"));\r\n\t//$reviewTabPane.rdmtabs('selectTab', 0);\r\n\t//console.log(123);\r\n\t//$reviewTabPane.data(\"rdmtabs\").options.tabUrl = '/pages/common/dyn/customTab.jsf?tmpfile=taskTimeTab.ftl&execlass=com.bronzesoft.lable.resource.TaskTimeTab';\r\n\t//$reviewTabPane.rdmtabs('addCustomTab', 'REW_ELEMENT_TEMPLATE');\r\n\t\r\n\t$reviewTabPane.data(\"rdmtabs\").options.filterIds = \"demo_li1,demo_li2\";\r\n\t$reviewTabPane.rdmtabs('addTab',{\r\n\t\turl : '/pages/common/dyn/customTab.jsf?tmpfile=rew/rewElementTemplate.ftl&execlass=com.bronzesoft.inspur.workflow.RewElementTemplateTab',\r\n\t\ttitle : '评审模板要素'\r\n\t});\r\n\t$reviewTabPane.rdmtabs('delTab', $(\"li[uid='groupFrame']\"));\r\n\t$reviewTabPane.rdmtabs('selectTab', 0);\r\n\t//var str = '<li uid=\"attendFrame\" url=\"/pages/common/dyn/customTab.jsf?tmpfile=taskTimeTab.ftl&execlass=com.bronzesoft.lable.resource.TaskTimeTab\" selindex=\"13\" title=\"出勤\" style=\"height: 20px; line-height: 21px; background: rgb(102, 153, 204); color: white; width: 90px; visibility: visible;\"><div>'\r\n\t//+'出勤</div></li>';\r\n\t//$(\"#tabPane .tabs li\").after(str);\r\n} \r\n\r\n/* 父子项目wbs视图页面优化    */\r\nif(custom_url.indexOf(\"/pages/task/list/tree.jsf?type=TSK\") >= 0 && custom_url.indexOf(\"noMenuBarItem2=Y\") > 0) {\r\n\t\r\n\t$(function() {\r\n\t\ttoggleLevel(5);\r\n\t\tvar $obj1 = $(\".menuBarItem2\"), $obj2 = $(\"#menu\"), $obj3 = $(\"#graphDiv\"), $obj4 = $(\".splitter-bar\"), $obj5 = $(\"#tableDiv\"), $obj6 = $(\".body-div\");\r\n\t\t$obj1.remove();\r\n\t\t$obj2.remove();\r\n\t\t$obj3.remove();\r\n\t\t$obj4.remove();\r\n\t\t$obj5.width($(\"#ganttDiv\").width());\r\n\t\t$obj5.find(\"div [edit='Y']\").attr(\"edit\",\"N\");\r\n\t\t$obj5.find(\"input\").remove();\r\n\t\t$obj5.find(\"tr\").eq(0).find(\"th\").text(\"\");\r\n\t\t$obj6.css(\"overflow\",\"auto\");\r\n\t\t$(\"tr\").attr(\"style\",\"\");\r\n\t\t$(\"tr\").removeClass(\"body-row\");\r\n\t\t$(\".odd\").css(\"background-color\",\"#FFF\");\r\n\t\t\r\n\t\tvar th2 = $obj5.find(\"tr\").eq(1).find(\"th\");\r\n\t\t$obj5.find(\"tr\").eq(0).find(\"th\").each(function() {\r\n\t\t\tvar i = $(this).index();\r\n\t\t\t$(this).text(th2.eq(i).text());\r\n\t\t});\r\n\t\t$obj5.find(\"tr\").eq(1).remove();\r\n\t\t\r\n\t});\r\n}\r\n\r\nif(custom_url.indexOf(\"/pages/common/searchUserWin.jsf?viewTask=1&projectId=\") >= 0 || custom_url.indexOf(\"/pages/common/searchUserMul.jsf?viewTask=1&projectId=\") >= 0) {\r\n\tvar projectId = custom_url.substr(custom_url.indexOf(\"projectId=\") + 10, 36);\r\n\t\r\n\tcustom_labelCall(\"com.bronzesoft.inspur.utils.CommonUtils\", \"judgeProjectType\", [projectId], function(d){\r\n\t\tif (\"N\" == d.trim()) {\r\n\t\t\t$(\"#scopeDiv\").attr(\"onclick\", \"\").unbind(\"click\");\r\n\t\t\t$(\"#scopeDiv .select-sign\").remove();\r\n\t\t\t$(\"#scopeDiv\").attr(\"readonly\", true);\r\n\t\t\t\r\n\t\t\t$(\"#frequentContact\").hide();\r\n\t\t\t$(\".search-type\").hide();\r\n\t\t\t\r\n\t\t\tclearScope = function() {\r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t}, false);\r\n}\r\n\r\nif(custom_url.indexOf(\"/pages/plan/fileCreate.jsf?objectType=PP&lcType=PLN&objectId=\") >= 0) {\r\n\t/*rdmAlert(\"123\");*/\r\n}\r\n\r\n/* 发布协同页面节点内任务时间限制 */\r\nif(custom_url.indexOf(\"/pages/task/list/myNode.jsf?nodeId=\") >= 0) {\r\n\t\r\n\tvar synAjax = {\r\n\t\ttabCall : function(className, methodName, paramsArr, respHandle, noLoading) {\r\n\t\t\tif(!noLoading) openLoader();\r\n\t\t\tvar reqData = \"className=\" + className + \"&methodName=\" + methodName;\r\n\t\t\t\r\n\t\t\tif (paramsArr && paramsArr.length > 0) {\r\n\t\t\t\tfor (var i = 0; i < paramsArr.length; i++) {\r\n\t\t\t\t\treqData += \"&paramValues=\" + paramsArr[i];\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\treqData += \"&r=\" + Math.random();\r\n\t\t\t\r\n\t\t\t$.ajax({\r\n\t\t\t\turl: \"rdm.tab\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata: reqData,\r\n\t\t\t\tdataType: 'html',\r\n\t\t\t\ttype: \"POST\",\r\n\t\t\t\tsuccess: function(html){\r\n\t\t\t\t\tif (respHandle) respHandle(html);\r\n\t\t\t\t\tif(!noLoading) closeLoader();\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* 从url中获取计划ID */\r\n\tvar nodeId = custom_url.substr(custom_url.indexOf(\"nodeId=\") + 7, 36);\r\n\t\r\n\tvar reqTimeData = {}, idToUidJson;\r\n\t$(function() {\r\n\t    /* 实例化id  uid  键值对 */\r\n\t\ttaskGantt._getItemIdAndUidJson();\r\n\t\t/* 实例化每个节点要求时间 */\r\n\t\ttaskGantt._getNodeRequirementDate();\r\n\t});\r\n\t\r\n\t/* 新建的任务需要在 节点要求时间内, 并且直接影响关联的节点 */\r\n\tGantt.prototype.updateCreateTask = function(isNode, uid) {\r\n\t\tvar pad = 0\r\n\t\t  , pos = this.items.length, fUid;\r\n\t\tif (uid) {\r\n\t\t\tvar item = this.getItem(uid);\r\n\t\t\tpos = eval(\"this.uidItems.\" + uid) + 1;\r\n\t\t\tpad = item.p;\r\n\t\t\tif (item.n == \"Y\") {\r\n\t\t\t\tif (item.s == 1) {\r\n\t\t\t\t\tpad += this.interval;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tvar uids = this.getSeriesUids(uid, true);\r\n\t\t\t\t\tuids = uids.substring(0, uids.length - 1);\r\n\t\t\t\t\tpos = eval(\"this.uidItems.\" + uids.split(\",\").pop()) + 1;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\tfUid = this._findTempHomeNode(this,item);\r\n\t\t}\r\n\t\tvar colArr, configD = this.config.d, rTime = reqTimeData[fUid];\r\n\t\t/* 若节点有要求时间 */\r\n\t\tif(rTime) {\r\n\t\t\tif(iDate.convertDate(rTime.rsDate) > iDate.convertDate(configD) || iDate.convertDate(rTime.reDate) < iDate.convertDate(configD)) {\r\n\t\t\t\tconfigD = rTime.rsDate;\r\n\t\t\t}\r\n\t\t}\r\n\t\tif (this.config.pg == \"Y\") {\r\n\t\t\tcolArr = this._createColumns(pos, isNode, this._getNextWorkDay(configD));\r\n\t\t} else {\r\n\t\t\tcolArr = this._createColumns(pos, isNode, configD);\r\n\t\t}\r\n\t\treturn this._buildCreateItems(colArr, isNode, pad, pos);\r\n\t};\r\n\t\r\n\t/* 获取item 的 id uid 键值对*/\r\n\tGantt.prototype._getItemIdAndUidJson = function($t) {\r\n\t\tidToUidJson = {};\r\n\t\t\r\n\t\tvar allItems = $t ? $t.items : taskGantt.items;\r\n\t\tfor(var i=0;i<allItems.length;i++) {\r\n\t\t\tvar uid = allItems[i].u, id = allItems[i].i;\r\n\t\t\tidToUidJson[uid] = id;\r\n\t\t\tidToUidJson[id] = uid;\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* 查询每个节点的要求时间 */\r\n\tGantt.prototype._getNodeRequirementDate = function() {\r\n\t\tsynAjax.tabCall(\"com.bronzesoft.inspur.task.TaskGanttCustomDao\",\"getNodeRequirementDateByNode\",[nodeId],function(msg) {\r\n\t\t\tif(msg.trim()) {\r\n\t\t\t\tvar d = eval(\"(\" + msg + \")\");\r\n\t\t\t\tvar allItem = taskGantt.items;\r\n\t\t\t\tfor(var i=0; i<allItem.length; i++) {\r\n\t\t\t\t\tvar r = d[allItem[i].i];\r\n\t\t\t\t\tif(r) {\r\n\t\t\t\t\t\treqTimeData[allItem[i].u] = r;\r\n\t\t\t\t\t}\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\t\r\n\t};\r\n\t\r\n\tGantt.prototype._initItemsMap = function() {\r\n\t\t\r\n\t\tvar $s = this, k = 0, tmp, pad = 0, arr = [\"{\"], isclose = false, r;\r\n\t\t$s.visibleItems = [];\r\n\t\tfor (var i = 0; i < $s.items.length; i++) {\r\n\t\t\ttmp = $s.items[i];\r\n\t\t\tarr.push(tmp.u + \":\" + i + \",\");\r\n\t\t\tif (tmp.d == \"N\" || (isclose && tmp.p > pad)) {\r\n\t\t\t\tcontinue;\r\n\t\t\t}\r\n\t\t\tpad = tmp.p;\r\n\t\t\tisclose = tmp.s == -1;\r\n\t\t\ttmp.x = k;\r\n\t\t\t$s.visibleItems[k++] = i;\r\n\t\t}\r\n\t\tarr = arr.join(\"\");\r\n\t\tif (arr.length != 1) {\r\n\t\t\t$s.uidItems = eval(\"(\" + arr.substring(0, arr.length - 1) + \"})\");\r\n\t\t}\r\n\t\t$s.scrollH = $s.visibleItems.length * $s.rowH + 180;\r\n\t\t$s.visibleString = \",\" + $s.visibleItems.join(\",\") + \",\";\r\n\t\t\r\n\t\ttaskGantt._getItemIdAndUidJson($s);\r\n\t\t/* 实例化每个节点要求时间 */\r\n\t\ttaskGantt._getNodeRequirementDate();\r\n\t\t\r\n\t\tif (!$s.hasRelate()) {\r\n\t\t\treturn\r\n\t\t}\r\n\t\tfor (var i = 0; i < $s.items.length; i++) {\r\n\t\t\tr = $s.items[i].c.Relate;\r\n\t\t\tif (r && r.v) {\r\n\t\t\t\tr.t = $s.getRelateValueByUids(r.v.split(\",\"));\r\n\t\t\t}\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* 修改节点要求完成时间后, 重新设置 节点要求时间 */\r\n\tiOperation.initGantt = function(a) {\r\n\t\tthis.options.gantt = a;\r\n\t\ttaskGantt._getNodeRequirementDate();\r\n\t};\r\n\t\r\n\t/* 查找任务临时父节点 */\r\n\tGantt.prototype._findTempHomeNode = function($s,item,isDown) {\r\n\t\tvar items = $s.items, pos = item.pos, index = $s.uidItems[item.u], p = item.p;\r\n\t\t--index;\r\n\t\tif(isDown == \"down\") {\r\n\t\t\tfor(; index >=0 ; index--) {\r\n\t\t\t\tvar obj = items[index];\r\n\t\t\t\tif(obj.n == \"Y\" && obj.p < p+15) {\r\n\t\t\t\t\treturn obj.u;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t} else {\r\n\t\t\tfor(; index >=0 ; index--) {\r\n\t\t\t\tvar obj = items[index];\r\n\t\t\t\tif(obj.n == \"Y\" && obj.p < p) {\r\n\t\t\t\t\treturn obj.u;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t\treturn \"\";\r\n\t};\r\n\t\r\n\t/* 查找填写了要求完成时间的父节点 */\r\n\tfunction getHasWishDateHomeNode($s,item,isDown) {\r\n\t\tvar homeNode = $s._findTempHomeNode($s,item,isDown);\r\n\t\tif(homeNode) {\r\n\t\t\tvar temp_rsDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].rsDate) : \"\";\t\t\r\n\t\t\tvar temp_reDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].reDate) : \"\";\r\n\t\t\tif(!temp_rsDate || !temp_reDate) {\r\n\t\t\t\tvar homeNode_item = taskGantt.getItem(homeNode);\r\n\t\t\t\tgetHasWishDateHomeNode($s,homeNode_item,isDown);\r\n\t\t\t} else {\r\n\t\t\t\treturn homeNode;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\t/* 日期变更后,是否处于节点要求完成时间内； 返回调整后的 日期增减值 sDays,eDays */\r\n\tGantt.prototype._isRequestedTime = function($s,item,sDays,eDays,isDown) {\r\n\t\t\r\n\t\tvar homeNode, p = item.p, overTips = \"\";\r\n\t\tif((p != 0) || isDown) {\r\n\t\t\thomeNode = getHasWishDateHomeNode($s,item,isDown);\r\n\t\t}\r\n\t\tif(homeNode) {\r\n\t\t\tvar sDate = iDate.convertDate(item.c.PlanStartDate.t);\t/* 增减前 计划开始时间 */\r\n\t\t\tvar eDate = iDate.convertDate(item.c.PlanEndDate.t);\t/* 增减前 计划完成时间 */\r\n\t\t\tvar csDate = iDate.addDays(iDate.convertDate(item.c.PlanStartDate.t), sDays);\t/* 增减后 计划开始时间 */    \r\n\t\t\tvar ceDate = iDate.addDays(iDate.convertDate(item.c.PlanEndDate.t), eDays);\t\t/* 增减后 计划完成时间 */    \r\n\t\t\tvar rsDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].rsDate) : \"\";\t\t/* 节点要求计划开始时间 */\t\r\n\t\t\tvar reDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].reDate) : \"\";\t    /* 节点要求计划完成时间 */\t\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划开始时间 小于 要求计划开始时间, 计划开始时间增减值(sDays) = rsDate - sDate */\r\n\t\t\tif(rsDate && (csDate < rsDate)){\r\n\t\t\t\tsDays = iDate.getSubDays(sDate, rsDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t} \r\n\t\t\t\r\n\t\t\t/* 若 增减后计划完成时间 大于 要求计划完成时间, 计划完成时间增减值(eDays) = reDate - eDate */\r\n\t\t\tif(reDate && (ceDate > reDate)) {\r\n\t\t\t\teDays = iDate.getSubDays(eDate, reDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划开始时间 大于 要求计划完成时间, 计划开始时间增减值(sDays) = reDate - sDate */\r\n\t\t\tif(reDate && (csDate > reDate)) {\r\n\t\t\t\tsDays = iDate.getSubDays(sDate, reDate);\r\n\t\t\t\t/*eDays = iDate.getSubDays(eDate, reDate);*/\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划完成时间 小于 要求计划开始时间, 计划完成时间增减值(eDays) = rsDate - eDate */\r\n\t\t\tif(rsDate && (ceDate < rsDate)) {\r\n\t\t\t\t/*sDays = iDate.getSubDays(sDate, rsDate);*/\r\n\t\t\t\teDays = iDate.getSubDays(eDate, rsDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\treturn [sDays, eDays, overTips];\r\n\t};\r\n\t\r\n\t/* 获取修改任务时间, 节点日期的增减值 */\r\n\tGantt.prototype._overNodeTime = function($s,item,fUid,sDays,eDays,thisItems) {\r\n\t\t\r\n\t\tvar homeNode = $s.items[eval(\"$s.uidItems.\" + fUid)];\r\n\t\tvar nsDate = iDate.convertDate(homeNode.c.PlanStartDate.t);\r\n\t\tvar neDate = iDate.convertDate(homeNode.c.PlanEndDate.t);\r\n\t\tvar sDate = iDate.convertDate(item.c.PlanStartDate.t);\r\n\t\tvar eDate = iDate.convertDate(item.c.PlanEndDate.t);\r\n\r\n\t\tvar s_delayDays = 0, e_delayDays = 0;\r\n\t\t/* 获取当前节点中所有任务的 最小开始时间 和 最大完成时间 */\r\n\t\tvar mDate = $s._getMaxAndMinDate(thisItems,sDate,eDate);\r\n\t\t\r\n\t\tif(sDays != 0) {\r\n\t\t\tif(sDate > nsDate) {\r\n\t\t\t\ts_delayDays = iDate.getSubDays(nsDate, mDate[0]);\t\t\t\r\n\t\t\t} else if(sDate < nsDate) {\r\n\t\t\t\ts_delayDays = iDate.getSubDays(nsDate, sDate);\r\n\t\t\t} \r\n\t\t}\r\n\t\t\r\n\t\tif(eDays != 0) {\r\n\t\t\tif(eDate > neDate) {\r\n\t\t\t\te_delayDays = iDate.getSubDays(neDate, eDate);\r\n\t\t\t} else if(eDate < neDate) {\r\n\t\t\t\te_delayDays = iDate.getSubDays(neDate, mDate[1]);\r\n\t\t\t} \r\n\t\t}\t\r\n\t\t\r\n\t\treturn [s_delayDays,e_delayDays];\t\r\n\t};\r\n\t\r\n\t\tGantt.prototype.getRelateChange = function(uid, sDays, eDays, fromGraph) {\r\n\t\t\r\n\t    var $s = this\r\n\t      , item = $s.items[eval(\"$s.uidItems.\" + uid)];\r\n\t    $s.changeUids = \"\";\r\n\t    $s.cacheArr = [];\r\n\t    $s.mileArr = [];\r\n\t    $s.adjustArr = [];\r\n\t    $s.lockArr = [];\r\n\t    var oEnd = item.c.PlanEndDate.t;\r\n\t\t\r\n\t\t/* 判断任务变更时间是否超过节点要求完成时间 */\r\n\t\tvar adjustTime = $s._isRequestedTime($s,item,sDays,eDays);\r\n\t\t\r\n\t\t /* 若有超时节点要求时间,提示一下 */\r\n\t\tif(adjustTime[2]) {\r\n\t\t\tgetIMessage().init(adjustTime[2]); \r\n\t\t}\r\n\t\t\r\n\t\t/* 按照调整后的 日期增减值, 变更日期 */\r\n\t\t$s._changeItemDate(item, adjustTime[0], adjustTime[1]);\r\n\t\t\t\t\r\n\t    var relate = eval(\"$s.relates.\" + uid);\r\n\t    if ((sDays != 0 || eDays != 0) && relate) {\r\n\t        $s._bulidRelateChange(item, relate, sDays, oEnd, true);\r\n\t        $s._bulidRelateChange(item, relate, eDays, oEnd, false);\r\n\t    }\r\n\t    var arr = $s.mileArr, item;\r\n\t    if ($s.lockArr.length != 0) {\r\n\t        return 1;\r\n\t    } else {\r\n\t        if ($s.adjustArr.length != 0) {\r\n\t            return 2;\r\n\t        } else {\r\n\t            if (arr.length == 0) {\r\n\t                return null;\r\n\t            } else {\r\n\t                var size = arr.length > 5 ? 5 : arr.length;\r\n\t                var msg = [\"<div style='text-align: left;height: auto;max-height:400px;overflow:auto;'>\" + top.$(\"#tskHint32\").html() + \"<br><br>\"];\r\n\t                for (var i = 0; i < size; i++) {\r\n\t                    item = arr[i][0];\r\n\t                    msg.push(\"<span>\" + item.c.Name.t + \"</span><br><span>\" + top.$(\"#tskHint4\").html() + \":\" + arr[i][1] + \"-->\" + arr[i][2] + \"<span><br><br>\");\r\n\t                }\r\n\t                if (arr.length > size) {\r\n\t                    msg.push(\"<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;..........\");\r\n\t                }\r\n\t                msg.push(\"</div>\");\r\n\t                return msg.join(\"\");\r\n\t            }\r\n\t        }\r\n\t    }\r\n\t};\r\n\t\r\n\tGantt.prototype._bulidRelateChange = function(item, relate, days, oEnd, isLeft) {\r\n\t    var $s = this, tmp, uid, puid, isclose, s, e, sub, relate = isLeft ? relate.i.split(\",\") : relate.o.split(\",\");\r\n\t    if (relate.length < 3 || (days == 0 || (isLeft && days > 0))) {\r\n\t        return;\r\n\t    }\r\n\t    var _oEnd = \"\";\r\n\t    for (var i = 1; i < relate.length - 1; i++) {\r\n\t        uid = relate[i],\r\n\t        tmp = $s.items[eval(\"$s.uidItems.\" + uid)];\r\n\t        _oEnd = tmp.c.PlanEndDate.t;\r\n\t        if (!isLeft && days < 0) {\r\n\t            if ($s.changeUids.indexOf(uid + \",\") > -1) {\r\n\t                continue;\r\n\t            }\r\n\t            $s.changeUids += uid + \",\";\r\n\t        }\r\n\t        if (days > 0) {\r\n\t            s = tmp.c.PlanStartDate.t,\r\n\t            e = item.c.PlanEndDate.t;\r\n\t            if (e < s) {\r\n\t                continue;\r\n\t            }\r\n\t            sub = iDate.getSubDays(iDate.convertDate(s), iDate.convertDate(e)) + 1;\r\n\t            if ($s.config.pg != \"Y\") {\r\n\t                sub = sub > days ? days : sub;\r\n\t            }\r\n\t        } else {\r\n\t            if (isLeft) {\r\n\t                s = item.c.PlanStartDate.t,\r\n\t                e = tmp.c.PlanEndDate.t,\r\n\t                ee = tmp.c.PlanStartDate.t;\r\n\t                if (e < s) {\r\n\t                    continue;\r\n\t                }\r\n\t                if ($s.config.pg == \"Y\") {\r\n\t                    sub = iDate.getSubWorkdays(iDate.convertDate(s), iDate.convertDate(e));\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(ee), iDate.getDateByWorkDay(iDate.convertDate(ee), -sub));\r\n\t                } else {\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(s), iDate.convertDate(e)) + 1;\r\n\t                    sub = (sub + days < 0) ? -sub : days;\r\n\t                }\r\n\t            } else {\r\n\t                if ($s.config.pg == \"Y\") {\r\n\t                    s = tmp.c.PlanStartDate.t,\r\n\t                    e = item.c.PlanEndDate.t;\r\n\t                    var oSub = iDate.getSubWorkdays(iDate.convertDate(oEnd), iDate.convertDate(s)) - 1;\r\n\t                    var ns = iDate.getDateByWorkDay(iDate.convertDate(e), oSub);\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(s), ns);\r\n\t                } else {\r\n\t                    sub = days;\r\n\t                }\r\n\t            }\r\n\t        }\r\n\t\t\t\r\n\t\t\t/* 判断任务变更时间是否超过节点要求完成时间 */\r\n\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,sub,sub);\r\n\t\t\t\r\n\t        $s._changeItemDate(tmp, adjustTime[0], adjustTime[1]);\r\n\t        $s._bulidRelateChange(tmp, eval(\"$s.relates.\" + uid), sub, _oEnd, isLeft);\r\n\t    }\r\n\t}\r\n\t;\r\n\t\r\n\t\tGantt.prototype.updateUpItem = function(ids) {\r\n\t    if (!ids) {\r\n\t        return;\r\n\t    }\r\n\t\t\r\n\t\t/* 升级时,确保任务时间在  节点要求时间内 */\r\n\t\tvar idArr = ids.split(\",\"), $s = this;\r\n\t\tfor(var i=0; i<idArr.length -1; i++) {\r\n\t\t\tvar tmp = $s.getItem(idArr[i]);\r\n\t\t\tif(tmp.n != \"Y\") {\r\n\t\t\t\tif(!$s.cacheArr) {\r\n\t\t\t\t\t$s.cacheArr = [];\r\n\t\t\t\t}\r\n\t\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,0,0,\"up\");\r\n\t\t\t\t$s._changeItemDate(tmp, adjustTime[0], adjustTime[1]);\r\n\t\t\t}\t\r\n\t\t}\r\n\t\t\r\n\t    ids = ids.substring(0, ids.length - 1).split(\",\");\r\n\t    var $s = this,\r\n\t    item = $s.getItem(ids[0]);\r\n\t    max = eval(\"$s.uidItems.\" + ids[ids.length - 1]);\r\n\t    var arr, pad = $s.interval,\r\n\t    pos, pre, nxt, parent, len = $s.items.length,\r\n\t    canUp, refresh = false,\r\n\t    needSave = false;\r\n\t    if (this.config.o && item.p / pad <= 1) {\r\n\t        return;\r\n\t    }\r\n\t    if ($s.isArmy && $s.myGanttCount != 0 && item.p / pad <= $s.myGanttCount) {\r\n\t        return;\r\n\t    }\r\n\t    for (var i = 0; i < ids.length; i++) {\r\n\t        if ($s._checkLockTask($s.getItem(ids[i]))) {\r\n\t            getIMessage().init($(\"#op_gantt_msg16\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t    }\r\n\t    while (item && item.pos <= max) {\r\n\t        pos = item.pos;\r\n\t        nxt = pos < len - 1 ? $s.items[++pos] : null;\r\n\t        canUp = true;\r\n\t        arr = [item];\r\n\t        if (item.p > 0) {\r\n\t            while (canUp && nxt && nxt.p >= item.p) {\r\n\t                if (pos > max && nxt.p == item.p) {\r\n\t                    canUp = false;\r\n\t                } else {\r\n\t                    arr.push(nxt);\r\n\t                    nxt = $s.items[++pos];\r\n\t                    if (nxt) {\r\n\t                        nxt.pos = pos;\r\n\t                    }\r\n\t                }\r\n\t            }\r\n\t            if (item.n == \"Y\") {\r\n\t                if (nxt && nxt.p >= item.p) {\r\n\t                    item.s = 1;\r\n\t                }\r\n\t                canUp = true;\r\n\t            }\r\n\t            if (canUp) {\r\n\t                for (var i = 0; i < arr.length; i++) {\r\n\t                    arr[i].p = arr[i].p - pad;\r\n\t                    pre = $s.items[arr[i].pos - 1];\r\n\t                    if (pre.n == \"Y\" || this._checkSimulateNode(pre)) {\r\n\t                        if (pre.p == arr[i].p) {\r\n\t                            pre.s = 0;\r\n\t                        } else {\r\n\t                            if (pre.p == 0) {\r\n\t                                pre.s = 1;\r\n\t                                refresh = true;\r\n\t                            }\r\n\t                        }\r\n\t                    }\r\n\t                }\r\n\t                needSave = true;\r\n\t            }\r\n\t        }\r\n\t        item = nxt;\r\n\t        if (item) {\r\n\t            item.pos = pos;\r\n\t        }\r\n\t    }\r\n\t    if (refresh) {\r\n\t        $s._initItemsMap();\r\n\t    }\r\n\t    $s._updateNodeDate();\r\n\t    if (needSave) {\r\n\t        $s._activeSave();\r\n\t    }\r\n\t};\r\n\t\r\n\tGantt.prototype.updateDownItem = function(ids) {\r\n\t\t\r\n\t    if (!ids) {\r\n\t        return;\r\n\t    }\r\n\t\t\r\n\t\t/* 降级时,确保任务时间在  节点要求时间内 */\r\n\t\tvar idArr = ids.split(\",\"), $s = this;\r\n\t\tfor(var i=0; i<idArr.length -1; i++) {\r\n\t\t\tvar tmp = $s.getItem(idArr[i]);\r\n\t\t\tif(!$s.cacheArr) {\r\n\t\t\t\t$s.cacheArr = [];\r\n\t\t\t}\r\n\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,0,0,\"down\");\r\n\t\t\tif(adjustTime[0] != 0 || adjustTime[1] != 0) {\r\n\t\t\t\tgetIMessage().init(adjustTime[2],1); \r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t    ids = ids.substring(0, ids.length - 1).split(\",\");\r\n\t    var $s = this,\r\n\t    item = $s.getItem(ids[0]);\r\n\t    max = eval(\"$s.uidItems.\" + ids[ids.length - 1]);\r\n\t    var pad, pos, pre, nxt, parent, len = $s.items.length,\r\n\t    refresh = false,\r\n\t    needSave = false;\r\n\t    for (var i = 0; i < ids.length; i++) {\r\n\t        if ($s._checkLockTask($s.getItem(ids[i]))) {\r\n\t            getIMessage().init($(\"#op_gantt_msg16\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t    }\r\n\t    var chg = [];\r\n\t    while (item && item.pos <= max) {\r\n\t        pad = $s._canDown(item) ? $s.interval: 0;\r\n\t        if (!needSave) {\r\n\t            needSave = pad > 0;\r\n\t        }\r\n\t        pos = item.pos;\r\n\t        nxt = pos < len - 1 ? $s.items[++pos] : null;\r\n\t        chg = [];\r\n\t        if (pad > 0 && nxt) {\r\n\t            while (nxt && item.p < nxt.p) {\r\n\t                nxt.p = nxt.p + pad;\r\n\t                if ($s._compareParentDay(nxt.u, nxt.c.PlanEndDate.t)) {\r\n\t                    nxt.p -= pad;\r\n\t                    getIMessage().init($(\"#op_gantt_msg15\").html(), 1);\r\n\t                    return false;\r\n\t                }\r\n\t                chg.push(nxt);\r\n\t                nxt = $s.items[++pos];\r\n\t            }\r\n\t        }\r\n\t        if (item.pos > 0) {\r\n\t            pre = $s.items[item.pos - 1];\r\n\t            pre.s = ((pre.n == \"Y\" || $s.isArmy) && pre.p == item.p) ? 1 : pre.s;\r\n\t        }\r\n\t        item.p = item.p + pad;\r\n\t        if ($s._compareParentDay(item.u, item.c.PlanEndDate.t)) {\r\n\t            item.p -= pad;\r\n\t            if (pre.s == 1) {\r\n\t                pre.s = 0;\r\n\t            }\r\n\t            for (var i = 0; i < chg.length; i++) {\r\n\t                chg[i].p -= pad;\r\n\t            }\r\n\t            getIMessage().init($(\"#op_gantt_msg15\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t        parent = $s.getItem($s._getParent(item.u));\r\n\t        if (parent && parent.s == -1) {\r\n\t            parent.s = 1;\r\n\t            refresh = true;\r\n\t        }\r\n\t        item = nxt;\r\n\t        if (item) {\r\n\t            item.pos = pos;\r\n\t        }\r\n\t    }\r\n\t    if (refresh) {\r\n\t        $s._initItemsMap();\r\n\t    }\r\n\t    $s._updateNodeDate();\r\n\t    if (needSave) {\r\n\t        $s._activeSave();\r\n\t    }\r\n\t};\r\n\t\r\n}\r\n\r\n\r\n\r\n/* 节点增加前后置关系    */\r\nif(custom_url.indexOf(\"/pages/task/list/tree.jsf?type=TSK\") >= 0 && custom_url.indexOf(\"noMenuBarItem2=Y\") < 0) {\r\n\tvar synAjax = {\r\n\t\ttabCall : function(className, methodName, paramsArr, respHandle, noLoading) {\r\n\t\t\tif(!noLoading) openLoader();\r\n\t\t\tvar reqData = \"className=\" + className + \"&methodName=\" + methodName;\r\n\t\t\t\r\n\t\t\tif (paramsArr && paramsArr.length > 0) {\r\n\t\t\t\tfor (var i = 0; i < paramsArr.length; i++) {\r\n\t\t\t\t\treqData += \"&paramValues=\" + paramsArr[i];\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\treqData += \"&r=\" + Math.random();\r\n\t\t\t\r\n\t\t\t$.ajax({\r\n\t\t\t\turl: \"rdm.tab\",\r\n\t\t\t\tasync: false,\r\n\t\t\t\tdata: reqData,\r\n\t\t\t\tdataType: 'html',\r\n\t\t\t\ttype: \"POST\",\r\n\t\t\t\tsuccess: function(html){\r\n\t\t\t\t\tif (respHandle) respHandle(html);\r\n\t\t\t\t\tif(!noLoading) closeLoader();\r\n\t\t\t\t}\r\n\t\t\t});\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* 从url中获取计划ID */\r\n\tvar planId = custom_url.substr(custom_url.indexOf(\"planId=\") + 7, 36);\r\n\t\r\n\t\r\n\t/* 是否执行了 升级降级 操作, 如果执行了升级降级操作,须点击保存按钮,才可链接节点 */\r\n\tvar reqTimeData = {}, relateNodeData = {}, isChangeNode = \"N\", idToUidJson;\r\n\t\r\n\t$(function() {\r\n\t\t/* 用户是否是项目经理 */\r\n\t\tvar isManager = userIsManager(planId);\r\n\t\t\r\n\t\t/* 实例化链接节点按钮 */\r\n\t\tif(\"Y\" == isManager) {\r\n\t\t\t$(\".menuBarItem2\").eq(0).append(\"<div class='button-group menu-right' style='margin: 0px; display: block;'><input type='button' id='uploadButton' class='button' onclick='linkNode(true);' value='链接节点'></div>\");\r\n\t\t\t$(\".menuBarItem2\").eq(0).append(\"<div class='button-group menu-right' style='margin: 0px; display: block;'><input type='button' id='uploadButton' class='button' onclick='linkNode(false);' value='取消链接节点'></div>\");\t\r\n\t\t}\r\n\t\t/* 实例化id  uid  键值对 */\r\n\t\ttaskGantt._getItemIdAndUidJson();\r\n\t\t/* 实例化节点关联关系 */\r\n\t\ttaskGantt._getNodeRelateData();\r\n\t\t/* 实例化每个节点要求时间 */\r\n\t\ttaskGantt._getNodeRequirementDate();\r\n\t\t/* 前置节点 字段不可编辑  */\r\n\t\tsetPreNodeNotEdit();\r\n\t});\r\n\t\r\n\tfunction userIsManager(planId) {\r\n\t\tvar isM = \"N\";\r\n\t\tsynAjax.tabCall(\"com.bronzesoft.inspur.task.TaskGanttCustomDao\",\"userIsManager\",[planId],function(msg) {\r\n\t\t\tif(msg.trim()) {\r\n\t\t\t\tisM = msg.trim();\r\n\t\t\t}\r\n\t\t});\t\r\n\t\treturn isM;\r\n\t}\r\n\t\r\n\t/* 设置前置节点列不可编辑 */\r\n\tfunction setPreNodeNotEdit() {\r\n\t\t\r\n\t\tvar index_node = $(\"#ganttDiv\").find(\"th[name='Fld_T_00004']\").index();\r\n\t\tvar $td = $(\"#ganttDiv\").find(\"tbody\").eq(1).find(\"td\");\r\n\t\t$td.each(function() {\r\n\t\t\tif($(this).index() == index_node) {\r\n\t\t\t\tvar $div = $(this).find(\"div\");\r\n\t\t\t\tif($div.length > 0) {\r\n\t\t\t\t\t$div.attr(\"edit\",\"N\");\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n\t\r\n\t/* 展开/关闭节点前 保存关联关系 */\r\n\tGantt.prototype.adjustToggleNode = function(uid) {\r\n\t\t/* 保存关联关系 */\r\n\t\t\r\n\t\tsaveNodeRelate();\r\n\t\tvar item = this.items[eval(\"this.uidItems.\" + uid)];\r\n\t\titem.s = item.s == -1 ? 1 : -1;\r\n\t\tthis._initItemsMap();\r\n\t};\r\n\t\r\n\t/* 新建的任务需要在 节点要求时间内, 并且直接影响关联的节点 */\r\n\tGantt.prototype.updateCreateTask = function(isNode, uid) {\r\n\t\tvar pad = 0\r\n\t\t  , pos = this.items.length, fUid;\r\n\t\tif (uid) {\r\n\t\t\tvar item = this.getItem(uid);\r\n\t\t\tpos = eval(\"this.uidItems.\" + uid) + 1;\r\n\t\t\tpad = item.p;\r\n\t\t\tif (item.n == \"Y\") {\r\n\t\t\t\tif (item.s == 1) {\r\n\t\t\t\t\tpad += this.interval;\r\n\t\t\t\t} else {\r\n\t\t\t\t\tvar uids = this.getSeriesUids(uid, true);\r\n\t\t\t\t\tuids = uids.substring(0, uids.length - 1);\r\n\t\t\t\t\tpos = eval(\"this.uidItems.\" + uids.split(\",\").pop()) + 1;\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\tfUid = this._findTempHomeNode(this,item);\r\n\t\t}\r\n\t\tvar colArr, configD = this.config.d, rTime = reqTimeData[fUid];\r\n\t\t/* 若节点有要求时间 */\r\n\t\tif(rTime) {\r\n\t\t\tif(iDate.convertDate(rTime.rsDate) > iDate.convertDate(configD) || iDate.convertDate(rTime.reDate) < iDate.convertDate(configD)) {\r\n\t\t\t\tconfigD = rTime.rsDate;\r\n\t\t\t}\r\n\t\t}\r\n\t\tif (this.config.pg == \"Y\") {\r\n\t\t\tcolArr = this._createColumns(pos, isNode, this._getNextWorkDay(configD));\r\n\t\t} else {\r\n\t\t\tcolArr = this._createColumns(pos, isNode, configD);\r\n\t\t}\r\n\t\treturn this._buildCreateItems(colArr, isNode, pad, pos);\r\n\t};\r\n\t\r\n\t\r\n\t/* 新建任务、节点时, 先保存关联关系 */\r\n\tfunction createTask(c) {\r\n\t\t/* 保存关联关系 */\r\n\t\tsaveNodeRelate();\r\n\t\tvar b = $table.ganttTable(\"getRows\");\r\n\t\tif (b && b.indexOf(\",\") >= 0) {\r\n\t\t\tb = b.split(\",\")[0];\r\n\t\t}\r\n\t\tvar a = taskGantt.updateCreateTask(c, b);\r\n\t\tif (a) {\r\n\t\t\t$graph.ganttGraph(\"refreshData\", iMain.getEvt(), false);\r\n\t\t\t$table.ganttTable(\"selectRow\", {\r\n\t\t\t\tcol: a[1],\r\n\t\t\t\tid: a[0] + \",\"\r\n\t\t\t});\r\n\t\t}\r\n\t}\r\n\t\r\n\tGantt.prototype._initItemsMap = function() {\r\n\t\t\r\n\t\tvar $s = this, k = 0, tmp, pad = 0, arr = [\"{\"], isclose = false, r;\r\n\t\t$s.visibleItems = [];\r\n\t\tfor (var i = 0; i < $s.items.length; i++) {\r\n\t\t\ttmp = $s.items[i];\r\n\t\t\tarr.push(tmp.u + \":\" + i + \",\");\r\n\t\t\tif (tmp.d == \"N\" || (isclose && tmp.p > pad)) {\r\n\t\t\t\tcontinue;\r\n\t\t\t}\r\n\t\t\tpad = tmp.p;\r\n\t\t\tisclose = tmp.s == -1;\r\n\t\t\ttmp.x = k;\r\n\t\t\t$s.visibleItems[k++] = i;\r\n\t\t}\r\n\t\tarr = arr.join(\"\");\r\n\t\tif (arr.length != 1) {\r\n\t\t\t$s.uidItems = eval(\"(\" + arr.substring(0, arr.length - 1) + \"})\");\r\n\t\t}\r\n\t\t$s.scrollH = $s.visibleItems.length * $s.rowH + 180;\r\n\t\t$s.visibleString = \",\" + $s.visibleItems.join(\",\") + \",\";\r\n\t\t\r\n\t\ttaskGantt._getItemIdAndUidJson($s);\r\n\t\t/* 实例化节点关联关系 */\r\n\t\ttaskGantt._getNodeRelateData($s);\r\n\t\t/* 实例化每个节点要求时间 */\r\n\t\ttaskGantt._getNodeRequirementDate();\r\n\t\t\r\n\t\tif (!$s.hasRelate()) {\r\n\t\t\treturn\r\n\t\t}\r\n\t\tfor (var i = 0; i < $s.items.length; i++) {\r\n\t\t\tr = $s.items[i].c.Relate;\r\n\t\t\tif (r && r.v) {\r\n\t\t\t\tr.t = $s.getRelateValueByUids(r.v.split(\",\"));\r\n\t\t\t}\r\n\t\t}\r\n\t};\r\n\t\r\n\t\r\n\t/* 获取item 的 id uid 键值对*/\r\n\tGantt.prototype._getItemIdAndUidJson = function($t) {\r\n\t\tidToUidJson = {};\r\n\t\t\r\n\t\tvar allItems = $t ? $t.items : taskGantt.items;\r\n\t\tfor(var i=0;i<allItems.length;i++) {\r\n\t\t\tvar uid = allItems[i].u, id = allItems[i].i;\r\n\t\t\tidToUidJson[uid] = id;\r\n\t\t\tidToUidJson[id] = uid;\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* id 转 uid 或 uid 转 id*/\r\n\tGantt.prototype._itemIdToUid = function(ids) {\r\n\t\tif(ids) {\r\n\t\t\tvar idsArr = ids.split(\",\"), uids = [];\r\n\t\t\tfor(var i=0;i<idsArr.length;i++) {\r\n\t\t\t\tuids.push(idToUidJson[idsArr[i]]);\r\n\t\t\t}\r\n\t\t\treturn uids.join(\",\");\r\n\t\t}\r\n\t\treturn ids;\r\n\t};\r\n\t\r\n\t/* 保存节点关联关系 */\r\n\tfunction saveNodeRelate() {\r\n\t\t\r\n\t\tvar d = {};\r\n\t\t/* 需把uid 转化成 id */\r\n\t\tfor(var j in relateNodeData) {\r\n\t\t\tv