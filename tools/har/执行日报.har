\t\t}\r\n\t\t}\r\n\t\treturn \"\";\r\n\t};\r\n\t\r\n\t\r\n\t/* 判断是否有前后置节点 */\r\n\tGantt.prototype._hasNodeRelate = function($s,item) {\r\n\t\tvar homeNode = \"\";\r\n\t\t/* 向上查找节点, 返回值再确认一下 */\r\n\t\tvar itemsArr = $s.items, p = item.p;\r\n\t\tif(p != 0) {\r\n\t\t\tvar i = eval(\"$s.uidItems.\" + item.u); \r\n\t\t\ti--;\r\n\t\t\tfor(;i<itemsArr.length;i--) {\r\n\t\t\t\tvar item = itemsArr[i], fp = item.p;\r\n\t\t\t\tif(fp < p) {\r\n\t\t\t\t\treturn [relateNodeData[item.u],item.u];\r\n\t\t\t\t} \r\n\t\t\t}\r\n\t\t}\r\n\t\treturn homeNode;\r\n\t};\r\n\t\r\n\t/* 查找填写了要求完成时间的父节点 */\r\n\tfunction getHasWishDateHomeNode($s,item,isDown) {\r\n\t\tvar homeNode = $s._findTempHomeNode($s,item,isDown);\r\n\t\tif(homeNode) {\r\n\t\t\tvar temp_rsDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].rsDate) : \"\";\t\t\r\n\t\t\tvar temp_reDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].reDate) : \"\";\r\n\t\t\tif(!temp_rsDate || !temp_reDate) {\r\n\t\t\t\tvar homeNode_item = taskGantt.getItem(homeNode);\r\n\t\t\t\tgetHasWishDateHomeNode($s,homeNode_item,isDown);\r\n\t\t\t} else {\r\n\t\t\t\treturn homeNode;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n\t\r\n\t/* 日期变更后,是否处于节点要求完成时间内； 返回调整后的 日期增减值 sDays,eDays */\r\n\tGantt.prototype._isRequestedTime = function($s,item,sDays,eDays,isDown) {\r\n\t\t\r\n\t\tvar homeNode, p = item.p, overTips = \"\";\r\n\t\tif((p != 0) || isDown) {\r\n\t\t\thomeNode = getHasWishDateHomeNode($s,item,isDown);\r\n\t\t}\r\n\t\tif(homeNode) {\r\n\t\t\tvar sDate = iDate.convertDate(item.c.PlanStartDate.t);\t/* 增减前 计划开始时间 */\r\n\t\t\tvar eDate = iDate.convertDate(item.c.PlanEndDate.t);\t/* 增减前 计划完成时间 */\r\n\t\t\tvar csDate = iDate.addDays(iDate.convertDate(item.c.PlanStartDate.t), sDays);\t/* 增减后 计划开始时间 */    \r\n\t\t\tvar ceDate = iDate.addDays(iDate.convertDate(item.c.PlanEndDate.t), eDays);\t\t/* 增减后 计划完成时间 */    \r\n\t\t\tvar rsDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].rsDate) : \"\";\t\t/* 节点要求计划开始时间 */\t\r\n\t\t\tvar reDate = reqTimeData[homeNode] ? iDate.convertDate(reqTimeData[homeNode].reDate) : \"\";\t    /* 节点要求计划完成时间 */\t\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划开始时间 小于 要求计划开始时间, 计划开始时间增减值(sDays) = rsDate - sDate */\r\n\t\t\tif(rsDate && (csDate < rsDate)){\r\n\t\t\t\tsDays = iDate.getSubDays(sDate, rsDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t} \r\n\t\t\t\r\n\t\t\t/* 若 增减后计划完成时间 大于 要求计划完成时间, 计划完成时间增减值(eDays) = reDate - eDate */\r\n\t\t\tif(reDate && (ceDate > reDate)) {\r\n\t\t\t\teDays = iDate.getSubDays(eDate, reDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划开始时间 大于 要求计划完成时间, 计划开始时间增减值(sDays) = reDate - sDate */\r\n\t\t\tif(reDate && (csDate > reDate)) {\r\n\t\t\t\tsDays = iDate.getSubDays(sDate, reDate);\r\n\t\t\t\t/*eDays = iDate.getSubDays(eDate, reDate);*/\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t/* 若 增减后计划完成时间 小于 要求计划开始时间, 计划完成时间增减值(eDays) = rsDate - eDate */\r\n\t\t\tif(rsDate && (ceDate < rsDate)) {\r\n\t\t\t\t/*sDays = iDate.getSubDays(sDate, rsDate);*/\r\n\t\t\t\teDays = iDate.getSubDays(eDate, rsDate);\r\n\t\t\t\toverTips = overTips ? overTips : \"任务时间需包含于其节点要求时间区间:[ \"+reqTimeData[homeNode].rsDate + \" ~ \" + reqTimeData[homeNode].reDate + \" ]\";\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\treturn [sDays, eDays, overTips];\r\n\t};\r\n\t\r\n\t/* 获取修改任务时间, 节点日期的增减值 */\r\n\tGantt.prototype._overNodeTime = function($s,item,fUid,sDays,eDays,thisItems) {\r\n\t\t\r\n\t\tvar homeNode = $s.items[eval(\"$s.uidItems.\" + fUid)];\r\n\t\tvar nsDate = iDate.convertDate(homeNode.c.PlanStartDate.t);\r\n\t\tvar neDate = iDate.convertDate(homeNode.c.PlanEndDate.t);\r\n\t\tvar sDate = iDate.convertDate(item.c.PlanStartDate.t);\r\n\t\tvar eDate = iDate.convertDate(item.c.PlanEndDate.t);\r\n\r\n\t\tvar s_delayDays = 0, e_delayDays = 0;\r\n\t\t/* 获取当前节点中所有任务的 最小开始时间 和 最大完成时间 */\r\n\t\tvar mDate = $s._getMaxAndMinDate(thisItems,sDate,eDate);\r\n\t\t\r\n\t\tif(sDays != 0) {\r\n\t\t\tif(sDate > nsDate) {\r\n\t\t\t\ts_delayDays = iDate.getSubDays(nsDate, mDate[0]);\t\t\t\r\n\t\t\t} else if(sDate < nsDate) {\r\n\t\t\t\ts_delayDays = iDate.getSubDays(nsDate, sDate);\r\n\t\t\t} \r\n\t\t}\r\n\t\t\r\n\t\tif(eDays != 0) {\r\n\t\t\tif(eDate > neDate) {\r\n\t\t\t\te_delayDays = iDate.getSubDays(neDate, eDate);\r\n\t\t\t} else if(eDate < neDate) {\r\n\t\t\t\te_delayDays = iDate.getSubDays(neDate, mDate[1]);\r\n\t\t\t} \r\n\t\t}\t\r\n\t\t\r\n\t\treturn [s_delayDays,e_delayDays];\t\r\n\t};\r\n\t\r\n\t/* 获取本节点中的所有任务 */\r\n\tGantt.prototype._getItemsByNodeUid = function($s,nodeUid) {\r\n\t\tvar itemsArr = $s.items;\r\n\t\tvar i = eval(\"$s.uidItems.\" + nodeUid), fp = itemsArr[i].p, cItems = []; \r\n\t\ti++;\r\n\t\tfor(;i<itemsArr.length;i++) {\r\n\t\t\tvar item = itemsArr[i], cp = item.p, uid = item.u;\r\n\t\t\tif(fp < cp) {\r\n\t\t\t\tcItems[uid] = item;\r\n\t\t\t} else {\r\n\t\t\t\tbreak;\r\n\t\t\t}\r\n\t\t}\r\n\t\treturn cItems;\r\n\t};\r\n\t\r\n\t/* 获取当前节点中所有任务的 最小开始时间 和 最大完成时间 */\r\n\tGantt.prototype._getMaxAndMinDate = function(thisItems,sDate,eDate) {\t\r\n\t\tif(!thisItems) {\r\n\t\t\treturn [null,null];\r\n\t\t}\r\n\t\tvar eArr = eDate ? [eDate] : [];\r\n\t\tvar sArr = sDate ? [sDate] : [];\r\n\t\t\r\n\t\tfor(var i in thisItems) {\r\n\t\t\teArr.push(iDate.convertDate(thisItems[i].c.PlanEndDate.t));\r\n\t\t\tsArr.push(iDate.convertDate(thisItems[i].c.PlanStartDate.t));\r\n\t\t}\r\n\t\t\r\n\t\tvar e_MaxDate = new Date(Math.max.apply(null,eArr));\r\n\t    var s_MinDate = new Date(Math.min.apply(null,sArr));\r\n\t\t\r\n\t\treturn [s_MinDate,e_MaxDate];\r\n\t};\r\n\t\r\n\t/* 移动任务日期 */\r\n\tGantt.prototype._delayTaskTime = function($s,thisItems,overSdays,overEdays) {\r\n\t\t\r\n\t    for(var i in thisItems) {\r\n\t\t\tvar t_status = thisItems[i].c.Status.v;\r\n\t\t\tif(t_status && \"NP,PA,FC,WA,CL\".indexOf(t_status) < 0) {\r\n\t\t\t\t/* 再次根据节点要求时间调整一下 日期增减值 */\r\n\t\t\t\tvar adjustTime = $s._isRequestedTime($s,thisItems[i],overSdays,overEdays);\r\n\t\t\t\t/* 变更任务日期 */\r\n\t\t\t\t$s._changeItemDate(thisItems[i],adjustTime[0],adjustTime[1]);\r\n\t\t\t}\r\n\t\t}\r\n\t};\r\n\t\r\n\t/* 改变后置节点任务时间 */\r\n\tGantt.prototype._changePostItemDate = function(k, a, i) {\r\n\t\t\r\n\t\tvar b = k.l == 1 || (k.c.Status.v && \"FC,CL,PA,WA\".indexOf(k.c.Status.v) > -1)\r\n\t\t  , l = k.c.PlanStartDate.t\r\n\t\t  , h = k.c.PlanEndDate.t\r\n\t\t  , c = k.c.PlanDuration.t;\r\n\t\tthis.cacheArr.push([b, k, l, h, c]);\r\n\t\tvar j, g, d;\r\n\t\tif (this.config.pg == \"Y\") {\r\n\t\t\tj = iDate.addDays(iDate.convertDate(l), a);\r\n\t\t\tif (!iDate.isWorkingDay(j)) {\r\n\t\t\t\tj = iDate.getNextWorkDay(j);\r\n\t\t\t}\r\n\t\t\tif (a == i) {\r\n\t\t\t\tg = iDate.getDateByWorkDay2(new Date(j), c > 0 ? (c - 1) : 0);\r\n\t\t\t\td = c > 0 ? c : 1;\r\n\t\t\t} else {\r\n\t\t\t\tg = iDate.addDays(iDate.convertDate(h), i);\r\n\t\t\t\tif (!iDate.isWorkingDay(g)) {\r\n\t\t\t\t\tg = iDate.getPrevWorkDay(g);\r\n\t\t\t\t}\r\n\t\t\t\tif (g < j) {\r\n\t\t\t\t\tg = j;\r\n\t\t\t\t}\r\n\t\t\t\td = iDate.getSubWorkdays(j, g);\r\n\t\t\t}\r\n\t\t} else {\r\n\t\t\tj = iDate.addDays(iDate.convertDate(l), a);\r\n\t\t\tg = iDate.addDays(iDate.convertDate(h), i);\r\n\t\t\td = iDate.getSubWorkdays(j, g);\r\n\t\t}\r\n\t\tj = iDate.formatDay(j);\r\n\t\tg = iDate.formatDay(g);\r\n\t\tif (!b && k.c.milestone.t && a > 0 && this.mileArr.length <= 11) {\r\n\t\t\tthis.mileArr.push([k, h, g]);\r\n\t\t}\r\n\t\tif (!b && (this._compareParentDay(k.u, g) || this._compareChildrenDay(k.u, g))) {\r\n\t\t\tthis.adjustArr.push(k);\r\n\t\t}\r\n\t\tk.c.PlanStartDate.t = j;\r\n\t\tk.c.PlanEndDate.t = g;\r\n\t\tk.c.PlanDuration.t = d;\r\n\t\tk.m = 1;\r\n\t};\r\n\t\r\n\t\r\n\tGantt.prototype.getRelateChange = function(uid, sDays, eDays, fromGraph) {\r\n\t\t\r\n\t    var $s = this\r\n\t      , item = $s.items[eval(\"$s.uidItems.\" + uid)];\r\n\t    $s.changeUids = \"\";\r\n\t    $s.cacheArr = [];\r\n\t    $s.mileArr = [];\r\n\t    $s.adjustArr = [];\r\n\t    $s.lockArr = [];\r\n\t    var oEnd = item.c.PlanEndDate.t;\r\n\t\t\r\n\t\t/* 判断任务变更时间是否超过节点要求完成时间 */\r\n\t\tvar adjustTime = $s._isRequestedTime($s,item,sDays,eDays);\r\n\t\t\r\n\t\t /* 若有超时节点要求时间,提示一下 */\r\n\t\tif(adjustTime[2]) {\r\n\t\t\tgetIMessage().init(adjustTime[2]); \r\n\t\t}\r\n\t\t\r\n\t\t/* 按照调整后的 日期增减值, 变更日期 */\r\n\t\t$s._changeItemDate(item, adjustTime[0], adjustTime[1]);\r\n\t\t\r\n\t\t\r\n\t\t/* 判断是否有节点关联关系 */\r\n\t\tvar nodeRelate = $s._hasNodeRelate($s,item);\r\n\t\tif(nodeRelate && nodeRelate.length == 2) {\r\n\t\t\t/* 获取当前节点下的第一级所有任务/节点 */\r\n\t\t\tvar thisItems = $s._getItemsByNodeUid($s,nodeRelate[1]);\r\n\t\t\t/* 获取修改任务时间后,其节点日期的增减天数 */\r\n\t\t\tvar overNodeTime = $s._overNodeTime($s,item,nodeRelate[1],sDays,eDays,thisItems);\r\n\t\t\t/* 声明前置节点(可多个) 和 后置节点(可多个) */\r\n\t\t\tvar preNode = nodeRelate[0] ? nodeRelate[0].i : \"\", postNode = nodeRelate[0] ? nodeRelate[0].o : \"\";\r\n\t\t\t\r\n\t\t\t/* 如果存在前置节点 */\r\n\t\t\tif(preNode) {\r\n\t\t\t\tvar preNodeArr = preNode.split(\",\");\r\n\t\t\t\t/* 获取前置节点所有任务 */\r\n\t\t\t\tfor(var i = 0; i<preNodeArr.length; i++) {\r\n\t\t\t\t    var preItems = $s._getItemsByNodeUid($s,preNodeArr[i]);\r\n\t\t\t\t\t/* 移动任务日期 */\r\n\t\t\t\t\t$s._delayTaskTime($s,preItems,overNodeTime[0],overNodeTime[0]);\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t\t\r\n\t\t\t/* 如果存在后置节点 */\r\n\t\t\tif(postNode) {\r\n\t\t\t\tvar postNodeArr = postNode.split(\",\");\r\n\t\t\t\t/* 获取后置节点所有任务 */\r\n\t\t\t\tfor(var i = 0; i<postNodeArr.length; i++) {\r\n\t\t\t\t\tvar postItems = $s._getItemsByNodeUid($s,postNodeArr[i]);\r\n\t\t\t\t\t/* 移动任务日期 */\r\n\t\t\t\t\t$s._delayTaskTime($s,postItems,overNodeTime[1],overNodeTime[1]);\r\n\t\t\t\t}\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t    var relate = eval(\"$s.relates.\" + uid);\r\n\t    if ((sDays != 0 || eDays != 0) && relate) {\r\n\t        $s._bulidRelateChange(item, relate, sDays, oEnd, true);\r\n\t        $s._bulidRelateChange(item, relate, eDays, oEnd, false);\r\n\t    }\r\n\t    var arr = $s.mileArr, item;\r\n\t    if ($s.lockArr.length != 0) {\r\n\t        return 1;\r\n\t    } else {\r\n\t        if ($s.adjustArr.length != 0) {\r\n\t            return 2;\r\n\t        } else {\r\n\t            if (arr.length == 0) {\r\n\t                return null;\r\n\t            } else {\r\n\t                var size = arr.length > 5 ? 5 : arr.length;\r\n\t                var msg = [\"<div style='text-align: left;height: auto;max-height:400px;overflow:auto;'>\" + top.$(\"#tskHint32\").html() + \"<br><br>\"];\r\n\t                for (var i = 0; i < size; i++) {\r\n\t                    item = arr[i][0];\r\n\t                    msg.push(\"<span>\" + item.c.Name.t + \"</span><br><span>\" + top.$(\"#tskHint4\").html() + \":\" + arr[i][1] + \"-->\" + arr[i][2] + \"<span><br><br>\");\r\n\t                }\r\n\t                if (arr.length > size) {\r\n\t                    msg.push(\"<br>&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;&nbsp;..........\");\r\n\t                }\r\n\t                msg.push(\"</div>\");\r\n\t                return msg.join(\"\");\r\n\t            }\r\n\t        }\r\n\t    }\r\n\t};\r\n\t\r\n\tGantt.prototype._bulidRelateChange = function(item, relate, days, oEnd, isLeft) {\r\n\t    var $s = this, tmp, uid, puid, isclose, s, e, sub, relate = isLeft ? relate.i.split(\",\") : relate.o.split(\",\");\r\n\t    if (relate.length < 3 || (days == 0 || (isLeft && days > 0))) {\r\n\t        return;\r\n\t    }\r\n\t    var _oEnd = \"\";\r\n\t    for (var i = 1; i < relate.length - 1; i++) {\r\n\t        uid = relate[i],\r\n\t        tmp = $s.items[eval(\"$s.uidItems.\" + uid)];\r\n\t        _oEnd = tmp.c.PlanEndDate.t;\r\n\t        if (!isLeft && days < 0) {\r\n\t            if ($s.changeUids.indexOf(uid + \",\") > -1) {\r\n\t                continue;\r\n\t            }\r\n\t            $s.changeUids += uid + \",\";\r\n\t        }\r\n\t        if (days > 0) {\r\n\t            s = tmp.c.PlanStartDate.t,\r\n\t            e = item.c.PlanEndDate.t;\r\n\t            if (e < s) {\r\n\t                continue;\r\n\t            }\r\n\t            sub = iDate.getSubDays(iDate.convertDate(s), iDate.convertDate(e)) + 1;\r\n\t            if ($s.config.pg != \"Y\") {\r\n\t                sub = sub > days ? days : sub;\r\n\t            }\r\n\t        } else {\r\n\t            if (isLeft) {\r\n\t                s = item.c.PlanStartDate.t,\r\n\t                e = tmp.c.PlanEndDate.t,\r\n\t                ee = tmp.c.PlanStartDate.t;\r\n\t                if (e < s) {\r\n\t                    continue;\r\n\t                }\r\n\t                if ($s.config.pg == \"Y\") {\r\n\t                    sub = iDate.getSubWorkdays(iDate.convertDate(s), iDate.convertDate(e));\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(ee), iDate.getDateByWorkDay(iDate.convertDate(ee), -sub));\r\n\t                } else {\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(s), iDate.convertDate(e)) + 1;\r\n\t                    sub = (sub + days < 0) ? -sub : days;\r\n\t                }\r\n\t            } else {\r\n\t                if ($s.config.pg == \"Y\") {\r\n\t                    s = tmp.c.PlanStartDate.t,\r\n\t                    e = item.c.PlanEndDate.t;\r\n\t                    var oSub = iDate.getSubWorkdays(iDate.convertDate(oEnd), iDate.convertDate(s)) - 1;\r\n\t                    var ns = iDate.getDateByWorkDay(iDate.convertDate(e), oSub);\r\n\t                    sub = iDate.getSubDays(iDate.convertDate(s), ns);\r\n\t                } else {\r\n\t                    sub = days;\r\n\t                }\r\n\t            }\r\n\t        }\r\n\t\t\t\r\n\t\t\t/* 判断任务变更时间是否超过节点要求完成时间 */\r\n\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,sub,sub);\r\n\t\t\t\r\n\t        $s._changeItemDate(tmp, adjustTime[0], adjustTime[1]);\r\n\t        $s._bulidRelateChange(tmp, eval(\"$s.relates.\" + uid), sub, _oEnd, isLeft);\r\n\t    }\r\n\t}\r\n\t;\r\n\t\r\n\tGantt.prototype.updateUpItem = function(ids) {\r\n\t    if (!ids) {\r\n\t        return;\r\n\t    }\r\n\t\t\r\n\t\t/* 升级时,确保任务时间在  节点要求时间内 */\r\n\t\tvar idArr = ids.split(\",\"), $s = this;\r\n\t\tfor(var i=0; i<idArr.length -1; i++) {\r\n\t\t\tvar tmp = $s.getItem(idArr[i]);\r\n\t\t\tif(tmp.n != \"Y\") {\r\n\t\t\t\tif(!$s.cacheArr) {\r\n\t\t\t\t\t$s.cacheArr = [];\r\n\t\t\t\t}\r\n\t\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,0,0,\"up\");\r\n\t\t\t\t$s._changeItemDate(tmp, adjustTime[0], adjustTime[1]);\r\n\t\t\t}\t\r\n\t\t}\r\n\t\t\r\n\t    ids = ids.substring(0, ids.length - 1).split(\",\");\r\n\t    var $s = this,\r\n\t    item = $s.getItem(ids[0]);\r\n\t    max = eval(\"$s.uidItems.\" + ids[ids.length - 1]);\r\n\t    var arr, pad = $s.interval,\r\n\t    pos, pre, nxt, parent, len = $s.items.length,\r\n\t    canUp, refresh = false,\r\n\t    needSave = false;\r\n\t    if (this.config.o && item.p / pad <= 1) {\r\n\t        return;\r\n\t    }\r\n\t    if ($s.isArmy && $s.myGanttCount != 0 && item.p / pad <= $s.myGanttCount) {\r\n\t        return;\r\n\t    }\r\n\t    for (var i = 0; i < ids.length; i++) {\r\n\t        if ($s._checkLockTask($s.getItem(ids[i]))) {\r\n\t            getIMessage().init($(\"#op_gantt_msg16\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t    }\r\n\t    while (item && item.pos <= max) {\r\n\t        pos = item.pos;\r\n\t        nxt = pos < len - 1 ? $s.items[++pos] : null;\r\n\t        canUp = true;\r\n\t        arr = [item];\r\n\t        if (item.p > 0) {\r\n\t            while (canUp && nxt && nxt.p >= item.p) {\r\n\t                if (pos > max && nxt.p == item.p) {\r\n\t                    canUp = false;\r\n\t                } else {\r\n\t                    arr.push(nxt);\r\n\t                    nxt = $s.items[++pos];\r\n\t                    if (nxt) {\r\n\t                        nxt.pos = pos;\r\n\t                    }\r\n\t                }\r\n\t            }\r\n\t            if (item.n == \"Y\") {\r\n\t                if (nxt && nxt.p >= item.p) {\r\n\t                    item.s = 1;\r\n\t                }\r\n\t                canUp = true;\r\n\t            }\r\n\t            if (canUp) {\r\n\t                for (var i = 0; i < arr.length; i++) {\r\n\t                    arr[i].p = arr[i].p - pad;\r\n\t                    pre = $s.items[arr[i].pos - 1];\r\n\t                    if (pre.n == \"Y\" || this._checkSimulateNode(pre)) {\r\n\t                        if (pre.p == arr[i].p) {\r\n\t                            pre.s = 0;\r\n\t                        } else {\r\n\t                            if (pre.p == 0) {\r\n\t                                pre.s = 1;\r\n\t                                refresh = true;\r\n\t                            }\r\n\t                        }\r\n\t                    }\r\n\t                }\r\n\t                needSave = true;\r\n\t            }\r\n\t        }\r\n\t        item = nxt;\r\n\t        if (item) {\r\n\t            item.pos = pos;\r\n\t        }\r\n\t    }\r\n\t    if (refresh) {\r\n\t        $s._initItemsMap();\r\n\t    }\r\n\t    $s._updateNodeDate();\r\n\t    if (needSave) {\r\n\t        $s._activeSave();\r\n\t\t\tisChangeNode = \"Y\";\r\n\t    }\r\n\t};\r\n\t\r\n\tGantt.prototype.updateDownItem = function(ids) {\r\n\t\t\r\n\t    if (!ids) {\r\n\t        return;\r\n\t    }\r\n\t\t\r\n\t\t/* 降级时,确保任务时间在  节点要求时间内 */\r\n\t\tvar idArr = ids.split(\",\"), $s = this;\r\n\t\tfor(var i=0; i<idArr.length -1; i++) {\r\n\t\t\tvar tmp = $s.getItem(idArr[i]);\r\n\t\t\tif(!$s.cacheArr) {\r\n\t\t\t\t$s.cacheArr = [];\r\n\t\t\t}\r\n\t\t\tvar adjustTime = $s._isRequestedTime($s,tmp,0,0,\"down\");\r\n\t\t\tif(adjustTime[0] != 0 || adjustTime[1] != 0) {\r\n\t\t\t\tgetIMessage().init(adjustTime[2],1); \r\n\t\t\t\treturn;\r\n\t\t\t}\r\n\t\t\t/*$s._changeItemDate(tmp, adjustTime[0], adjustTime[1]);*/\r\n\t\t}\r\n\t\t\r\n\t    ids = ids.substring(0, ids.length - 1).split(\",\");\r\n\t    var $s = this,\r\n\t    item = $s.getItem(ids[0]);\r\n\t    max = eval(\"$s.uidItems.\" + ids[ids.length - 1]);\r\n\t    var pad, pos, pre, nxt, parent, len = $s.items.length,\r\n\t    refresh = false,\r\n\t    needSave = false;\r\n\t    for (var i = 0; i < ids.length; i++) {\r\n\t        if ($s._checkLockTask($s.getItem(ids[i]))) {\r\n\t            getIMessage().init($(\"#op_gantt_msg16\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t    }\r\n\t    var chg = [];\r\n\t    while (item && item.pos <= max) {\r\n\t        pad = $s._canDown(item) ? $s.interval: 0;\r\n\t        if (!needSave) {\r\n\t            needSave = pad > 0;\r\n\t        }\r\n\t        pos = item.pos;\r\n\t        nxt = pos < len - 1 ? $s.items[++pos] : null;\r\n\t        chg = [];\r\n\t        if (pad > 0 && nxt) {\r\n\t            while (nxt && item.p < nxt.p) {\r\n\t                nxt.p = nxt.p + pad;\r\n\t                if ($s._compareParentDay(nxt.u, nxt.c.PlanEndDate.t)) {\r\n\t                    nxt.p -= pad;\r\n\t                    getIMessage().init($(\"#op_gantt_msg15\").html(), 1);\r\n\t                    return false;\r\n\t                }\r\n\t                chg.push(nxt);\r\n\t                nxt = $s.items[++pos];\r\n\t            }\r\n\t        }\r\n\t        if (item.pos > 0) {\r\n\t            pre = $s.items[item.pos - 1];\r\n\t            pre.s = ((pre.n == \"Y\" || $s.isArmy) && pre.p == item.p) ? 1 : pre.s;\r\n\t        }\r\n\t        item.p = item.p + pad;\r\n\t        if ($s._compareParentDay(item.u, item.c.PlanEndDate.t)) {\r\n\t            item.p -= pad;\r\n\t            if (pre.s == 1) {\r\n\t                pre.s = 0;\r\n\t            }\r\n\t            for (var i = 0; i < chg.length; i++) {\r\n\t                chg[i].p -= pad;\r\n\t            }\r\n\t            getIMessage().init($(\"#op_gantt_msg15\").html(), 1);\r\n\t            return false;\r\n\t        }\r\n\t        parent = $s.getItem($s._getParent(item.u));\r\n\t        if (parent && parent.s == -1) {\r\n\t            parent.s = 1;\r\n\t            refresh = true;\r\n\t        }\r\n\t        item = nxt;\r\n\t        if (item) {\r\n\t            item.pos = pos;\r\n\t        }\r\n\t    }\r\n\t    if (refresh) {\r\n\t        $s._initItemsMap();\r\n\t    }\r\n\t    $s._updateNodeDate();\r\n\t    if (needSave) {\r\n\t        $s._activeSave();\r\n\t\t\tisChangeNode = \"Y\";\r\n\t    }\r\n\t};\r\n\t\r\n\tfunction dynSaveTask(callBack, sync, refresh, srcId, srcType) {\r\n\t    openLoader();\r\n\t    $table.ganttTable(\"selectRow\", {\r\n\t        col: -1\r\n\t    });\r\n\t    try {\r\n\t        if ($(\"#saveButton\").attr(\"disabled\") || GANTT_ISCUSTOM) {\r\n\t            closeLoader();\r\n\t            if (callBack) {\r\n\t                callBack();\r\n\t            }\r\n\t            return false;\r\n\t        }\r\n\t    } catch (e) {\r\n\t        return false;\r\n\t    }\r\n\t    taskGantt.updateSaveItems();\r\n\t    var items = taskGantt.items, _item, tmp = [];\r\n\t    copyTmp = [];\r\n\t    for (var i = 0; i < items.length; i++) {\r\n\t        _item = items[i];\r\n\t        if (_item.m != 1) {\r\n\t            continue;\r\n\t        }\r\n\t        if (taskGantt.isArmy && _item.sim == 1) {\r\n\t            continue;\r\n\t        }\r\n\t        if (taskGantt.config.o && _item.u == \"u1\") {\r\n\t            continue;\r\n\t        }\r\n\t        if (_item.y != \"\") {\r\n\t            copyTmp.push(_item);\r\n\t        } else {\r\n\t            tmp.push(_item);\r\n\t        }\r\n\t    }\r\n\t    var async = sync ? false : true\r\n\t      , isSuccess = true;\r\n\t    jtaskEntityBean.dynSaveTask(JSON.stringify(tmp), JSON.stringify(copyTmp), taskGantt.config.m, taskGantt.config.p, srcId ? srcId : \"\", srcType ? srcType : \"\", {\r\n\t        async: async,\r\n\t        callback: function(r) {\r\n\t            if (r) {\r\n\t                r = eval(\"(\" + r + \")\");\r\n\t                if (r.msg) {\r\n\t                    iOperation._showAopWarnMsg(r.msg);\r\n\t                    isSuccess = false;\r\n\t                }\r\n\t                if (r.ui) {\r\n\t                    var item = r.ui.split(\",\"), arr, _item;\r\n\t                    for (var i = 0; i < item.length; i++) {\r\n\t                        arr = item[i].split(\"=\");\r\n\t                        _item = taskGantt.getItem(arr[0]);\r\n\t                        _item.i = arr[1];\r\n\t                        _item.m = 0;\r\n\t                        _item.y = \"\";\r\n\t                    }\r\n\t                }\r\n\t            }\r\n\t            $(\"#saveButton\").attr(\"disabled\", true);\r\n\t            setPageInfoChanged(false);\r\n\t            try {\r\n\t                if (!GANTT_ISCUSTOM) {\r\n\t                    dynSaveView();\r\n\t                }\r\n\t            } catch (e) {}\r\n\t            if (refresh) {\r\n\t                $graph.ganttGraph(\"refreshData\", iMain.getEvt(), false);\r\n\t            }\r\n\t            closeLoader();\r\n\t            if (srcId && srcType) {\r\n\t                if ($(\"#updateNode\\\\:tranTo\").size() > 0) {\r\n\t                    if (checkIsLifecycle(srcType)) {\r\n\t                        _transition_post($(\"#transitionName\").val());\r\n\t                    } else {\r\n\t                        $(\"#updateNode\\\\:tranTo\").click();\r\n\t                    }\r\n\t                }\r\n\t            }\r\n\t            if (callBack) {\r\n\t                callBack();\r\n\t            } else {\r\n\t                if (isSuccess) {\r\n\t                    getIMessage().init(top.$(\"#tskHint61\").html());\r\n\t\t\t\t\t\tisChangeNode = \"N\";\r\n\t\t\t\t\t\t/* 保存节点关联关系至数据库 */\r\n\t\t\t\t\t\tsaveNodeRelate();\