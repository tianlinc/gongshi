            "compression": 0,
            "text": "function controlKeyInput(obj,reg){\r\n  \twhile(reg.test(obj.value)){\r\n   \t\tobj.value=obj.value.replace(reg,'');\r\n  \t}\r\n}\r\n\r\nfunction Trim(ui){ \r\n\tvar notValid=/(^\\s)|(\\s$)/; \r\n\twhile(notValid.test(ui))\r\n\t{ \r\n\t\tui=ui.replace(notValid,\"\");\r\n\t} \r\n\treturn ui;\r\n} \r\n\r\nfunction getStringLength(str){\r\n\tvar defaultLength = 2;\r\n\ttry {\r\n\t\tdefaultLength = parseInt((defaultCharLength && defaultCharLength != '' && defaultCharLength > 1) ? defaultCharLength : 2);\r\n\t} catch(e) {\r\n\t\tdefaultLength = 2;\r\n\t}\r\n    var sLen =0;\r\n    if (str && str.length) {\r\n\t    for (i=0;i<str.length;i++){\r\n\t       if (str.charCodeAt(i)>255 || str.charCodeAt(i) == 183){\r\n\t\t      sLen+=defaultLength;\r\n\t\t   }else{\r\n\t\t    sLen++;\r\n\t\t   }\r\n\t    }\r\n    }\r\n\treturn sLen;\r\n}\r\n\r\nfunction hiddenMsgSpan(objSign,num){\r\n  \tif(num<0){\r\n  \t\treturn;\r\n  \t}\r\n  \tfor(var i=0;i<=num;i++){\r\n  \t\t//var obj = document.getElementById(objSign+i);\r\n  \t\t//if(obj){\r\n  \t\t//\tobj.style.display = \"none\";\r\n  \t\t//}\r\n\t  \tif($('#'+objSign+i).size() > 0){\r\n\t  \t\t$('#'+objSign+i).hide();\r\n\t  \t}\r\n  \t}\r\n}\r\n\r\nfunction isEmail(sEmail){\r\n\tvar regu =\r\n\t\t\t\"^(([0-9a-zA-Z]+)|([0-9a-zA-Z]+[_.0-9a-zA-Z-]*[0-9a-zA-Z]+))@([a-zA-Z0-9-]+[.])+([a-zA-Z]+)$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = sEmail.match(re);\r\n\tif (r==sEmail)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isNumber(numberStr){\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction toDecimal(val, digit) {\r\n\tvar t = parseFloat(val);\r\n\t\r\n\tif (isNaN(t)) return 0;\r\n\t\r\n\tdigit = digit ? digit : 1;\r\n\t\r\n\treturn Math.round(t * 10 * digit)/(10 * digit)\r\n}\r\n\r\nfunction isFloat(numberStr)\t{\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^([0-9]*)(\\\\.)?[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isAllFloat(numberStr)\t{\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^(-?[0-9]*)(\\\\.)?[0-9]*$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction isInteger(numberStr){\r\n    tempStr=Trim(numberStr);\r\n\tvar regu =\"^-?\\\\d+$\";\r\n\tvar re = new RegExp(regu, \"g\");\r\n\tvar r = tempStr.match(re);\r\n\tif (r==tempStr)\r\n\t{\r\n\t\treturn true;\r\n\t}\r\n\treturn false;\r\n}\r\n\r\nfunction ascllToGBK(codeStr){\r\n\tif(codeStr!=null&&codeStr!=''){\r\n\t\tif(codeStr.substr(0,1)==\"#\"){\r\n\t\t\treturn String.fromCharCode(codeStr.substr(1,6));\r\n\t\t}\r\n\t\treturn codeStr;\r\n\t}\r\n\treturn \"\";\r\n}\r\n\r\nfunction printValue(val0,val1,val2){\r\n\tif(val0=='Y'){\r\n\t\tdocument.write(val1);\r\n\t\treturn;\r\n\t}\r\n\tif(val0=='N'){\r\n\t\tdocument.write(val2);\r\n\t\treturn;\r\n\t}\r\n\tdocument.write(\"\");\r\n}\r\n\r\nfunction searchData(idObj,nameObj,url,isDefault,rtnValResolver){\r\n\tif(url == null || url == \"\") return;\r\n\t\t\r\n\tif(isDefault == null || isDefault){\t\r\n\t\tif (idObj.value && idObj.value.length <= 36) {\r\n\t\t\tif(url.indexOf(\"?\")>=0){\r\n\t\t\t\turl = url + \"&objectIds=\"+idObj.value;\r\n\t\t\t}else{\r\n\t\t\t\turl = url + \"?objectIds=\"+idObj.value;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj.value;  \r\n    dialogArgument[1] = nameObj.value;\r\n    \r\n    var h = (url.indexOf(\"searchUser\") >= 0\r\n    \t\t|| url.indexOf(\"searchProject\") >= 0\r\n    \t\t|| url.indexOf(\"searchProduct\") >= 0\r\n    \t\t|| url.indexOf(\"searchDepart\") >= 0) ? 510 : 430;\r\n     \r\n    showModDialog(url, 600, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        \r\n        if(msg!=null){\r\n\t\t   if(msg==''){\r\n\t\t\t  idObj.value = '';\r\n\t\t\t  nameObj.value = '';\r\n\t\t   }else{\r\n\t\t\t  var array = msg.split(\"%&*%\");\r\n\t\t\t  idObj.value = array[0];\r\n\t\t\t  nameObj.value = escapeHTML(array[1]);\r\n\t\t   }\r\n\t\t   rtnVal='Y';\r\n\t    }\r\n\t    if(typeof rtnValResolver == 'function'){\r\n\t       rtnValResolver(rtnVal);\r\n\t    }\r\n    });\t\r\n\t\r\n\treturn;\t\t\r\n}\r\n\r\nfunction filterData(idObj,nameObj,url,w,h,isDefault,rtnValResolver) {\r\n\tif(url == null || url == \"\") return;\r\n\t\t\r\n\tif(isDefault == null || isDefault){\t\r\n\t\tif (idObj.value && idObj.value.length <= 36) {\r\n\t\t\tif(url.indexOf(\"?\")>=0){\r\n\t\t\t\turl = url + \"&objectIds=\"+idObj.value;\r\n\t\t\t}else{\r\n\t\t\t\turl = url + \"?objectIds=\"+idObj.value;\r\n\t\t\t}\r\n\t\t}\r\n\t}\r\n    var dialogArgument = new Array();\r\n    dialogArgument[0] = idObj.value;  \r\n    dialogArgument[1] = nameObj.value;\r\n     \r\n    showModDialog(url, w, h, dialogArgument, function(msg) {\r\n        var rtnVal='N';\r\n        if(msg!=null){\r\n\t\t   if(msg==''){\r\n\t\t\t  idObj.value = '';\r\n\t\t\t  nameObj.value = '';\r\n\t\t   }else{\r\n\t\t\t  var array = msg.split(\"%&*%\");\r\n\t\t\t  idObj.value = array[0];\r\n\t\t\t  nameObj.value = escapeHTML(array[1]);\r\n\t\t   }\r\n\t\t   rtnVal='Y';\r\n\t    }\r\n\t    if(typeof rtnValResolver == 'function'){\r\n\t       rtnValResolver(rtnVal);\r\n\t    }\r\n    });\t\r\n\t\r\n\treturn;\t\t\r\n}\r\n\r\nfunction searchBelong($inp, callback, param) {\r\n\tvar scope = $inp.attr(\"scope\"), mul = $inp.attr(\"mul\"), projectType = $inp.attr(\"projectType\");\r\n\t\r\n\tvar url = powerPath + \"pages/common/searchBelong\" + ((mul && mul == \"Y\") ? \"Mul\" : \"\") + \"Win.jsf?scope=\" + (scope ? scope : \"\") + (projectType ? \"&type=\" + projectType : \"\");\r\n\t\r\n\t// add project id or product id or is relate