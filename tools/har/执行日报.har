tData\",[projectId], downloadExcel, false);\r\n\t\tisClick = 1;\r\n\t}\r\n\t\r\n\tfunction downloadExcel(d){\r\n\t\tcloseLoader();\r\n\t\tif (d) {\r\n\t\t\tappendDownForm();\r\n\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\tinspur_sendDownRequest(d);\r\n\t\t} else {\r\n\t\t\trdmAlert(\"导出失败！\");\r\n\t\t}\r\n\t}\r\n\t\r\n\tfunction appendDownForm () {\r\n\t\tvar $form = \"\";\r\n\t\tvar $userInfo = $(\"div#roleDiv\");\r\n\t\t$form += \"<form id='inspur_file_downform' method='post' target='_top'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_dir' name='dir'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_name' name='fileName'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_address' name='address'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_extname' name='fileExtName'></form>\";\r\n\t\tif($userInfo && $userInfo.length > 0){\r\n\t\t\t$userInfo.append($form);\r\n\t\t}\t\r\n\t}\r\n\t\r\n\tfunction inspur_sendDownRequest(r) {\r\n\t\tstopClear(3);\r\n\r\n\t\ttry {\r\n\t\t\tparent.setClear();\r\n\t\t} catch (e) {\r\n\t\t}\r\n\r\n\t\tif (r.length == 1 && r[0] == \"N\") {\r\n\t\t\trdmAlert($(\"#hisense_fileNotExistMsg\").html());\r\n\t\t} else {\r\n\t\t\tr[0] = \"10.111.36.3\";\r\n\t\t\tr[1] = \"2029\";\r\n\t\t\t\r\n\t\t\t$(\"#inspur_file_dir\").val(r[2]);\r\n\t\t\t$(\"#inspur_file_address\").val(r[3]);\r\n\t\t\t$(\"#inspur_file_name\").val(r[4]);\r\n\t\t\t$(\"#inspur_file_extname\").val(r[5]);\r\n\r\n\t\t\tif ($.browser.safari) { $(\"#inspur_file_downform\").attr(\"target\", \"\"); }\r\n\r\n\t\t\tvar servlet;\r\n\t\t\tif (r[0]) {\r\n\t\t\t\tservlet = \"http://\" + r[0] + \":\" + r[1] + \"/download\";\r\n\t\t\t} else {\r\n\t\t\t\tservlet = powerPath + \"download\";\r\n\t\t\t}\r\n\r\n\t\t\t$(\"#inspur_file_downform\").attr(\"action\", servlet).submit();\r\n\t\t}\r\n\t}\r\n}\r\n\r\nfunction isManager(prjectId) {\r\n\tvar isManager = \"N\";\r\n\t\r\n\tsynAjax.tabCall(\"com.bronzesoft.inspur.project.member.ProjectMember\",\"isManager\",[prjectId],function(msg) {\r\n\t\tif(msg.trim()) {\r\n\t\t\tisManager = msg.trim();\r\n\t\t}\r\n\t});\t\r\n\t\r\n\treturn isManager;\r\n\t\r\n}\r\n\r\nfunction afterIssue(closeWin, d){\r\n\tif(\"Y\" == d){\r\n\t\tgetIMessage().init(\"新建成功\" , 0);\r\n\t} else {\r\n\t\tgetIMessage().init(\"新建失败\" , 1);\r\n\t}\r\n\tcloseWin();\r\n\trefresh();\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/rdsys/departmentList.jsf\") >= 0) {\r\n\tvar menu = $(\"#menuBar\")[0].innerHTML;\r\n\tvar d = [];\r\n\td.push(menu);\r\n\td.push(\"<input type='button' class='button' onclick='importData(\\\"change\\\");' title='按旧部门,新部门,的格式将Excel文件导入部门表,文件只支持两列，请严格规范格式！' value='修改部门名称'>\");\r\n\td.push(\"<input type='button' class='button' onclick='importData(\\\"add\\\");' title='按部门,一级,二级,...,的格式将Excel文件导入部门表及部门关系表' value='导入新部门'>\");\r\n\td.push(\"<input type='button' class='button' onclick='updateNum();' title='按照rdm编码规则更新部门编号' value='更新部门编号'>\");\r\n\td.push(\"<input type='button' class='button' onclick='updateOrg();' title='同步人力系统部门并更新部门编号' value='同步部门'>\");\r\n\t$(\"#menuBar\").html(d.join(\"\"));\r\n\tvar userId = $(\".rdm-user\").attr(\"id\");\r\n\t\r\n\tfunction importData(f){\r\n\t\tvar url = powerPath + \"pages/attachment/importFileDialog.jsf\";  \r\n\t\tshowModDialog(url, 400, 150,[], function(msg) {\r\n\t\t\tmsg = msg.replace(/\\\\/g,\"/\");// msg 返回的是 文件路径,文件格式\r\n\t\t\topenLoader();\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.tab.departmentConfig.ImportData\", \"readExcel\", [msg,userId,f],function (d) {\t\t\t\t\t\t\r\n\t\t\t\tswitch (d) {\r\n\t\t\t\tcase \"NoData\":\r\n\t\t\t\t\trdmAlert('文件中无数据!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"Error\":\r\n\t\t\t\t\trdmAlert('导入文件格式不匹配,请选择正确的文件导入!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"NN\":\r\n\t\t\t\t\trdmAlert('部门表和部门关系表导入失败!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"dptN\":\r\n\t\t\t\t\trdmAlert('部门表导入成功,部门关系表导入失败!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"Nupdpt\":\r\n\t\t\t\t\trdmAlert('部门表导入失败,部门关系表导入成功!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"dptupdpt\":\r\n\t\t\t\t\trdmAlert('部门表和部门关系表导入成功!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tcase \"Y\":\r\n\t\t\t\t\trdmAlert('修改部门名称成功!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\tdefault:\r\n\t\t\t\t\trdmAlert('文件读取失败!');\r\n\t\t\t\t\tbreak;\r\n\t\t\t\t}\t\r\n\t\t\t\tcloseLoader();\r\n\t\t\t\twindow.location.reload();\r\n\t\t\t});\r\n\t\t}); \r\n\t}\r\n\t\r\n\tfunction updateNum(){\r\n\t\t//labelWindow(\"com.bronzesoft.inspur.tab.departmentConfig.importData\", \"getUpdateLabelWindow\", [],330,130,[window, afterSave, \"\", true]);\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.tab.departmentConfig.ImportData\", \"getUpdateLabelWindow\", [],function (d) {\t\t\t\t\t\t\r\n\t\t\tvar level = d;\r\n\t\t\tvar lvl=prompt(\"部门最大层级\",level);\r\n\t\t\tif(lvl){\r\n\t\t\t\topenLoader();\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.tab.departmentConfig.ImportData\", \"updateMax_level\", [lvl],function (d) {\t\t\t\t\t\t\r\n\t\t\t\t\trdmAlert(d);\r\n\t\t\t\t\tcloseLoader();\r\n\t\t\t\t\twindow.location.reload();\r\n\t\t\t\t});\r\n\t\t\t} else \r\n\t\t\t\trdmAlert(\"最大层级不能为空\");\r\n\t\t});\r\n\t\t\r\n\t}\r\n\t\tfunction updateOrg(){\r\n\t\t\topenLoader();\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.timer.UserManageGetUserTimer\", \"listOrgInfo\", [],function (d) {\t\t\t\t\t\t\r\n\t\t\t\trdmAlert(d);\r\n\t\t\t\tcloseLoader();\r\n\t\t\t\twindow.location.reload();\r\n\t\t\t});\r\n\t\t\r\n\t}\r\n\t/*function labelWindow(g, a, d, b, j, h, c, f, k) {\r\n\t    if (!d) {\r\n\t        d = [];\r\n\t    } else {\r\n\t        for (var e = 0; e < d.length; e++) {\r\n\t            if (!d[e] || d[e] == \"undefined\") {\r\n\t                d[e] = \"\";\r\n\t            }\r\n\t        }\r\n\t    }\r\n\t    window.top.createWindow(\"\", [window, g, a, d], b, j, h, c, f, k);\r\n\t}*/\r\n}\r\n\r\n\r\n/**\r\n * 项目内固定角色信息，不再允许用户自定义角色\r\n */\r\n\r\nif(custom_url.indexOf(\"/pages/security/roleGroupDialog.jsf?pageType=\") > -1) {\r\n\tvar type = custom_url.substr(custom_url.indexOf(\"pageType=\") + 9, 3);\r\n\tvar projectId = custom_url.substr(custom_url.indexOf(\"objectId=\") + 9, 36);\r\n\tvar roleId = custom_url.substr(custom_url.indexOf(\"roleId=\") + 7, 36);\r\n\t\r\n\tcustom_labelCall(\"com.bronzesoft.inspur.project.approval.ProjectApproval\", \"getPjtRole\", [projectId, roleId], function (d) {\r\n\t\tdebugger;\r\n\t\tvar data = JSON.parse(unescape(d));\r\n\t\tvar h = [];\r\n\t\th.push(\"<select id='roleName' name='roleName' class='input_require dialogInputText' style='width:97.7%;' required='true' maxlength='32'>\");\r\n\t\th.push(\"<option ids='' value='' class='menu-li-empty'>请选择</option>\");\r\n\t\tfor (var i = 0; i < data.length; i++) {\r\n\t\t\tif (type==\"edi\" && data[i][0]==\"Y\") {\r\n\t\t\t\th.push(\"<option value='\", data[i][1],\"' selected>\", data[i][1],\"</option>\");\r\n\t\t\t} else {\r\n\t\t\t\th.push(\"<option value='\", data[i][1],\"' >\", data[i][1],\"</option>\");\r\n\t\t\t}\r\n\t\t}\r\n\t\th.push(\"</select>\");\r\n\t\t\r\n\t\t$(\"#roleName\").replaceWith(h.join(\"\"));\r\n\t});\r\n}\r\n\r\n/*项目管理—-》建项管理——》项目组成员*/\r\nif (custom_url.indexOf(\"/pages/workflow/entity.jsf?objectId=\") > -1) {\r\n\tinitScript([ powerPath + \"scripts/workflow/entity.js\"]);\r\n\tinitScript([ powerPath + \"scripts/plugin/bronzesoft.ui.tabs.js\"]);\r\n\tinitScript([ powerPath + \"scripts/utils/iMain.js\"]);\r\n\r\n\t/* 从url中获取projectId */\r\n\tvar projectId = custom_url.substr(custom_url.indexOf(\"objectId=\") + 9, 36);\r\n\r\n\t$(\"#addProjectTeamMember\").after(\"<input id='exportprojectMemberModel' type='button' class='button' style='margin-bottom:5px;margin-left:15px;' onclick='exportprojectMemberModels(projectId)' value='导出项目组成员模板'>\");\t\r\n\t$(\"#exportprojectMemberModel\").after(\"<input id='importExcel' type='button' class='button' style='margin-bottom:5px;margin-left:15px;' onclick='importFromExcel();' value='导入项目组成员'>\");\t\r\n\t$(\"#addProjectTeamMember\").remove();\r\n\t\r\n\tfunction importFromExcel() {\r\n\t\tvar url = powerPath + \"pages/attachment/importFileDialog.jsf\";  \r\n\t\tshowModDialog(url, 400, 150,[], function(msg) {\r\n\t\t\tmsg = msg.replace(/\\\\/g,\"/\");\r\n\t\t\t/* msg 返回的是 文件路径,文件格式  */ \r\n\t\t\tlabelCall(\"com.bronzesoft.inspur.project.approval.ProjectApproval\", \"readExcel\", [msg],function (d) {\r\n\t\t\t\tvar data = JSON.parse(unescape(d));\r\n\t\t\t\tif(data.emailError == 'emailError') {\r\n\t\t\t\t\trdmAlert(data.errorMsg.replace(/\\n/g,\"<br/>\"));\r\n\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t\tif (data.msg == 'success') {\r\n\t\t\t\t\t\r\n\t\t\t\t\tvar projectMembers = JSON.parse(data.data);\r\n\t\t\t\t\t/*遍历每一行*/\r\n\t\t\t\t\tvar data = [];\r\n\t\t\t\t\tfor(var i=0;i<projectMembers.length;i++){\r\n\t\t\t\t\t\tvar d = {};\r\n\t\t\t\t\t\tvar one = projectMembers[i];\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\tvar userId = one.userId\t;\r\n\t\t\t\t\t\tvar memberName = one.memberName;\r\n\t\t\t\t\t\tvar roleName = one.roleName;\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\td.userId = userId;\r\n\t\t\t\t\t\td.memberName = memberName;\r\n\t\t\t\t\t\td.roleName = roleName;\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\tdata.push(d);\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t}\r\n\t\t\t\t\t\r\n\t\t\t\t\t/* 遍历$(\"#member-tab\")中的角色一列，跟roleName进行对应，如果能对应上，则在该行对应的\"人员\"一列上赋上值 */\r\n\t\t\t\t\tfor (var i = 1; i < $(\"#member-tab tr\").length; i++) {\r\n\t\t\t\t\t\tvar $tr = $(\"#member-tab tr:eq(\"+i+\")\");\r\n\t\t\t\t\t\tvar roleNameFromPage = $tr.find(\"td:eq(1)\").find(\"label\").html();\r\n\t\t\t\t\t\t\r\n\t\t\t\t\t\tvar memberNames = [];\r\n\t\t\t\t\t\tvar userIds = [];\r\n\t\t\t\t\t\tfor (var j = 0; j < data.length; j++) {\r\n\t\t\t\t\t\t \tvar roleNameFromExcel = data[j].roleName;\r\n\t\t\t\t\t\t \t\r\n\t\t\t\t\t\t \tif (roleNameFromPage == roleNameFromExcel) {\r\n\t\t\t\t\t\t \t\tmemberNames.push(data[j].memberName);\r\n\t\t\t\t\t\t \t\t\r\n\t\t\t\t\t\t \t\tuserIds.push(data[j].userId);\r\n\t\t\t\t\t\t \t\t\r\n\t\t\t\t\t\t \t\t$tr.find(\"td:eq(2)\").find(\"input\").attr(\"value\",memberNames);\r\n\t\t\t\t\t\t\t \t$tr.find(\"td:eq(2)\").find(\"input\").attr(\"ids\",userIds);\r\n\t\t\t\t\t\t\t \t\r\n\t\t\t\t\t\t\t\t$(\"#PjtStaffID\"+(i+1)).val(userIds);\r\n\t\t\t\t\t\t \t}\r\n\t\t\t\t\t\t}\r\n\t\t\t\t\t}\r\n\t\t\t\t\t\r\n\t\t\t\t} \r\n\t\t\t\tif (data.msg == 'NoData') {\r\n\t\t\t\t\trdmAlert('文件中无数据!');\r\n\t\t\t\t}  \r\n\t\t\t\tif (data.msg == 'formatError') {\r\n\t\t\t\t\trdmAlert('存在错误的邮箱格式！');\r\n\t\t\t\t} \r\n\t\t\t\t\r\n\t\t\t\t\t\r\n\t\t\t\t\r\n\t\t\t});\r\n\t\t  \r\n\t\t}); \r\n\t}\r\n\t\r\n\tfunction exportprojectMemberModels(projectId) {\r\n\t\t\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.project.approval.ProjectApproval\", \"exportToExcel\", [projectId], downloadExcel, false);\r\n\t\r\n\t}\r\n\r\n\tfunction downloadExcel(d){\r\n\t\tcloseLoader();\r\n\t\tif (d) {\r\n\t\t\tappendDownForm();\r\n\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\tinspur_sendDownRequest(d);\r\n\t\t} else {\r\n\t\t\trdmAlert(\"导出失败！\");\r\n\t\t}\r\n\t}\r\n\t\r\n\tfunction appendDownForm () {\r\n\t\tvar $form = \"\";\r\n\t\tvar $userInfo = $(\"div#projectMemberDiv\");\r\n\t\t$form += \"<form id='inspur_file_downform' method='post' target='_top'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_dir' name='dir'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_name' name='fileName'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_address' name='address'>\";\r\n\t\t$form += \"<input type='hidden' id='inspur_file_extname' name='fileExtName'></form>\";\r\n\t\tif($userInfo && $userInfo.length > 0){\r\n\t\t\t$userInfo.append($form);\r\n\t\t}\t\r\n\t}\r\n\t\r\n\tfunction inspur_sendDownRequest(r) {\r\n\t\tstopClear(3);\r\n\r\n\t\ttry {\r\n\t\t\tparent.setClear();\r\n\t\t} catch (e) {\r\n\t\t}\r\n\r\n\t\tif (r.length == 1 && r[0] == \"N\") {\r\n\t\t\trdmAlert($(\"#hisense_fileNotExistMsg\").html());\r\n\t\t} else {\r\n\t\t\tr[0] = \"10.111.36.3\";\r\n\t\t\tr[1] = \"2029\";\r\n\t\t\t\r\n\t\t\t$(\"#inspur_file_dir\").val(r[2]);\r\n\t\t\t$(\"#inspur_file_address\").val(r[3]);\r\n\t\t\t$(\"#inspur_file_name\").val(r[4]);\r\n\t\t\t$(\"#inspur_file_extname\").val(r[5]);\r\n\r\n\t\t\tif ($.browser.safari) { $(\"#inspur_file_downform\").attr(\"target\", \"\"); }\r\n\r\n\t\t\tvar servlet;\r\n\t\t\tif (r[0]) {\r\n\t\t\t\tservlet = \"http://\" + r[0] + \":\" + r[1] + \"/download\";\r\n\t\t\t} else {\r\n\t\t\t\tservlet = powerPath + \"download\";\r\n\t\t\t}\r\n\r\n\t\t\t$(\"#inspur_file_downform\").attr(\"action\", servlet).submit();\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/*里程碑发布，根据项目类型阶段进行屏蔽，只显示相对应的阶段*/\r\nif (custom_url.indexOf(\"/pages/lifecycle/entity/entityTab.project.jsf\") > -1) {\r\n\t/*var projectId = custom_url.substr(custom_url.indexOf(\"objectId=\") + 9, 36);\r\n\tcustom_labelCall(\"com.bronzesoft.inspur.project.milestone.ShowMileStone\", \"getProjectStage\", [projectId],function (d) {\r\n\t\tif (d == '7690592b-711b-4f0b-bd7f-e57bc3828d61') {\r\n\t\t\t//CDP\r\n\t\t\t$(\"li[val='PDT里程碑发布']\").remove();\r\n\t\t\t$(\"li[val='项目开发里程碑发布']\").remove();\r\n\t\t} else if (d == 'e816d3b3-47f6-43ea-be65-a2d2e524e471') {\r\n\t\t\t//PDT\r\n\t\t\t$(\"li[val='CDP里程碑发布']\").remove();\r\n\t\t\t$(\"li[val='项目开发里程碑发布']\").remove();\r\n\t\t} else if (d == '1e311614-a537-4797-845e-06429389e460') {\r\n\t\t\t//项目开发\r\n\t\t\t$(\"li[val='CDP里程碑发布']\").remove();\r\n\t\t\t$(\"li[val='PDT里程碑发布']\").remove();\r\n\t\t} \r\n\t\t\r\n\t}, true);*/\r\n}\r\n\r\n/*任务驳回之后，重新编辑提交，执行日期框不执行3天超期校验 */\r\nif(custom_url.indexOf(\"/pages/task/entity.jsf?taskId=\") >= 0 ) {\r\n\t\r\n\t/*查询出此task任务是否被驳回，以及此task任务的计划开始时间和计划结束时间*/\r\n\tvar taskId = custom_url.substr(custom_url.indexOf(\"taskId=\") + 7, 36);\r\n\tvar reject;\r\n\tvar planStartTime;\r\n\tvar planEndTime;\r\n\tvar data;\r\n\t\r\n\tcustom_labelCall(\"com.bronzesoft.inspur.task.TaskDateCheck\", \"reject\", [taskId],function (d) {\r\n\t\tdata = d;\r\n\t\treject = data.substr(0,1);\r\n\t\t\r\n\t}, true);\r\n\t\r\n\tif (reject == \"Y\") {\r\n\t\tplanStartTime = data.substr(1,10);\r\n\t\tplanEndTime = data.substr(11,10);\r\n\t\t\r\n\t\tfunction taskReport_checkDay() {\r\n\t\t    openLoader();\r\n\t\t    var e = $(\"li[field='report_action_date'] textarea\");\r\n\t\t    var f = taskReport_day;\r\n\t\t    var d = taskReport_dailyDays;\r\n\t\t    var b = taskReport_today;\r\n\t\t    var a = e.val();\r\n\t\t    var c = getDays(a, b);\r\n\t\t    /*\r\n\t\t    if (!(a >= planStartTime && a <= planEndTime)) {\r\n\t\t    \tgetIMessage().init(\"执行日期必须介于计划开始时间和计划结束时间之间\",1);\r\n\t\t    \te.val(planStartTime);\r\n          \t\ta = planStartTime;\r\n\t\t    }\r\n\t\t    */\r\n\t\t    taskReport_init(false, a);\r\n\t\t    closeLoader()\r\n\t\t}\r\n\t}\r\n}\r\n\r\n/* 项目移交，项目开发阶段信息下的项目实体类型字段数据回显*/   \r\nif(custom_url.indexOf(\"/pages/workflow/entity.jsf?isView=Y&objectId=\") >= 0) {\r\n\tif ($(\"li[field=Fld_00021]\").size() > 0) {\r\n\t\t/*查询出项目实体类型字段的name*/\r\n\t\tvar projectId = custom_url.substr(custom_url.indexOf(\"objectId=\") + 9, 36);\r\n\t\t\t\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.project.ProjectTypeConfigAop\",\"getProjectModelType\",[projectId],function(data) {\r\n\t\t\tif(data) {\r\n\t\t\t\t$(\"li[field=TypeID]\").find(\"div.field-content\").text(data);\r\n\t\t\t}\r\n\t\t\t\r\n\t\t}, true);\r\n\t}\r\n}\r\n\r\n/* 修改密码记录与校验*/   \r\nif(custom_url.indexOf(\"/passwordUpdate.jsf\") >= 0) {\r\n\t\r\n\t\t/*查询出项目实体类型字段的name*/\r\n\t\tvar s = $(\".menuBarItem2 input\").eq(0);\r\n\t\tvar password = '';\r\n\t\tif ($(\"#passwordForm\\\\:newPassword\")) {password = $(\"#passwordForm\\\\:newPassword\").val();}\r\n\t\tvar userId = $(\"#expireUserId\").val();\r\n\t\ts.removeAttr(\"onclick\");\r\n\t\ts.click(function(){\r\n\tif ($(\"#passwordForm\\\\:newPassword\")) {password = $(\"#passwordForm\\\\:newPassword\").val();}\r\n\t\r\n\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.userManager.UserMngController\",\"modifyPassword\",[password,userId],function(data) {\r\n\r\n\t\t\tvar daa=data;\r\n\t\t\tvar da111;\r\n\t\t\t\tif(data=='N') {\r\n\t\t\t\t\talert(\"密码不允许与最近三次密码相同\");\r\n\t\t\t\t\treturn;\r\n\t\t\t\t}\r\n\t\t\t\telse{\r\n\t\t\t\t\t\tupdatePassword();\r\n\t\t\t\t\t}\r\n\t\t\t\t\r\n\t\t\t}, true);\r\n\t\t})\r\n}\r\n\r\n/*人员信息调整记录，编辑用户信息时，记录下次最后一版的用户信息*/\r\nif (custom_url.indexOf(\"/pages/rdsys/user/userAdd.jsf?employeeId=\") > -1) {\r\n\t\r\n\t\r\n\tfunction saveUser(c, b) {\r\n\t\tif(valid) {\r\n\t\t\t$(\"#_sex\").val($(\"#sex0\").attr(\"checked\") ? \"0\" : \"1\");\r\n\t\t\tif($(\"#isEmployeeY\").attr(\"checked\")) {\r\n\t\t\t\t$(\"#_isEmployee\").val(\"Y\");\r\n\t\t\t\t$(\"input.inputText\", $(\".unEmployee\")).val(\"\");\r\n\t\t\t\tinitOtherInfo()\r\n\t\t\t} else {\r\n\t\t\t\t$(\"#_isEmployee\").val(\"N\");\r\n\t\t\t\t$(\"input.inputText\", $(\".employee\")).val(\"\")\r\n\t\t\t}\r\n\t\t}\r\n\t\tif(checkData()) {\r\n\t\t\tif(valid) {\r\n\t\t\t\tvar a = \"\";\r\n\t\t\t\t$(\"input:checkbox:checked\", $(\"#roleTab\")).each(function() {\r\n\t\t\t\t\ta += $(this).val() + \",\"\r\n\t\t\t\t});\r\n\t\t\t\t$(\"#_roleIds\").val(a);\r\n\t\t\t\tif(b) {\r\n\t\t\t\t\t$(\"#userForm\\\\:saveAgain\").click();\r\n\t\t\t\t} else {\r\n\t\t\t\t\t$(\"#userForm\\\\:\" + (c ? \"update\" : \"save\")).click();\r\n\t\t\t\t}\r\n\t\t\t} else {\r\n\t\t\t\t$(\"#_isValid\").val($(\"#isValidY\").attr(\"checked\") ? \"Y\" : \"N\");\r\n\t\t\t\t$(\"#userForm\\\\:change\").click()\r\n\t\t\t}\r\n\t\t}\r\n\t\t\r\n\t\tif (!$(\"#userForm\\\\:trueName\").val()) {\r\n\t\t\tisValid = $(\"#isValidY\").attr(\"checked\") ? \"Y\" : \"N\";\r\n\t\t\tusername = $(\"#userForm\\\\:name\").val();\r\n\t\t\tif(!username){username = '';}\r\n\t\t\tvar groupNum = $(\"#groupNumber\").val();\r\n\t\t\tvar workType = $(\"#workTypeSel\").val();\r\n\t\t\tvar personStatus = $(\"#personStatusSel\").val();\r\n\t\t\tvar productLine = $(\"#productLineSel\").val();\r\n\t\t\tvar isCadre = $(\"#isCadreSel\").val();\r\n\t\t\tvar flag=true;\t\t\r\n\t\t\t\t\tif(!groupNum) \t\t\t{$(\"#msg31\").show(); \t\t\t\t\tflag=false;}\r\n\t\t\t\t\tif(!workType)\t\t\t{$(\"#msg33\").show();\t\t\t\t\tflag=false;}\r\n\t\t\t\t\tif(!personStatus)\r\n\t\t\t{$(\"#msg34\").show();\t\t\t\t\tflag=false;}\r\n\t\t\t\t\tif(!productLine)\r\n\t\t\t{$(\"#msg35\").show();\r\n\t\t\t\t\tflag=false;}\r\n\t\t\t\t\tif(!isCadreSel)\r\n\t\t\t{$(\"#msg36\").show();\r\n\t\t\t\t\tflag=false;}\r\n\t\t\t\t\tif(!flag){\r\n\t\t\t\t\t\treturn false;\r\n\t\t\t\t\t\t}\r\n\t\t\t//保存用户自定义属性\r\n\t\t\tif(username){\r\n\t\t\t\tcustom_labelCall(\"com.bronzesoft.inspur.userManager.UserMngController\", \"saveOrUpdateUserCustomPer\", [username + \"拼接\" + isValid, groupNum, workType, personStatus, productLine,isCadre],function (d) {\r\n\t\t\t\t\t\r\n\t\t\t\t}, true);\r\n\t\t\t}\r\n\t\t\tcancleEdit();\r\n\t\t}  \r\n\t\t\r\n\t\t\r\n\t}\r\n\t\r\n\t\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/lifecycle/entity/list.jsf?type=PJT\") >= 0) {\r\n\t\tvar input = \"<input type='button' class='button' onclick='exportMilestone();' title='选择相应项目' value='里程碑统计' />\";\r\n\tinput += \"<input type='button' class='button' onclick='exportGantt();' value='分配置里程碑甘特图导出'/>\";\r\n\tif($(\".menuBarItem\")){\r\n\t\t$(\".menuBarItem\").find(\"input[value='报告生成']\").after(input);\r\n\t}\r\n\t\r\n\t// 隐藏项目管理 - 全隐藏\r\n\t$(\"#projectView\").hide();\r\n\t\r\n\tfunction exportMilestone(){\r\n\t\tbuildPage(\"exportMilestone\", powerPath + \"pages/lifecycle/entity/list.jsf?type=PJT&action=export&flag=milestone\");\r\n\t}\r\n\t\r\n\t\r\n\tfunction exportGantt(){\r\n\t\topenLoader();\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.project.ProjectMilestoneGantt\", \"exportGantt\", [], function(d) {\r\n\t\t\tif(d){\r\n\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t$(\"#operate\\\\:__path\").val(\"D:\\\\Bronzesoft\\\\RDM\\\\Application\\\\rdmapp\\\\power\\\\temp/\" + d.filePath);\r\n\t\t        $(\"#operate\\\\:__fileName\").val(d.fileName);\r\n\t\t        $(\"#operate\\\\:__contentType\").val(\"application/vnd.ms-excel\");\r\n\t\t        $(\".window-panel\", window.parent.document).css(\"z-index\", 19);\r\n\t\t        $(\"#operate\\\\:downloadProject\").click();\r\n\t\t        setTimeout(function() {\r\n\t\t        \tparent.clearPage(\"exportMilestone\");\r\n\t\t\t    }, 500);\r\n\t\t\t} else {\r\n\t\t\t\trdmAlert(\"表单生成失败!\");\r\n\t\t\t}\r\n\t\t\tcloseLoader();\r\n\t\t});\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/lifecycle/entity/list.jsf?type=PJT&action=export&flag=milestone\") >= 0) {\r\n\tdocument.writeln(\"<script type='text/javascript' src='/scripts/workflow/entity.js'></script>\");\r\n\tdocument.writeln(\"<style>.input_text{width: 70px;vertical-align: text-bottom;}</style>\");\r\n\t\r\n\tvar nowDate = new Date();\r\n\tvar fullYear = nowDate.getFullYear();\r\n\tvar month = nowDate.getMonth() + 1; // getMonth 方法返回 0-11，代表1-12月\r\n\tvar endOfMonth = new Date(fullYear, month, 0).getDate(); // 获取本月最后一天\r\n\tvar endDate = getFullDate(nowDate.setDate(endOfMonth));//当月最后一天\r\n\tvar startDate = getFullDate(nowDate.setDate(1));//当月第一天\r\n\t\r\n\tvar input = \"<input type='button' class='button' onclick='exportMilestoneDetails();' title='导出选择项目里程碑完成情况统计表单' value='导出' />\";\r\n\tvar cancel = \"<input type='button' class='button' onclick='parent.clearPage(\\\"exportMilestone\\\");' value='取消' />\";\r\n\tvar pdt_config = \"<input type='button' class='button' onclick='pdtConfig();' value='PDT配置' />\";\r\n\tvar time_config = \"<span style='margin-left: 10px;'>计划完成时间</span><input id='start_date' style='margin-left: 10px;' class='input_require inputText input_text' onclick='iCalendar.setDay($(this));' value='' readonly/> ~ <input id='end_date' class='input_require inputText input_text' onclick='iCalendar.setDay($(this));' value='' readonly/>\";\r\n\tvar real_time_config = \"<span style='margin-left: 10px;'>实际完成时间</span><input id='real_start_date' style='margin-left: 10px;' class='inputText input_text' onclick='iCalendar.setDay($(this));' value='' readonly/> ~ <input id='real_end_date' class='inputText input_text' onclick='iCalendar.setDay($(this));' value='' readonly/>\";\r\n\t\r\n\tif($(\".menuBarItem\")){\r\n\t\t$(\".menuBarItem\").find(\"input[value='下一步']\").remove();\r\n\t\t$(\".menuBarItem\").find(\"input[value='取消']\").before(input);\r\n\t\t\r\n\t\t$(\".menuBarItem\").find(\"input[value='取消']\").remove();\r\n\t\t$(\".menuBarItem\").find(\"input[value='新建']\").before(cancel);\r\n\t\t\r\n\t\t$(\".menuBarItem\").find(\"input[value='取消']\").after(pdt_config);\r\n\t\t\r\n\t\t$(\".menuBarItem\").find(\"input[value='PDT配置']\").after(time_config + real_time_config);\r\n\t}\r\n\t\r\n\tif($(\"#titleBar\")){\r\n\t\t$(\"#titleBar span\").remove();\r\n\t\t$(\"#titleBar div\").text(\"提示：所选项目将会导出项目里程碑完成情况明细单\");\r\n\t}\r\n\t\r\n\tfunction pdtConfig() {\r\n\t\tlabelWindow(\"com.bronzesoft.inspur.project.MilestoneStatistics\", \"initConfig\", [], 514, 375, [window, function (closeWin, d){\r\n\t\t\tif(\"N\" == d.trim()){\r\n\t\t\t\trdmAlert(\"PDT配置保存失败\");\r\n\t\t\t}else{\r\n\t\t\t\trdmAlert(\"PDT配置保存成功\");\r\n\t\t\t\tcloseWin();\r\n\t\t\t}\r\n\t\t}, \"\", true]);\r\n\t}\r\n\r\n\tfunction exportMilestoneDetails(){\r\n\t    var c = \"\";\r\n\t    for (var b in projectIdCache) {\r\n\t        var a = projectIdCache[b];\r\n\t        if (a != \"\") {\r\n\t            c += a + \",\"\r\n\t        }\r\n\t    }\r\n\t    \r\n\t    /*var st = $(\"#start_date\").val();\r\n\t    if (!st) {\r\n\t    \trdmAlert(\"起始日期不能为空!\");\r\n\t    \treturn;\r\n\t    }\r\n\t    \r\n\t    var et = $(\"#end_date\").val();\r\n\t    if (!et) {\r\n\t    \trdmAlert(\"截止日期不能为空!\");\r\n\t    \treturn;\r\n\t    }*/\r\n\t\t\r\n\t\tvar rs = $(\"#real_start_date\").val();\r\n\t    var re = $(\"#real_end_date\").val();\r\n\t    var st = $(\"#start_date\").val();\r\n\t    var et = $(\"#end_date\").val();\r\n\t    if (!rs && !re) {\r\n\t    \tif (!st) {\r\n\t    \t\trdmAlert(\"起始日期不能为空!\");\r\n\t    \t\treturn;\r\n\t    \t}\r\n\t    \t\r\n\t    \tif (!et) {\r\n\t    \t\trdmAlert(\"截止日期不能为空!\");\r\n\t    \t\treturn;\r\n\t    \t}\r\n\t    }\r\n\t\t\r\n\t\topenLoader();\r\n\t    labelCall(\"com.bronzesoft.inspur.project.MilestoneStatistics\", \"createForm\", [c, st, et, rs, re],function (d) {\r\n\t\t\tif(d){\r\n\t\t\t\td = eval(\"(\" + d + \")\");\r\n\t\t\t\t$(\"#operate\\\\:__path\").val(\"D:\\\\Bronzesoft\\\\RDM\\\\Application\\\\rdmapp\\\\power\\\\temp/\" + d.filePath);\r\n\t\t        $(\"#operate\\\\:__fileName\").val(d.fileName);\r\n\t\t        $(\"#operate\\\\:__contentType\").val(\"application/vnd.ms-excel\");\r\n\t\t        $(\".window-panel\",window.parent.document).css(\"z-index\", 19);\r\n\t\t        $(\"#operate\\\\:downloadProject\").click();\r\n\t\t        setTimeout(function() {\r\n\t\t        \tparent.clearPage(\"exportMilestone\");\r\n\t\t\t    }, 500);\r\n\t\t\t} else {\r\n\t\t\t\trdmAlert(\"表单生成失败!\");\r\n\t\t\t}\r\n\t\t\tcloseLoader();\r\n\t\t});\r\n\t}\r\n\t\r\n\t// 格式化日期格式为 xxxx-xx-xx\r\n\tfunction getFullDate(targetDate) {\r\n\t\tvar D, y, m, d;\r\n\t\tif (targetDate) {\r\n\t\t    D = new Date(targetDate);\r\n\t\t    y = D.getFullYear();\r\n\t\t    m = D.getMonth() + 1;\r\n\t\t    d = D.getDate();\r\n\t\t} else {\r\n\t\t    y = fullYear;\r\n\t\t    m = month;\r\n\t\t    d = date;\r\n\t\t}\r\n\t\tm = m > 9 ? m : '0' + m;\r\n\t\td = d > 9 ? d : '0' + d;\r\n\t\treturn y + '-' + m + '-' + d;\r\n\t};\r\n\t\r\n\tfunction labelCall(classKey, methodName, params, respHandler, isAsync) {\r\n\t\tvar o = {\r\n\t\t\t\"classKey\": classKey,\r\n\t\t\t\"methodName\": methodName,\r\n\t\t\t\"r\": Math.random(),\r\n\t\t\t\"params\": \"\"\r\n\t\t};\r\n\t\tvar p = \"{\";\r\n\t\tif(params && params.length > 0) {\r\n\t\t\tfor(var i = 0; i < params.length; i++) {\r\n\t\t\t\tp += \"\\\"p\" + i + \"\\\":\\\"\" + params[i] + \"\\\",\";\r\n\t\t\t}\r\n\r\n\t\t\tif(p && p.length > 1) {\r\n\t\t\t\tp = p.substring(0, p.length - 1) + \"}\";\r\n\t\t\t\to.params = p;\r\n\t\t\t}\r\n\t\t}\r\n\r\n\t\t$.ajax({\r\n\t\t\tasync: !isAsync,\r\n\t\t\turl: \"rdm.label\",\r\n\t\t\ttype: \"POST\",\r\n\t\t\tdata: o,\r\n\t\t\tdataType: \"html\",\r\n\t\t\tsuccess: function(html) {\r\n\t\t\t\trespHandler(html.trim());\r\n\t\t\t}\r\n\t\t});\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/entity/list.jsf?isGadget=Y&type=WF30\") >= 0) {\r\n\t/*\r\n\t * 更新bug数据\r\n\t * */\r\n\t$(function () {\r\n\t\tvar update = [];\r\n\t\tupdate.push(\"<input type='button' class='button' onclick='update_bug();' value='全量更新'>\");\r\n\t\tupdate.push(\"<input type='button' class='button' onclick='update_new_bug();' value='增量更新'>\");\r\n\t\tupdate.push(\"<input id='startDate' style='cursor: pointer;width: 100px;margin-left: 5px;margin-bottom: 5px;' class='inputText' onclick='iCalendar.setDay($(this));return false;' readonly='readonly' placeholder='更新时间(起始)'/>\");\r\n\t\tupdate.push(\"<input id='endDate' style='cursor: pointer;width: 100px;margin-left: 5px;margin-bottom: 5px;' class='inputText' onclick='iCalendar.setDay($(this));return false;' readonly='readonly' placeholder='更新时间(结束)'/>\");\r\n\t\tupdate.push(\"<select id='bugType' style='cursor: pointer;width: 100px;margin-left: 5px;margin-bottom: 5px;' class='inputText input_require' readonly='readonly' placeholder='选择类别'>\");\r\n\t\tupdate.push(\"<option value='CDL'>CDL</option>\");\r\n\t\tupdate.push(\"<option value='MANTIS'>MANTIS</option>\");\r\n\t\tupdate.push(\"<option value='JIRA'>JIRA</option>\");\r\n\t\tupdate.push(\"</select>\");\r\n\r\n\t\t\r\n\t\tvar loginUserId = $(\".rdm-user\", window.parent.parent.document).attr(\"id\");\r\n\t\t\r\n\t\tif($(\".menuBarItem\") && loginUserId == \"33ba99dc-dc20-4b4b-b398-9c5e78e5735f\"){\r\n\t\t\t$(\".menuBarItem\").find(\".button:last\").after(update.join(\"\"));\r\n\t\t}\r\n\t});\r\n\t\r\n\t/*\r\n\t * 按时间节点更新\r\n\t * t1:单独输入，按当前节点更新数据；\r\n\t * t2:与t1构成时间段，按时间段范围时间更新\r\n\t * */\r\n\tfunction update_new_bug(){\r\n\t\tvar t1 = $(\"#startDate\").val();\r\n\t\tvar t2 = $(\"#endDate\").val();\r\n\t\tvar type = $(\"#bugType\").val();\r\n\t\t\r\n\t\tif(!t1){\r\n\t\t\trdmAlert(\"起始时间节点不能为空!\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t\r\n\t\tif(!type){\r\n\t\t\trdmAlert(\"类别不能为空!\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t\r\n\t\topenLoader();\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.bug.BugUpdate\", \"updateData\", [t1, t2, type], goodSync);\r\n\t}\r\n\t\r\n\t/*\r\n\t * 全量更新\r\n\t * */\r\n\tfunction update_bug(){\r\n\t\tvar type = $(\"#bugType\").val();\r\n\t\t\r\n\t\tif(!type){\r\n\t\t\trdmAlert(\"类别不能为空!\");\r\n\t\t\treturn;\r\n\t\t}\r\n\t\t\r\n\t\tcustom_labelCall(\"com.bronzesoft.inspur.bug.BugUpdate\", \"updateAllData\", [type], goodSync);\r\n\t}\r\n\t\r\n\tfunction goodSync(d){\r\n\t\tif(d.trim() == \"Y\"){\r\n\t        getIMessage().init(\"更新成功\", 0);\r\n\t        window.location.reload();\r\n\t\t} else {\r\n\t\t\tgetIMessage().init(\"更新失败\", 1);\r\n\t\t}\r\n\t\tcloseLoader();\r\n\t}\r\n}\r\n\r\nif (custom_url.indexOf(\"/pages/entity/list.jsf?isGadget=Y&type=WF40\") >= 0) {\r\n\t/*\r\n\t * 更新预算数据\r\n\t * */\r\n\t$(function () {\r\n\t\tvar update = \"<input type='button' class='button' onclick='update_ebms();' value='全量更新'>\" +\r\n\t\t\"<input type='button' class='button' onclick='update_new_ebms();' value='增量更新'>\" + \r\n\t\t\"<input id='startDate' style='cursor: pointer;width: 100px;margin-left: 5px;margin-bottom: 5px;' class='inputText' onclick='iCalendar.setDay($(this));return false;' readonly='readonly' placeholder='更新时间(起始)'/>\" + \r\n\t\t\"<input id='endDate' style='cursor: pointer;width: 100px;margin-left: 5px;margin-bottom: 5px;' class='inputText' onclick='iCalendar.setDay($(this));return false;' readonly='readonly' placeholder='更新时间(结束)'/>\" + \r\n\t\t\"<input type='button' class='button' onclick='update_rest();' value='同步接口'>\";\r\n\t\t\r\n\t\tvar loginUserId = $(\".rdm-user\", window.parent.parent.document).attr(\"id\");\r\n\t\t\r\n\t\tif($(\".menuBarItem\") && loginUserId == \"33ba99dc-dc20-4b4b-b398-9c5e78e5735f\"){\r\n\t\t\t$(\".menuBarItem\").find(\".button:last\").after(update);\r\n\t\t}\r\n\t});\r\n\t\r\n\t/*\r\n\t * 按时间节点更新\r\n\t * t1:单独输入，按当前节点更新数据；\r\n\t * t2:与t1构成时间段，按时间段范围时间更新\r\n\t * */\r\n\tfunction update_new_ebms(){\r\n\t\tvar t1 = $(\"#startDate\").val();\r\n\t\tvar t2 = $(\"#endDate\").val();\r\n\t\t\r\n\t